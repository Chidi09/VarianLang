// Authentication Module for Varian & Zenith

// JWT Verification Middleware
fn jwt_middleware(secret) {
    return |req, next| {
        let auth_header = req.headers?.authorization
        if (auth_header == null) {
            return http.create_struct(
                ["status", "body", "content_type"],
                [401, "Missing Authorization header", "text/plain"]
            )
        }
        if (!auth_header.starts_with("Bearer ")) {
            return http.create_struct(
                ["status", "body", "content_type"],
                [401, "Invalid Authorization header format", "text/plain"]
            )
        }
        let token = auth_header.substring(7, auth_header.len())
        let payload = auth.verify_jwt(token, secret)
        if (payload == null) {
            return http.create_struct(
                ["status", "body", "content_type"],
                [401, "Invalid or expired token", "text/plain"]
            )
        }

        // Attach payload to req as req.user
        let keys = _validate.get_keys(req)
        let vals = []
        let i = 0
        while (i < keys.len()) {
            vals = vals.push(_validate.get_field(req, keys[i]))
            i = i + 1
        }
        keys = keys.push("user")
        vals = vals.push(payload)
        
        let req_with_user = http.create_struct(keys, vals)
        return next(req_with_user)
    }
}

// Session Actor
actor SessionStore {
    sessions: any // Map/Struct created dynamically
}

fn session_store_actor(self) {
    self.sessions = http.create_struct([], [])
    while (true) {
        let msg = receive()
        let action = _validate.get_field(msg, "action")
        let sid = _validate.get_field(msg, "sid")
        if (action == "get") {
            let user = _validate.get_field(self.sessions, sid)
            let reply_to = _validate.get_field(msg, "reply_to")
            reply_to <- user
        } else if (action == "set") {
            let user = _validate.get_field(msg, "user")
            // Update sessions by creating a new struct with new key/value
            let keys = _validate.get_keys(self.sessions)
            let vals = []
            let i = 0
            let replaced = false
            while (i < keys.len()) {
                if (keys[i] == sid) {
                    vals = vals.push(user)
                    replaced = true
                } else {
                    vals = vals.push(_validate.get_field(self.sessions, keys[i]))
                }
                i = i + 1
            }
            if (!replaced) {
                keys = keys.push(sid)
                vals = vals.push(user)
            }
            self.sessions = http.create_struct(keys, vals)
        } else if (action == "delete") {
            let keys = _validate.get_keys(self.sessions)
            let new_keys = []
            let new_vals = []
            let i = 0
            while (i < keys.len()) {
                if (keys[i] != sid) {
                    new_keys = new_keys.push(keys[i])
                    new_vals = new_vals.push(_validate.get_field(self.sessions, keys[i]))
                }
                i = i + 1
            }
            self.sessions = http.create_struct(new_keys, new_vals)
        }
    }
}

// Helper to extract cookie value
fn _extract_cookie(cookie_header, name) {
    if (cookie_header == null) { return null }
    let parts = cookie_header.split(";")
    let i = 0
    while (i < parts.len()) {
        let part = _sanitize.trim(parts[i])
        if (part.starts_with(name + "=")) {
            return part.substring(name.len() + 1, part.len())
        }
        i = i + 1
    }
    return null
}

// Session Middleware Builder
fn session_middleware(store_pid, cookie_name) {
    return |req, next| {
        let cookie_header = req.headers?.cookie
        let sid = _extract_cookie(cookie_header, cookie_name)
        let user = null

        if (sid != null) {
            let reply = task.channel(1)
            store_pid <- http.create_struct(
                ["action", "sid", "reply_to"],
                ["get", sid, reply]
            )
            user = <- reply
        }

        // Attach user (or null) to req.user
        let keys = _validate.get_keys(req)
        let vals = []
        let i = 0
        while (i < keys.len()) {
            vals = vals.push(_validate.get_field(req, keys[i]))
            i = i + 1
        }
        keys = keys.push("user")
        vals = vals.push(user)
        
        let req_with_user = http.create_struct(keys, vals)
        return next(req_with_user)
    }
}

// Global zenith_auth namespace object
let zenith_auth = http.create_struct(
    ["jwt", "session_store", "session", "hash_password", "verify_password"],
    [
        |secret| { return jwt_middleware(secret) },
        | | { return task.spawn(session_store_actor, []) },
        |store_pid, cookie_name| { return session_middleware(store_pid, cookie_name) },
        |password| { return auth.hash_password(password) },
        |password, hash| { return auth.verify_password(password, hash) }
    ]
)

// db.vn - Compile-time SQL generation + runtime parameter binding
//
// Query *shape* (table, fields, where field/op pairs, limit/offset, dialect)
// is static at almost every call site, so compile_select()/QueryBuilder.build()
// depend on nothing but that shape and are safe to evaluate inside a
// `comptime { ... }` block. The actual bind *values* are runtime-only and are
// supplied afterwards via bind(), which checks the value count against the
// shape before any SQL ever reaches the driver.

struct CompiledQuery { sql: string, param_count: int, dialect: string }
struct BoundQuery { sql: string, params: array }

// Pure function of query shape -> SQL text. No parameter values involved,
// so this can be called from inside `comptime { ... }` to bake the SQL
// string into the program at compile time.
fn compile_select(table, fields, wheres, limit_val, offset_val, dialect) {
    let sql = "SELECT "
    for i in 0..fields.len() {
        if i > 0 { sql = sql + ", " }
        sql = sql + fields[i]
    }
    sql = sql + " FROM " + table

    if wheres.len() > 0 {
        sql = sql + " WHERE "
        for i in 0..wheres.len() {
            if i > 0 { sql = sql + " AND " }
            let clause = wheres[i]
            let placeholder = "?"
            if dialect == "postgres" {
                let idx = i + 1
                placeholder = "$" + idx
            }
            sql = sql + clause[0] + " " + clause[1] + " " + placeholder
        }
    }

    if limit_val >= 0 { sql = sql + " LIMIT " + limit_val }
    if offset_val >= 0 { sql = sql + " OFFSET " + offset_val }

    return CompiledQuery { sql: sql, param_count: wheres.len(), dialect: dialect }
}

// Runtime wrapper: attaches concrete parameter values to a CompiledQuery,
// enforcing that the value count matches the shape's where-clause count
// before anything is sent to the driver.
fn bind(compiled, params) {
    if params.len() != compiled.param_count {
        throw("db.bind: expected " + compiled.param_count + " parameter(s), got " + params.len())
    }
    return BoundQuery { sql: compiled.sql, params: params }
}

fn run_sqlite(bound, conn) {
    return sqlite.query(conn, bound.sql, bound.params)
}

fn run_postgres(bound, conn) {
    return postgres.query(conn, bound.sql, bound.params)
}

// Runs body(conn) inside a transaction that is ALWAYS rolled back, even on
// success -- so a test can exercise real inserts/updates against a real
// connection without leaving residue for the next test to trip over.
fn test_transaction(conn, body) {
    sqlite.query(conn, "BEGIN")
    try {
        let result = body(conn)
        sqlite.query(conn, "ROLLBACK")
        return result
    } catch e {
        sqlite.query(conn, "ROLLBACK")
        throw(e)
    }
}

// Fluent builder over compile_select — same comptime-safety guarantee:
// every method only touches shape (table/fields/where field+op/limit/offset),
// never a bound value, so a full builder chain ending in .build() can be
// wrapped in `comptime { ... }` just like a bare compile_select() call.
struct QueryBuilder {
    table: string,
    select_fields: array,
    where_clauses: array,
    limit_val: int,
    offset_val: int,
    dialect: string
}

fn select(table) {
    return QueryBuilder {
        table: table,
        select_fields: ["*"],
        where_clauses: [],
        limit_val: -1,
        offset_val: -1,
        dialect: "sqlite"
    }
}

impl QueryBuilder {
    fn use_dialect(self, d) {
        self.dialect = d
        return self
    }

    fn fields(self, f_arr) {
        self.select_fields = f_arr
        return self
    }

    fn where(self, field, op) {
        self.where_clauses = self.where_clauses.push([field, op])
        return self
    }

    fn limit(self, l) {
        self.limit_val = l
        return self
    }

    fn offset(self, o) {
        self.offset_val = o
        return self
    }

    fn paginate(self, page, per_page) {
        if page < 1 {
            page = 1
        }
        self = self.limit(per_page)
        self = self.offset((page - 1) * per_page)
        return self
    }

    fn cursor_paginate(self, field, has_cursor, l) {
        if has_cursor {
            self = self.where(field, ">")
        }
        self = self.limit(l)
        return self
    }

    fn find_by_key(self, field) {
        self = self.where(field, "=")
        self = self.limit(1)
        return self
    }

    fn build(self) {
        return compile_select(self.table, self.select_fields, self.where_clauses,
                               self.limit_val, self.offset_val, self.dialect)
    }
}

// mail.vn - Send email two ways:
//   1. mail.send_smtp(...) -- raw SMTP, for a local dev relay (mailpit/MailHog)
//      or an internal unauthenticated relay. No TLS/AUTH support.
//   2. mail.send_resend(...) -- HTTP API via Resend, using http.post. This is
//      the path for any real provider (Resend, SendGrid, Postmark, ...) since
//      they all just want a POST with a Bearer token and a JSON body — the
//      mechanism doesn't need new native code, just a different vn_modules
//      wrapper per provider built on the same http.post primitive.

struct MailResult { ok: bool, body }

fn send_smtp(host, port, from, to, subject, body) {
    let ok = smtp.send(host, port, from, to, subject, body)
    return MailResult { ok: ok, body: null }
}

// Resend's HTTP API. http.post doesn't expose the response status code, so
// `ok` here only means "got a response back" -- inspect `.body` yourself for
// Resend's own success/error shape (a real `id` field vs. an error message).
fn send_resend(api_key, from, to, subject, body) {
    let headers = [
        "Authorization: Bearer " + api_key,
        "Content-Type: application/json"
    ]
    let payload = http.create_struct(
        ["from", "to", "subject", "text"],
        [from, [to], subject, body]
    )
    let resp = http.post("https://api.resend.com/emails", headers, json_encode(payload))
    return MailResult { ok: resp != null, body: resp }
}

// observe.vn - Structured logging + a Prometheus /metrics route helper.
// Pure Varian: logging is JSON lines to stdout, metrics formatting is plain
// string building. No native code needed -- this is a documented pattern on
// top of time.now_iso8601() / json_encode() / http.create_struct(), all of
// which already exist.

struct Logger { name: string }

fn new_logger(name) {
    return Logger { name: name }
}

let log = Logger { name: "app" }

impl Logger {
    fn _emit(self, level, msg, field_keys, field_values) {
        let keys = ["level", "logger", "msg", "ts"]
        let values = [level, self.name, msg, time.now_iso8601()]
        for i in 0..field_keys.len() {
            keys = keys.push(field_keys[i])
            values = values.push(field_values[i])
        }
        print(json_encode(http.create_struct(keys, values)))
    }

    fn info(self, msg) {
        self._emit("info", msg, [], [])
    }
    fn warn(self, msg) {
        self._emit("warn", msg, [], [])
    }
    fn error(self, msg) {
        self._emit("error", msg, [], [])
    }

    // Structured variants: extra context as parallel key/value arrays,
    // e.g. log.info_with("request handled", ["status", "path"], [200, "/"])
    fn info_with(self, msg, field_keys, field_values) {
        self._emit("info", msg, field_keys, field_values)
    }
    fn warn_with(self, msg, field_keys, field_values) {
        self._emit("warn", msg, field_keys, field_values)
    }
    fn error_with(self, msg, field_keys, field_values) {
        self._emit("error", msg, field_keys, field_values)
    }
}

// ─── Prometheus /metrics ───
//
// counter_names/counter_values are parallel arrays -- build them from
// whatever in-memory struct or Actor you're already tracking counts with.
fn metrics_text(counter_names, counter_values) {
    let out = ""
    for i in 0..counter_names.len() {
        let name = counter_names[i]
        out = out + "# HELP " + name + " " + name + " total\n"
        out = out + "# TYPE " + name + " counter\n"
        out = out + name + " " + counter_values[i] + "\n"
    }
    return out
}

// Drop straight into a ZenithApp: app.get("/metrics", metrics_handler(names, values), "Prometheus metrics")
//
// Built via http.create_struct rather than a `Response { ... }` literal:
// vn_modules/*.vn files are concatenated alphabetically (see docs/TOOLING.md),
// so observe.vn loads before zenith.vn -- a literal naming the `Response`
// struct here would reference a type that isn't registered with the parser
// yet. http.create_struct sidesteps that since http.serve()'s response
// writer only looks at field names ("status"/"body"/"content_type"), not
// the struct's type name.
fn metrics_handler(counter_names, counter_values) {
    return | req | {
        return http.create_struct(
            ["status", "body", "content_type"],
            [200, metrics_text(counter_names, counter_values), "text/plain; version=0.0.4"]
        )
    }
}

// queue.vn - Background job queue and cron

struct CronJob {
    stopped: bool
}

fn cron_worker(interval_ms, handler, job) {
    while !job.stopped {
        task.sleep(interval_ms)
        if job.stopped {
            return null
        }
        handler()
    }
}

fn cron(interval_ms, handler) {
    let job = CronJob { stopped: false }
    task.spawn(cron_worker, [interval_ms, handler, job])
    return job
}

struct WorkerPool {
    ch: channel,
    count: int,
    workers: int,
    stopped: bool
}

fn pool_worker(ch, pool) {
    while !pool.stopped {
        let job = <- ch
        if job == null {
            return null
        }
        try {
            job()
        } catch e {
            print("Worker caught error: " + e)
        }
    }
}

impl WorkerPool {
    fn spawn(self, worker_count) {
        self.ch = task.channel(1000)
        self.count = worker_count
        self.stopped = false
        let i = 0
        while i < worker_count {
            task.spawn(pool_worker, [self.ch, self])
            i = i + 1
        }
    }
    fn submit(self, job_fn) {
        if self.stopped {
            return null
        }
        self.ch <- job_fn
    }
    fn stop(self) {
        self.stopped = true
        task.close(self.ch)
    }
    fn close(self) {
        self.stop()
    }
}

// shield.vn - Security and protection middleware for Zenith

fn _join_strings(arr, sep) {
    let res = ""
    for i in 0..arr.len() {
        if i > 0 {
            res = res + sep
        }
        res = res + arr[i]
    }
    return res
}

// ─── CORS Middleware ───
fn cors(allow_origins, allow_methods, allow_headers) {
    return |req, next| {
        let origins_str = _join_strings(allow_origins, ", ")
        let methods_str = _join_strings(allow_methods, ", ")
        let headers_str = _join_strings(allow_headers, ", ")

        let cors_headers = http.create_struct(
            ["access_control_allow_origin", "access_control_allow_methods", "access_control_allow_headers"],
            [origins_str, methods_str, headers_str]
        )

        if req.method == "OPTIONS" {
            return http.create_struct(
                ["status", "body", "content_type", "headers"],
                [204, "", "text/plain", cors_headers]
            )
        }

        let resp = next(req)

        // Merge onto whatever headers an inner middleware/handler already
        // set, rather than replacing them outright -- this used to
        // silently discard e.g. csrf()'s Set-Cookie header whenever cors()
        // was registered before it (middleware wraps outside-in by
        // registration order, so an outer middleware's post-processing
        // runs *after* an inner one's, on the way back out).
        let existing_headers = _validate.get_field(resp, "headers")
        let merged_headers = cors_headers
        if existing_headers != null {
            let keys = _validate.get_keys(existing_headers)
            let vals = []
            for i in 0..keys.len() {
                vals = vals.push(_validate.get_field(existing_headers, keys[i]))
            }
            keys = keys.push("access_control_allow_origin").push("access_control_allow_methods").push("access_control_allow_headers")
            vals = vals.push(origins_str).push(methods_str).push(headers_str)
            merged_headers = http.create_struct(keys, vals)
        }

        return http.create_struct(
            ["status", "body", "content_type", "headers"],
            [resp.status, resp.body, resp.content_type, merged_headers]
        )
    };
}

// ─── Rate Limiting Middleware (in-memory, single-worker only) ───
//
// IMPORTANT: this tracks request counts in one Actor living inside one VM.
// Zenith's clustering (app.listen_cluster(port, workers)) runs each worker
// as a FULLY INDEPENDENT VM (its own heap, its own copy of every Actor) --
// there is no shared memory between workers. That means a clustered server
// using THIS middleware enforces max_reqs *per worker*, not per server: a
// client distributed across N workers can make up to N * max_reqs requests
// in one window before any single worker's limiter notices. For a
// clustered deployment, use rate_limit_redis() below instead, which
// coordinates across every worker through a shared Redis counter.
actor RateLimiterActor {
    ips: array = [],
    tokens: array = [],
    last_updated: array = [],
    max_tokens: int = 60,
    window_ms: int = 60000,

    fn init(self, max_t, win_ms) {
        self.ips = []
        self.tokens = []
        self.last_updated = []
        self.max_tokens = max_t
        self.window_ms = win_ms
    }

    fn check_limit(self, ip) -> bool {
        let now = time.now_ms()
        let idx = -1
        for i in 0..self.ips.len() {
            if self.ips[i] == ip {
                idx = i
                break
            }
        }

        if idx == -1 {
            self.ips = self.ips.push(ip)
            self.tokens = self.tokens.push(self.max_tokens - 1)
            self.last_updated = self.last_updated.push(now)
            return true
        }

        let elapsed = now - self.last_updated[idx]
        let regen = elapsed * self.max_tokens / self.window_ms
        let current_tokens = self.tokens[idx] + regen
        if current_tokens > self.max_tokens {
            current_tokens = self.max_tokens
        }

        if current_tokens >= 1 {
            self.tokens[idx] = current_tokens - 1
            self.last_updated[idx] = now
            return true
        } else {
            return false
        }
    }
}

fn rate_limit(max_reqs, window_ms) {
    let limiter = RateLimiterActor.spawn()
    limiter.init(max_reqs, window_ms)

    return |req, next| {
        let client_ip = req.ip
        if !limiter.check_limit(client_ip) {
            return http.create_struct(
                ["status", "body", "content_type"],
                [429, "Too Many Requests", "text/plain"]
            )
        }
        return next(req)
    };
}

// ─── Rate Limiting Middleware (Redis-backed, cluster-safe) ───
//
// Fixed-window counter: INCR a per-IP, per-window key and EXPIRE it once.
// Every worker (in-process or clustered) hits the same Redis instance, so
// the limit is enforced across the whole server, not per worker. Simpler
// than the in-memory token bucket above (bursts right at a window boundary
// can momentarily allow close to 2x max_reqs, a known fixed-window
// trade-off) but correctness under clustering matters more here than
// burst-smoothing precision.
fn rate_limit_redis(redis_conn, max_reqs, window_seconds) {
    return |req, next| {
        let window = time.now_ms() / (window_seconds * 1000)
        let key = "shield:ratelimit:" + req.ip + ":" + window

        let count = redis.cmd(redis_conn, "INCR", [key])
        if count == 1 {
            redis.cmd(redis_conn, "EXPIRE", [key, window_seconds])
        }

        if count > max_reqs {
            return http.create_struct(
                ["status", "body", "content_type"],
                [429, "Too Many Requests", "text/plain"]
            )
        }
        return next(req)
    };
}

// ─── CSRF Protection Middleware (signed double-submit cookie) ───
//
// On a safe method (GET/HEAD/OPTIONS), issues a random csrf_token cookie
// if the client doesn't already have one. On a state-changing method,
// requires the x-csrf-token header to match the csrf_token cookie value
// exactly (constant-time compare). This defeats both classic CSRF vectors:
// a cross-origin <form> submission can't set a custom header at all, and
// a cross-origin script can't read the victim's cookie (browser same-
// origin policy) to forge a matching header value -- it can only cause
// the cookie to be *sent* automatically, never *read* its contents.
//
// Varian functions have no default/optional parameters (a missing
// argument is a hard arity error, not a null), so this stays zero-arg to
// match every existing caller -- the cookie is issued without the Secure
// attribute. Serving exclusively over HTTPS in production and want it?
// Add "; Secure" to cookie_attrs below directly, or fork this function.
fn csrf() {
    let cookie_attrs = "Path=/; SameSite=Lax"

    return |req, next| {
        // NOTE: req.headers?.cookie is NOT safe here -- ?. only guards
        // against req.headers itself being nil; req.headers is a struct
        // built from whatever headers this specific client actually sent,
        // so a request with no Cookie header at all has a valid headers
        // struct that simply has no "cookie" field, and a plain .cookie
        // access on it throws ("Struct has no field 'cookie'") rather than
        // returning nil. _validate.get_field tolerates a missing field.
        let cookie_header = _validate.get_field(req.headers, "cookie")
        let existing_token = _extract_cookie(cookie_header, "csrf_token")

        if req.method == "GET" || req.method == "HEAD" || req.method == "OPTIONS" {
            let resp = next(req)
            if existing_token != null {
                return resp
            }
            // Issue a fresh token for this client; merge onto whatever
            // headers the handler itself already set. resp may be a plain
            // Response{...} literal with no "headers" field at all -- a
            // bare `resp.headers` would throw ("Struct has no field
            // 'headers'") rather than return nil, so this has to go
            // through the same nil-tolerant accessor session_middleware
            // and friends already use elsewhere in this codebase.
            let new_token = auth.generate_token(32)
            let set_cookie_val = "csrf_token=" + new_token + "; " + cookie_attrs
            let resp_headers = _validate.get_field(resp, "headers")
            if resp_headers == null {
                resp_headers = http.create_struct(["set_cookie"], [set_cookie_val])
            } else {
                let keys = _validate.get_keys(resp_headers).push("set_cookie")
                let vals = []
                for i in 0..(keys.len() - 1) {
                    vals = vals.push(_validate.get_field(resp_headers, keys[i]))
                }
                vals = vals.push(set_cookie_val)
                resp_headers = http.create_struct(keys, vals)
            }
            return http.create_struct(
                ["status", "body", "content_type", "headers"],
                [resp.status, resp.body, resp.content_type, resp_headers]
            )
        }

        let header_token = _validate.get_field(req.headers, "x_csrf_token")
        if existing_token == null || header_token == null || header_token == "" {
            return http.create_struct(
                ["status", "body", "content_type"],
                [403, "Forbidden: Missing CSRF Token", "text/plain"]
            )
        }
        if !auth.constant_time_eq(existing_token, header_token) {
            return http.create_struct(
                ["status", "body", "content_type"],
                [403, "Forbidden: Invalid CSRF Token", "text/plain"]
            )
        }

        return next(req)
    };
}

// storage.vn - Key/value blob storage, local filesystem backend.
//
// `key` maps directly to a relative path under `base_dir` (default ".storage"),
// created on first use. For S3/R2/GCS, there's no native module here -- use
// the existing python.run bridge to call boto3 directly (see
// examples/storage_s3_test.vn) rather than maintaining cloud SDK bindings in C.

struct Storage { base_dir: string }

fn new_storage(base_dir) {
    return Storage { base_dir: base_dir }
}

let default_storage = Storage { base_dir: ".storage" }

impl Storage {
    fn _path(self, key) {
        return self.base_dir + "/" + key
    }

    fn put(self, key, bytes) {
        io.mkdir(self.base_dir)
        return io.write_bytes(self._path(key), bytes)
    }

    fn get(self, key) {
        return io.read_bytes(self._path(key))
    }

    fn exists(self, key) {
        return io.exists(self._path(key))
    }

    fn delete(self, key) {
        return io.delete(self._path(key))
    }

    fn list(self) {
        let entries = io.list_dir(self.base_dir)
        if entries == null {
            return []
        }
        return entries
    }
}

fn storage_put(key, bytes) {
    return default_storage.put(key, bytes)
}

fn storage_get(key) {
    return default_storage.get(key)
}

fn storage_delete(key) {
    return default_storage.delete(key)
}

// Request Validation & Sanitization Module for Varian

// Helper to check if a value is nil or string
fn _validate_is_string(v) {
    try {
        _validate.min_len(v, 0)
        return true
    } catch e {
        return false
    }
}

struct Validator {
    _type_check: string,
    _checks: array,
    _transforms: array,
    _optional: bool
}

impl Validator {
    fn optional(self) {
        self._optional = true
        return self
    }

    // String checks
    fn is_email(self) {
        self._checks = self._checks.push(|v| {
            if (_validate.is_email(v)) { return null }
            return "Invalid email address"
        })
        return self
    }

    fn is_url(self) {
        self._checks = self._checks.push(|v| {
            if (_validate.is_url(v)) { return null }
            return "Invalid URL"
        })
        return self
    }

    fn is_alphanumeric(self) {
        self._checks = self._checks.push(|v| {
            if (_validate.is_alphanumeric(v)) { return null }
            return "Must be alphanumeric"
        })
        return self
    }

    fn is_uuid(self) {
        self._checks = self._checks.push(|v| {
            if (_validate.is_uuid(v)) { return null }
            return "Invalid UUID"
        })
        return self
    }

    fn min(self, limit) {
        self._checks = self._checks.push(|v| {
            if (self._type_check == "string") {
                if (_validate.min_len(v, limit)) { return null }
                return "Length must be at least " + limit
            } else if (self._type_check == "number") {
                if (v >= limit) { return null }
                return "Must be at least " + limit
            }
            return "Unsupported min check"
        })
        return self
    }

    fn max(self, limit) {
        self._checks = self._checks.push(|v| {
            if (self._type_check == "string") {
                if (_validate.max_len(v, limit)) { return null }
                return "Length must be at most " + limit
            } else if (self._type_check == "number") {
                if (v <= limit) { return null }
                return "Must be at most " + limit
            }
            return "Unsupported max check"
        })
        return self
    }

    // Sanitization/Transforms
    fn strip_html(self) {
        self._transforms = self._transforms.push(|v| {
            return _sanitize.strip_html(v)
        })
        return self
    }

    fn escape_html(self) {
        self._transforms = self._transforms.push(|v| {
            return _sanitize.escape_html(v)
        })
        return self
    }

    fn trim(self) {
        self._transforms = self._transforms.push(|v| {
            return _sanitize.trim(v)
        })
        return self
    }

    fn parse(self, v) {
        if (v == null) {
            if (self._optional) {
                return http.create_struct(["success", "data"], [true, null])
            }
            return http.create_struct(["success", "error"], [false, "Value is required"])
        }

        // Type verification
        if (self._type_check == "string") {
            if (!_validate_is_string(v)) {
                return http.create_struct(["success", "error"], [false, "Expected string"])
            }
        } else if (self._type_check == "number") {
            try {
                let dummy = v + 0
            } catch e {
                return http.create_struct(["success", "error"], [false, "Expected number"])
            }
        }

        // Apply transforms (sanitization)
        let current = v
        let i = 0
        while (i < self._transforms.len()) {
            let transform = self._transforms[i]
            current = transform(current)
            i = i + 1
        }

        // Apply checks
        let j = 0
        while (j < self._checks.len()) {
            let check = self._checks[j]
            let err = check(current)
            if (err != null) {
                return http.create_struct(["success", "error"], [false, err])
            }
            j = j + 1
        }

        return http.create_struct(["success", "data"], [true, current])
    }
}

struct ObjectValidator {
    _fields: any,
    _optional: bool
}

impl ObjectValidator {
    fn optional(self) {
        self._optional = true
        return self
    }

    fn parse(self, v) {
        if (v == null) {
            if (self._optional) {
                return http.create_struct(["success", "data"], [true, null])
            }
            return http.create_struct(["success", "error"], [false, "Value is required"])
        }

        // Verify it is actually a struct/object by calling _validate.get_keys
        let is_struct = true
        try {
            _validate.get_keys(v)
        } catch e {
            is_struct = false
        }
        if (!is_struct) {
            return http.create_struct(["success", "error"], [false, "Expected object"])
        }

        let schema_keys = _validate.get_keys(self._fields)
        let out_keys = []
        let out_vals = []

        let i = 0
        while (i < schema_keys.len()) {
            let key = schema_keys[i]
            let field_validator = _validate.get_field(self._fields, key)
            let val = _validate.get_field(v, key)

            let res = field_validator.parse(val)
            if (!res.success) {
                return http.create_struct(["success", "error"], [false, key + ": " + res.error])
            }

            out_keys = out_keys.push(key)
            out_vals = out_vals.push(res.data)
            i = i + 1
        }

        let validated_struct = http.create_struct(out_keys, out_vals)
        return http.create_struct(["success", "data"], [true, validated_struct])
    }
}

let validate = http.create_struct(
    ["str", "num", "object"],
    [
        | | { return Validator { _type_check: "string", _checks: [], _transforms: [], _optional: false } },
        | | { return Validator { _type_check: "number", _checks: [], _transforms: [], _optional: false } },
        |fields| { return ObjectValidator { _fields: fields, _optional: false } }
    ]
)

let sanitize = http.create_struct(
    ["strip_html", "escape_html", "trim"],
    [
        |v| { return _sanitize.strip_html(v) },
        |v| { return _sanitize.escape_html(v) },
        |v| { return _sanitize.trim(v) }
    ]
)

// zenith.vn - Zenith web framework
//
// - ZenithApp is a real instantiable struct: route tables, middleware, and
//   docs settings live per-instance instead of in shared module globals, so
//   you can build several independent apps in the same program.
// - Routing is a segment trie (radix-style router): each request walks one
//   node per path segment (O(depth)) instead of scanning every registered
//   route (O(routes)). The HTTP method is folded in as the trie's first
//   segment, so one tree handles all methods.
// - The OpenAPI document is built as real structs/arrays and serialized
//   once via json_encode, instead of hand-concatenated JSON strings.
// - listen() and the middleware "next" chain capture `self`/`app` directly
//   in real closures (value-copy upvalues) — no shared/global app slot.

struct Response { status: int, body: string, content_type: string, _keep_open: bool, headers }
struct Route { method: string, path: string, handler, summary: string, meta }
struct OpenApiInfo { title: string, version: string }
struct PathGroup { path_key: string, methods: array, ops: array }

fn _get_req_field(req, field, default_val) {
    let result = default_val
    try {
        let keys = _validate.get_keys(req)
        for i in 0..keys.len() {
            if keys[i] == field {
                result = _validate.get_field(req, field)
            }
        }
    } catch e {}
    return result
}

struct WebSocket {
    socket_fd: int,
    _buffer: string
}

impl WebSocket {
    fn read(self) {
        let incoming = http.read_socket(self.socket_fd, 4096)
        if incoming != null {
            self._buffer = self._buffer + incoming
        }

        if self._buffer.len() == 0 {
            if incoming == null {
                return null
            }
            return ""
        }

        if self._buffer.len() < 2 {
            return ""
        }

        let first = self._buffer.code_at(0)
        let second = self._buffer.code_at(1)

        let fin = math.bit_and(first, 128) != 0
        let opcode = math.bit_and(first, 15)
        let masked = math.bit_and(second, 128) != 0
        let payload_len = math.bit_and(second, 127)

        let header_len = 2
        if payload_len == 126 {
            if self._buffer.len() < 4 {
                return ""
            }
            let b1 = self._buffer.code_at(2)
            let b2 = self._buffer.code_at(3)
            payload_len = math.bit_or(b1 * 256, b2)
            header_len = 4
        } else if payload_len == 127 {
            if self._buffer.len() < 10 {
                return ""
            }
            let b5 = self._buffer.code_at(6)
            let b6 = self._buffer.code_at(7)
            let b7 = self._buffer.code_at(8)
            let b8 = self._buffer.code_at(9)
            payload_len = math.bit_or(math.bit_or(math.bit_or(b5 * 16777216, b6 * 65536), b7 * 256), b8)
            header_len = 10
        }

        let mask_offset = header_len
        if masked {
            header_len = header_len + 4
        }

        if self._buffer.len() < header_len + payload_len {
            return ""
        }

        let mask = []
        if masked {
            mask = [
                self._buffer.code_at(mask_offset),
                self._buffer.code_at(mask_offset + 1),
                self._buffer.code_at(mask_offset + 2),
                self._buffer.code_at(mask_offset + 3)
            ]
        }

        let payload_offset = header_len
        let payload_codes = []
        for i in 0..payload_len {
            let code = self._buffer.code_at(payload_offset + i)
            if masked {
                code = math.bit_xor(code, mask[i % 4])
            }
            payload_codes = payload_codes.push(code)
        }

        let decoded = "".from_codes(payload_codes)
        self._buffer = self._buffer.substring(header_len + payload_len, self._buffer.len())

        if opcode == 8 {
            return null
        }

        return decoded
    }

    fn write(self, text) {
        let payload_len = text.len()
        let frame_codes = [129]

        if payload_len <= 125 {
            frame_codes = frame_codes.push(payload_len)
        } else if payload_len <= 65535 {
            frame_codes = frame_codes.push(126)
            frame_codes = frame_codes.push(math.bit_and(payload_len / 256, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len, 255))
        } else {
            frame_codes = frame_codes.push(127)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(math.bit_and(payload_len / 16777216, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len / 65536, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len / 256, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len, 255))
        }

        for i in 0..payload_len {
            frame_codes = frame_codes.push(text.code_at(i))
        }

        let frame = "".from_codes(frame_codes)
        http.write_socket(self.socket_fd, frame)
    }

    fn close(self) {
        let close_frame = "".from_codes([136, 0])
        try {
            http.write_socket(self.socket_fd, close_frame)
        } catch e {}
        http.close_socket(self.socket_fd)
    }
}

struct SseSender {
    socket_fd: int
}

impl SseSender {
    fn send(self, data) {
        let chunk = "data: " + data + "\n\n"
        http.write_socket(self.socket_fd, chunk)
    }

    fn close(self) {
        http.close_socket(self.socket_fd)
    }
}

fn upgrade_websocket(req) {
    let headers = req.headers
    if headers == null {
        return null
    }
    let key = _get_req_field(headers, "sec_websocket_key", null)
    if key == null {
        return null
    }
    let accept_raw = key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
    let accept = auth.sha1_base64(accept_raw)

    let response = "HTTP/1.1 101 Switching Protocols\r\n" +
                   "Upgrade: websocket\r\n" +
                   "Connection: Upgrade\r\n" +
                   "Sec-WebSocket-Accept: " + accept + "\r\n\r\n"
    
    http.write_socket(req.socket_fd, response)
    
    return WebSocket {
        socket_fd: req.socket_fd,
        _buffer: ""
    }
}

fn sse_handshake(req) {
    let response = "HTTP/1.1 200 OK\r\n" +
                   "Content-Type: text/event-stream\r\n" +
                   "Cache-Control: no-cache\r\n" +
                   "Connection: keep-alive\r\n\r\n"
    http.write_socket(req.socket_fd, response)
    return SseSender { socket_fd: req.socket_fd }
}

struct RadixNode {
    static_keys: array,
    static_children: array,
    param_name: string,
    param_child,
    handler,
    summary: string
}

fn new_radix_node() {
    return RadixNode {
        static_keys: [],
        static_children: [],
        param_name: "",
        param_child: null,
        handler: null,
        summary: ""
    }
}

fn _split_path(path) {
    let raw = path.split("/")
    let segs = []
    for i in 0..raw.len() {
        if raw[i] != "" {
            segs = segs.push(raw[i])
        }
    }
    return segs
}

fn radix_insert(root, route_key, handler, summary) {
    let segs = _split_path(route_key)
    let node = root
    for i in 0..segs.len() {
        let seg = segs[i]
        if seg.starts_with(":") {
            if node.param_child == null {
                node.param_child = new_radix_node()
            }
            node.param_child.param_name = seg.substring(1, seg.len())
            node = node.param_child
        } else {
            let found = null
            for j in 0..node.static_keys.len() {
                if node.static_keys[j] == seg {
                    found = node.static_children[j]
                    break
                }
            }
            if found == null {
                found = new_radix_node()
                node.static_keys = node.static_keys.push(seg)
                node.static_children = node.static_children.push(found)
            }
            node = found
        }
    }
    node.handler = handler
    node.summary = summary
}

fn radix_lookup(root, route_key) {
    let segs = _split_path(route_key)
    let node = root
    let param_names = []
    let param_values = []
    for i in 0..segs.len() {
        let seg = segs[i]
        let next = null
        for j in 0..node.static_keys.len() {
            if node.static_keys[j] == seg {
                next = node.static_children[j]
                break
            }
        }
        if next == null && node.param_child != null {
            next = node.param_child
            param_names = param_names.push(next.param_name)
            param_values = param_values.push(seg)
        }
        if next == null {
            return null
        }
        node = next
    }
    if node.handler == null {
        return null
    }
    return http.create_struct(
        ["handler", "summary", "param_names", "param_values"],
        [node.handler, node.summary, param_names, param_values]
    )
}

// ─── App ───

struct ZenithApp {
    root: RadixNode,
    middlewares: array,
    route_list: array,
    docs_enabled: bool,
    docs_endpoint: string,
    static_mounts: array,
    title: string,
    schema_names: array,
    schema_values: array,
    port: int
}

fn new_app() {
    return ZenithApp {
        root: new_radix_node(),
        middlewares: [],
        route_list: [],
        docs_enabled: false,
        docs_endpoint: "/docs",
        static_mounts: [],
        title: "Zenith API",
        schema_names: [],
        schema_values: [],
        port: 8080
    }
}

// ─── Static file serving ───

struct StaticMount { prefix: string, directory: string }

fn _ends_with(s, suffix) {
    let s_len = s.len()
    let suf_len = suffix.len()
    if suf_len > s_len {
        return false
    }
    return s.substring(s_len - suf_len, s_len) == suffix
}

fn _mime_type_for_path(path) {
    if _ends_with(path, ".html") { return "text/html" }
    if _ends_with(path, ".css") { return "text/css" }
    if _ends_with(path, ".js") { return "application/javascript" }
    if _ends_with(path, ".json") { return "application/json" }
    if _ends_with(path, ".png") { return "image/png" }
    if _ends_with(path, ".jpg") { return "image/jpeg" }
    if _ends_with(path, ".jpeg") { return "image/jpeg" }
    if _ends_with(path, ".gif") { return "image/gif" }
    if _ends_with(path, ".svg") { return "image/svg+xml" }
    if _ends_with(path, ".ico") { return "image/x-icon" }
    if _ends_with(path, ".txt") { return "text/plain" }
    if _ends_with(path, ".pdf") { return "application/pdf" }
    if _ends_with(path, ".woff") { return "font/woff" }
    if _ends_with(path, ".woff2") { return "font/woff2" }
    return "application/octet-stream"
}

// Rejects any ".." path segment -- the one thing that matters for static
// file serving, since mount.directory + "/" + rel_path is otherwise just a
// plain filesystem path. ".." anywhere lets a request escape the mounted
// directory (e.g. GET /static/../../../etc/passwd).
fn _is_safe_relative_path(rel_path) {
    let segments = rel_path.split("/")
    for i in 0..segments.len() {
        if segments[i] == ".." {
            return false
        }
    }
    return true
}

// Returns a handler closure if `path` matches a registered static mount
// (whether or not the file actually exists -- a missing file still 404s
// through the normal handler/middleware chain rather than silently falling
// through to routing), or null if no mount's prefix matches at all.
fn _static_handler_for(app, path) {
    for i in 0..app.static_mounts.len() {
        let mount = app.static_mounts[i]
        if path.starts_with(mount.prefix) {
            let rel = path.substring(mount.prefix.len(), path.len())
            if !_is_safe_relative_path(rel) {
                return | req | {
                    return Response { status: 403, body: "Forbidden", content_type: "text/plain" }
                }
            }
            let full_path = mount.directory + "/" + rel
            return | req | {
                let bytes = io.read_bytes(full_path)
                if bytes == null {
                    return Response { status: 404, body: "Not Found", content_type: "text/plain" }
                }
                return Response { status: 200, body: bytes, content_type: _mime_type_for_path(full_path) }
            }
        }
    }
    return null
}

impl ZenithApp {
    fn _add_route(self, method, path, handler, summary, meta) {
        radix_insert(self.root, method + path, handler, summary)
        self.route_list = self.route_list.push(
            Route { method: method, path: path, handler: handler, summary: summary, meta: meta }
        )
    }

    fn register_schema(self, name, model_instance) {
        self.schema_names = self.schema_names.push(name)
        self.schema_values = self.schema_values.push(model_instance)
    }

    fn get(self, path, handler, summary, meta) {
        self._add_route("GET", path, handler, summary, meta)
    }

    fn post(self, path, handler, summary, meta) {
        self._add_route("POST", path, handler, summary, meta)
    }

    fn put(self, path, handler, summary, meta) {
        self._add_route("PUT", path, handler, summary, meta)
    }

    fn delete(self, path, handler, summary, meta) {
        self._add_route("DELETE", path, handler, summary, meta)
    }

    fn patch(self, path, handler, summary, meta) {
        self._add_route("PATCH", path, handler, summary, meta)
    }

    fn options(self, path, handler, summary, meta) {
        self._add_route("OPTIONS", path, handler, summary, meta)
    }

    // HEAD is routed like GET but the response body is dropped by the client;
    // we register it as its own method so an app can answer HEAD explicitly.
    fn head(self, path, handler, summary, meta) {
        self._add_route("HEAD", path, handler, summary, meta)
    }

    fn add_middleware(self, handler) {
        self.middlewares = self.middlewares.push(handler)
    }

    // Serves files under `directory` for any GET request whose path starts
    // with `prefix`. Runs through the normal middleware chain like any
    // other route (so CORS/logging/auth middleware still applies to static
    // assets) -- it's just a fallback when no explicit route matches.
    fn serve_static(self, prefix, directory) {
        self.static_mounts = self.static_mounts.push(StaticMount { prefix: prefix, directory: directory })
    }

    fn enable_docs(self, endpoint) {
        self.docs_enabled = true
        self.docs_endpoint = endpoint
        self.get("/openapi.json", |req| {
            let base_url = "http://localhost:" + self.port
            let spec = build_openapi_spec(self, base_url)
            return Response { status: 200, body: spec, content_type: "application/json" }
        }, "OpenAPI 3.0 specification", null)
        self.get("/swagger-ui.css", |req| {
            let css = io.read_text("Swagger UI.css")
            if css == null {
                return Response { status: 404, body: "CSS not found", content_type: "text/plain" }
            }
            return Response { status: 200, body: css, content_type: "text/css" }
        }, "Swagger UI custom stylesheet", null)
        self.get(endpoint, |req| {
            return _swagger_handler(self, req)
        }, "Swagger UI documentation", null)
    }

    // Synchronous request handling — usable directly in tests without a
    // running socket: app.handle(fake_req).
    fn handle(self, req) {
        let m = radix_lookup(self.root, req.method + req.path)
        let handler = null
        let params = null
        if m != null {
            handler = m.handler
            params = http.create_struct(m.param_names, m.param_values)
        } else if req.method == "GET" {
            handler = _static_handler_for(self, req.path)
        }
        let body = _get_req_field(req, "body", "")
        let json = _get_req_field(req, "json", null)
        let headers = _get_req_field(req, "headers", null)
        let ip = _get_req_field(req, "ip", "127.0.0.1")
        let socket_fd = _get_req_field(req, "socket_fd", -1)
        let query = _get_req_field(req, "query", "")

        let req2 = http.create_struct(
            ["method", "path", "query", "body", "json", "params", "_middleware_idx", "_route_handler", "headers", "ip", "socket_fd"],
            [req.method, req.path, query, body, json, params, 0, handler, headers, ip, socket_fd]
        )
        return _run_middleware(self, req2)
    }

    fn listen(self, port) {
        self.port = port
        print("Zenith running on http://localhost:", port)
        http.serve(port, |req| {
            return self.handle(req)
        })
    }

    // Forks `workers` OS processes sharing one listening socket -- the only
    // way to use more than one CPU core, since the task scheduler itself is
    // single-threaded. Open any DB/redis/etc. connections *inside* route
    // handlers (or otherwise after calling listen_cluster), not before --
    // a connection opened before the fork is a duplicated fd shared across
    // workers, which is unsafe for a stateful protocol.
    fn listen_cluster(self, port, workers) {
        self.port = port
        print("Zenith running on http://localhost:", port, "with", workers, "worker process(es)")
        http.serve(port, |req| {
            return self.handle(req)
        }, workers)
    }

    // HTTPS. cert_path/key_path are PEM files (e.g. from Let's Encrypt/
    // certbot, or a self-signed cert for local dev -- see
    // examples/tls_test.vn for how to generate one with openssl).
    //
    // Known gap: WebSocket/SSE upgrades (upgrade_websocket/sse_handshake)
    // write directly to the raw socket via http.write_socket(), which is
    // not TLS-aware -- wss:// is not supported yet, only plain https://
    // request/response (including app.serve_static()).
    fn listen_tls(self, port, cert_path, key_path) {
        self.port = port
        print("Zenith running on https://localhost:", port)
        http.serve_tls(port, |req| {
            return self.handle(req)
        }, cert_path, key_path)
    }

    // listen_tls() + listen_cluster()'s multi-process scaling combined.
    fn listen_tls_cluster(self, port, cert_path, key_path, workers) {
        self.port = port
        print("Zenith running on https://localhost:", port, "with", workers, "worker process(es)")
        http.serve_tls(port, |req| {
            return self.handle(req)
        }, cert_path, key_path, workers)
    }
}

fn _run_middleware(app, req) {
    let idx = req._middleware_idx
    if idx < app.middlewares.len() {
        let mw = app.middlewares[idx]
        let next_req = http.create_struct(
            ["method", "path", "body", "json", "params", "_middleware_idx", "_route_handler", "headers", "ip", "socket_fd"],
            [req.method, req.path, req.body, req.json, req.params, idx + 1, req._route_handler, req.headers, req.ip, req.socket_fd]
        )
        return mw(next_req, |r| {
            return _run_middleware(app, r)
        })
    } else {
        let handler = req._route_handler
        if handler == null {
            return Response { status: 404, body: "Not Found", content_type: "text/plain" }
        }
        return handler(req)
    }
}

// ─── OpenAPI ───

fn _convert_path(path_str) {
    let result = ""
    let remaining = path_str
    while remaining.len() > 0 {
        if remaining.starts_with("/") {
            result = result + "/"
            remaining = remaining.substring(1, remaining.len())
        } else if remaining.starts_with(":") {
            result = result + "{"
            remaining = remaining.substring(1, remaining.len())
            let slash = -1
            for j in 0..remaining.len() {
                if remaining.substring(j, j + 1) == "/" {
                    slash = j
                    break
                }
            }
            if slash < 0 {
                result = result + remaining + "}"
                remaining = ""
            } else {
                result = result + remaining.substring(0, slash) + "}"
                remaining = remaining.substring(slash, remaining.len())
            }
        } else {
            result = result + remaining.substring(0, 1)
            remaining = remaining.substring(1, remaining.len())
        }
    }
    return result
}

fn _val_to_schema(v) {
    if v == null {
        return http.create_struct(["type"], ["string"])
    }
    if v == true || v == false {
        return http.create_struct(["type"], ["boolean"])
    }
    let keys = _validate.get_keys(v)
    if keys != null {
        let prop_keys = []
        let prop_vals = []
        for i in 0..keys.len() {
            let key = keys[i]
            let field_val = _validate.get_field(v, key)
            prop_keys = prop_keys.push(key)
            prop_vals = prop_vals.push(_val_to_schema(field_val))
        }
        return http.create_struct(
            ["type", "properties"],
            ["object", http.create_struct(prop_keys, prop_vals)]
        )
    }
    if _validate.min_len(v, 0) {
        return http.create_struct(["type"], ["string"])
    }
    return http.create_struct(["type"], ["number"])
}

fn _val_to_ref(name) {
    return http.create_struct(["$ref"], ["#/components/schemas/" + name])
}

fn _json_content(schema) {
    return http.create_struct(
        ["application/json"],
        [http.create_struct(["schema"], [schema])]
    )
}

fn _response_with_schema(desc, schema) {
    return http.create_struct(
        ["description", "content"],
        [desc, _json_content(schema)]
    )
}

fn build_openapi_spec(app, base_url) {
    let groups = []
    for i in 0..app.route_list.len() {
        let route = app.route_list[i]
        let pkey = _convert_path(route.path)
        let method_name = route.method.lower()

        let op_keys = ["summary"]
        let op_vals = [route.summary]

        let resp_keys = []
        let resp_vals = []

        if route.meta != null {
            let req_schema = _validate.get_field(route.meta, "request_schema")
            let res_schema = _validate.get_field(route.meta, "response_schema")
            let res_status = _validate.get_field(route.meta, "response_status")
            let err_schema = _validate.get_field(route.meta, "error_schema")
            let err_status = _validate.get_field(route.meta, "error_status")
            let req_required = _validate.get_field(route.meta, "request_required")

            if req_schema != null and req_schema != "" {
                let required = true
                if req_required == false { required = false }
                op_keys = op_keys.push("requestBody")
                op_vals = op_vals.push(http.create_struct(
                    ["required", "content"],
                    [required, _json_content(_val_to_ref(req_schema))]
                ))
            }

            if res_schema != null and res_schema != "" {
                if res_status == null { res_status = 200 }
                let status_str = "" + res_status
                resp_keys = resp_keys.push(status_str)
                resp_vals = resp_vals.push(
                    _response_with_schema("OK", _val_to_ref(res_schema))
                )
            } else {
                resp_keys = ["200"]
                resp_vals = [http.create_struct(["description"], ["OK"])]
            }

            if err_schema != null and err_schema != "" {
                if err_status == null { err_status = 400 }
                let err_status_str = "" + err_status
                resp_keys = resp_keys.push(err_status_str)
                resp_vals = resp_vals.push(
                    _response_with_schema("Error", _val_to_ref(err_schema))
                )
            }
        } else {
            resp_keys = ["200"]
            resp_vals = [http.create_struct(["description"], ["OK"])]
        }

        op_keys = op_keys.push("responses")
        op_vals = op_vals.push(http.create_struct(resp_keys, resp_vals))

        let params = []
        let segs = route.path.split("/")
        for j in 0..segs.len() {
            if segs[j] != "" and segs[j].starts_with(":") {
                let param_name = segs[j].substring(1, segs[j].len())
                params = params.push(http.create_struct(
                    ["name", "in", "required", "schema"],
                    [param_name, "path", true, http.create_struct(["type"], ["string"])]
                ))
            }
        }
        if params.len() > 0 {
            op_keys = op_keys.push("parameters")
            op_vals = op_vals.push(params)
        }

        let op = http.create_struct(op_keys, op_vals)

        let group = null
        for j in 0..groups.len() {
            if groups[j].path_key == pkey {
                group = groups[j]
                break
            }
        }
        if group == null {
            group = PathGroup { path_key: pkey, methods: [], ops: [] }
            groups = groups.push(group)
        }
        group.methods = group.methods.push(method_name)
        group.ops = group.ops.push(op)
    }

    let path_keys = []
    let path_vals = []
    for i in 0..groups.len() {
        let g = groups[i]
        path_keys = path_keys.push(g.path_key)
        path_vals = path_vals.push(http.create_struct(g.methods, g.ops))
    }

    let components = null
    if app.schema_names.len() > 0 {
        let schema_keys = []
        let schema_vals = []
        for i in 0..app.schema_names.len() {
            let name = app.schema_names[i]
            let val = app.schema_values[i]
            schema_keys = schema_keys.push(name)
            schema_vals = schema_vals.push(_val_to_schema(val))
        }
        components = http.create_struct(
            ["schemas"],
            [http.create_struct(schema_keys, schema_vals)]
        )
    }

    let info = OpenApiInfo { title: app.title, version: "1.0.0" }
    let servers = [http.create_struct(["url"], [base_url])]
    
    let spec_keys = ["openapi", "info", "paths", "servers"]
    let spec_vals = ["3.0.0", info, http.create_struct(path_keys, path_vals), servers]
    if components != null {
        spec_keys = spec_keys.push("components")
        spec_vals = spec_vals.push(components)
    }
    
    let spec = http.create_struct(spec_keys, spec_vals)
    return json_encode(spec)
}

fn _swagger_handler(app, req) {
    let html = "<!DOCTYPE html>"
    html = html + "<html lang=\"en\">"
    html = html + "<head><meta charset=\"UTF-8\">"
    html = html + "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">"
    html = html + "<title>" + app.title + " Docs</title>"
    html = html + "<link rel=\"icon\" type=\"image/png\" href=\"data:image/png;base64,\">"
    html = html + "<link rel=\"stylesheet\" href=\"/swagger-ui.css\">"
    html = html + "<style> :root \{ --zenith-orange: #f95a29; --zenith-dark: #161616; --zenith-dark2: #1f1f1f; } body \{ margin: 0; background: var(--zenith-dark); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; } .zenith-header \{ display: flex; align-items: center; gap: 18px; padding: 22px 36px; background: linear-gradient(180deg, var(--zenith-dark2) 0%, var(--zenith-dark) 100%); border-bottom: 2px solid var(--zenith-orange); } .zenith-header img \{ height: 48px; } .zenith-header .zenith-title \{ color: #f5f5f5; font-size: 22px; font-weight: 700; letter-spacing: 1px; } .zenith-header .zenith-tagline \{ color: #cccccc; font-size: 13px; margin-top: 2px; } .swagger-ui .topbar \{ display: none; } .swagger-ui .btn.authorize, .swagger-ui .btn.execute \{ background-color: var(--zenith-orange); border-color: var(--zenith-orange); color: #fff; } .swagger-ui .opblock.opblock-get \{ border-color: var(--zenith-orange); background: rgba(249,90,41,0.05); } .swagger-ui .opblock.opblock-get .opblock-summary-method \{ background: var(--zenith-orange); } .swagger-ui .opblock.opblock-post .opblock-summary-method \{ background: #2e7d32; } .swagger-ui .opblock.opblock-delete .opblock-summary-method \{ background: #c62828; } .swagger-ui .opblock.opblock-put .opblock-summary-method \{ background: #6a1b9a; } .swagger-ui select, .swagger-ui input[type=text] \{ border-color: var(--zenith-orange); } .swagger-ui .filter .operation-filter-input \{ background: var(--zenith-dark2) !important; color: #ffffff !important; border: 2px solid var(--zenith-orange) !important; } ::selection \{ background: var(--zenith-orange); color: #fff; } .swagger-ui .opblock .opblock-summary-path, .swagger-ui .opblock .opblock-summary-path a, .swagger-ui .opblock .opblock-summary-description, .swagger-ui .opblock-tag, .swagger-ui .opblock-tag a, .swagger-ui .opblock-control-arrow \{ color: #ffffff !important; } .swagger-ui .info .title, .swagger-ui .info p, .swagger-ui .info .markdown, .swagger-ui .info .markdown p, .swagger-ui .info a, .swagger-ui .info .description, .swagger-ui .info .base-url \{ color: #ffffff !important; } .swagger-ui .parameter__name, .swagger-ui .parameter__type, .swagger-ui .parameter__in, .swagger-ui .parameters-col_description p, .swagger-ui .parameters-col_description input, .swagger-ui .parameters-col_description select \{ color: #ffffff !important; } .swagger-ui table thead tr td, .swagger-ui table thead tr th, .swagger-ui .response-col_status, .swagger-ui .response-col_description, .swagger-ui .response-col_links, .swagger-ui .responses-inner h4, .swagger-ui .responses-inner h5, .swagger-ui .response-col_description p \{ color: #ffffff !important; } .swagger-ui .model-box, .swagger-ui .model, .swagger-ui .model-title, .swagger-ui .model-title span, .swagger-ui .model-toggle, .swagger-ui .prop-type, .swagger-ui .prop-format, .swagger-ui .prop-const, .swagger-ui .property-row, .swagger-ui .property-row .property-name, .swagger-ui .property-row .property-type \{ color: #ffffff !important; } .swagger-ui section.models h4, .swagger-ui section.models .model-container, .swagger-ui .model-container .models-control, .swagger-ui .model-container .models-control span, .swagger-ui .markdown p, .swagger-ui .markdown pre, .swagger-ui .markdown code, .swagger-ui .markdown ul li, .swagger-ui .markdown ol li, .swagger-ui .scheme-container .schemes-title, .swagger-ui .scheme-container .schemes-server-container label \{ color: #ffffff !important; } .swagger-ui .btn, .swagger-ui .btn:hover, .swagger-ui .btn.cancel, .swagger-ui .btn.authorize, .swagger-ui .btn.execute \{ color: #ffffff !important; } .swagger-ui select, .swagger-ui label, .swagger-ui .response-content-type, .swagger-ui .parameter-content-type, .swagger-ui .opblock-section-header h4, .swagger-ui .opblock-section-header label, .swagger-ui .opblock-description-wrapper p, .swagger-ui .opblock-external-docs-wrapper p, .swagger-ui .opblock-body .opblock-section .opblock-section-header > label \{ color: #ffffff !important; } .swagger-ui .tab li, .swagger-ui .tab li.active, .swagger-ui .tab li button, .swagger-ui .tab li.active button \{ color: #ffffff !important; } </style>"
    html = html + "</head><body>"
    html = html + "<div class=\"zenith-header\"><img src=\"data:image/png;base64,\" alt=\"Zenith\"><div><div class=\"zenith-title\">" + app.title.upper() + "</div><div class=\"zenith-tagline\">Generated by Zenith -- built on Varian</div></div></div>"
    html = html + "<div id=\"swagger-ui\"></div>"
    html = html + "<script src=\"https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-bundle.js\"></script>"
    html = html + "<script>"
    html = html + "SwaggerUIBundle(\{"
    html = html + "url: '/openapi.json',"
    html = html + "dom_id: '#swagger-ui',"
    html = html + "filter: true,"
    html = html + "})"
    html = html + "</script>"
    html = html + "</body></html>"
    return Response { status: 200, body: html, content_type: "text/html" }
}

// ============================================================================
//  Request helpers — query strings, form bodies, cookies
//
//  Collections here are plain structs built with http.create_struct(): read a
//  field with _validate.get_field(s, key) (returns null when absent) and list
//  keys with _validate.get_keys(s). The query()/form()/cookie() accessors wrap
//  that so handler code never touches _validate directly.
// ============================================================================

fn _hex_nibble(c) {
    if c >= 48 and c <= 57 { return c - 48 }      // '0'..'9'
    if c >= 97 and c <= 102 { return c - 87 }     // 'a'..'f'
    if c >= 65 and c <= 70 { return c - 55 }      // 'A'..'F'
    return -1
}

// Percent-decode a URL-encoded component ("%20" -> space, "+" -> space).
// Invalid/short escapes are passed through literally rather than dropped.
fn url_decode(s) {
    if s == null { return "" }
    let out = []
    let n = s.len()
    let i = 0
    while i < n {
        let c = s.code_at(i)
        if c == 37 and i + 2 < n {                 // '%'
            let hi = _hex_nibble(s.code_at(i + 1))
            let lo = _hex_nibble(s.code_at(i + 2))
            if hi >= 0 and lo >= 0 {
                out = out.push(hi * 16 + lo)
                i = i + 3
            } else {
                out = out.push(c)
                i = i + 1
            }
        } else if c == 43 {                        // '+'
            out = out.push(32)
            i = i + 1
        } else {
            out = out.push(c)
            i = i + 1
        }
    }
    return "".from_codes(out)
}

// Parse "a=1&b=two&flag" into a struct {a:"1", b:"two", flag:""}, decoding
// both keys and values. Empty segments (e.g. trailing "&") are skipped.
fn parse_pairs(s) {
    let keys = []
    let vals = []
    if s == null or s == "" {
        return http.create_struct(keys, vals)
    }
    let pairs = s.split("&")
    for i in 0..pairs.len() {
        let p = pairs[i]
        if p == "" { continue }
        let eq = p.index_of("=")
        if eq < 0 {
            keys = keys.push(url_decode(p))
            vals = vals.push("")
        } else {
            keys = keys.push(url_decode(p.substring(0, eq)))
            vals = vals.push(url_decode(p.substring(eq + 1, p.len())))
        }
    }
    return http.create_struct(keys, vals)
}

// All query-string parameters as a struct.
fn query_params(req) {
    return parse_pairs(_get_req_field(req, "query", ""))
}

// A single query parameter, or `default` when absent.
fn query(req, key, default) {
    let v = _validate.get_field(query_params(req), key)
    if v == null { return default }
    return v
}

// All application/x-www-form-urlencoded body fields as a struct.
fn form_params(req) {
    return parse_pairs(_get_req_field(req, "body", ""))
}

// A single form field, or `default` when absent.
fn form(req, key, default) {
    let v = _validate.get_field(form_params(req), key)
    if v == null { return default }
    return v
}

// ── Cookies ────────────────────────────────────────────────────────────────

// Parse the inbound Cookie header ("a=1; b=2") into a struct.
fn cookies(req) {
    let keys = []
    let vals = []
    let headers = _get_req_field(req, "headers", null)
    let raw = null
    if headers != null {
        raw = _validate.get_field(headers, "cookie")
    }
    if raw == null or raw == "" {
        return http.create_struct(keys, vals)
    }
    let parts = raw.split(";")
    for i in 0..parts.len() {
        let p = _sanitize.trim(parts[i])
        if p == "" { continue }
        let eq = p.index_of("=")
        if eq < 0 { continue }
        keys = keys.push(p.substring(0, eq))
        vals = vals.push(url_decode(p.substring(eq + 1, p.len())))
    }
    return http.create_struct(keys, vals)
}

// A single inbound cookie value, or `default` when absent.
fn cookie(req, name, default) {
    let v = _validate.get_field(cookies(req), name)
    if v == null { return default }
    return v
}

// ============================================================================
//  Response helpers — headers, cookies, redirects
//
//  A Response carries an optional `headers` struct; the C response writer turns
//  each field "X_Foo" into the header "X-Foo". Field names are unique, so at
//  most one value per header name (one Set-Cookie per response).
// ============================================================================

// Return a copy of `resp` with header `name: value` set. `name` may use either
// dashes or underscores ("X-Frame-Options" / "X_Frame_Options").
fn with_header(resp, name, value) {
    let field = name.replace("-", "_")
    let keys = [field]
    let vals = [value]
    let existing = _get_req_field(resp, "headers", null)
    if existing != null {
        let ekeys = _validate.get_keys(existing)
        let nk = []
        let nv = []
        for i in 0..ekeys.len() {
            if ekeys[i] != field {
                nk = nk.push(ekeys[i])
                nv = nv.push(_validate.get_field(existing, ekeys[i]))
            }
        }
        nk = nk.push(field)
        nv = nv.push(value)
        keys = nk
        vals = nv
    }
    let hdrs = http.create_struct(keys, vals)
    return Response {
        status: _get_req_field(resp, "status", 200),
        body: _get_req_field(resp, "body", ""),
        content_type: _get_req_field(resp, "content_type", "text/plain"),
        _keep_open: false,
        headers: hdrs
    }
}

// Build a "Set-Cookie" header value. `opts` is an optional struct understanding
// max_age (int seconds), path, domain, http_only (bool), secure (bool) and
// same_site ("Strict"/"Lax"/"None"). Sensible secure defaults: when no opts are
// given the cookie is HttpOnly + SameSite=Lax + Path=/.
fn build_cookie(name, value, opts) {
    let s = name + "=" + value
    let path = "/"
    let http_only = true
    let secure = false
    let same_site = "Lax"
    let max_age = -1
    let domain = null
    if opts != null {
        let p = _validate.get_field(opts, "path")
        if p != null { path = p }
        let h = _validate.get_field(opts, "http_only")
        if h != null { http_only = h }
        let sc = _validate.get_field(opts, "secure")
        if sc != null { secure = sc }
        let ss = _validate.get_field(opts, "same_site")
        if ss != null { same_site = ss }
        let ma = _validate.get_field(opts, "max_age")
        if ma != null { max_age = ma }
        let dm = _validate.get_field(opts, "domain")
        if dm != null { domain = dm }
    }
    s = s + "; Path=" + path
    if domain != null { s = s + "; Domain=" + domain }
    if max_age >= 0 { s = s + "; Max-Age=" + max_age }
    if same_site != null { s = s + "; SameSite=" + same_site }
    if http_only { s = s + "; HttpOnly" }
    if secure { s = s + "; Secure" }
    return s
}

// Return a copy of `resp` with a Set-Cookie header for (name, value, opts).
fn set_cookie(resp, name, value, opts) {
    return with_header(resp, "Set-Cookie", build_cookie(name, value, opts))
}

// Expire a cookie immediately on the client.
fn clear_cookie(resp, name) {
    return with_header(resp, "Set-Cookie", name + "=; Path=/; Max-Age=0")
}

// 302 redirect to `url`.
fn redirect(url) {
    return redirect_with(url, 302)
}

// Redirect to `url` with an explicit status (301/302/303/307/308).
fn redirect_with(url, status) {
    return Response {
        status: status,
        body: "",
        content_type: "text/html",
        _keep_open: false,
        headers: http.create_struct(["Location"], [url])
    }
}

// JSON response helper: serialize `value` and set the JSON content type.
fn json_response(value, status) {
    return Response {
        status: status,
        body: json_encode(value),
        content_type: "application/json",
        _keep_open: false
    }
}

// ============================================================================
//  Sessions — stateless, signed with JWT (HMAC-SHA256)
//
//  The whole session payload lives in a signed cookie, so there is no
//  server-side store to keep in sync across cluster workers. Keep payloads
//  small and never put secrets in them: the value is signed (tamper-proof) but
//  NOT encrypted, so it is readable by the client. `secret` must be the same
//  across restarts/workers or existing sessions stop verifying.
// ============================================================================

// Sign `data` (a struct) into a session token.
fn session_sign(data, secret) {
    return auth.sign_jwt(data, secret)
}

// Read and verify the session from the "session" cookie. Returns the decoded
// payload struct, or null when missing/invalid/tampered.
fn session_get(req, secret) {
    let token = cookie(req, "session", null)
    if token == null { return null }
    return auth.verify_jwt(token, secret)
}

// Return a copy of `resp` that sets a signed session cookie carrying `data`.
fn session_set(resp, data, secret, opts) {
    let token = session_sign(data, secret)
    return set_cookie(resp, "session", token, opts)
}

// Log out: clear the session cookie.
fn session_clear(resp) {
    return clear_cookie(resp, "session")
}

// ============================================================================
//  Templating — render(template, ctx)
//
//  Supports, with arbitrary nesting:
//    <%= expr %>   interpolate, HTML-escaped (safe default)
//    <%- expr %>   interpolate, raw (no escaping)
//    <% if expr %> ... <% else %> ... <% endif %>
//    <% for x in items %> ... <% endfor %>
//  `expr` is a dotted path resolved against the context ("user.name"); inside a
//  for-loop the loop variable shadows the outer context. `ctx` is a struct
//  (use http.create_struct). Escaping-by-default makes the common case safe.
//
//  Delimiters are brace-free on purpose: Varian string literals already do
//  {expr} interpolation, so "<% %>" is what survives intact in an inline
//  template literal as well as one read from a file.
// ============================================================================

// Resolve a dotted path like "user.name" against a context struct.
fn _tpl_lookup(ctx, path) {
    if ctx == null { return null }
    let segs = path.split(".")
    let cur = ctx
    for i in 0..segs.len() {
        if cur == null { return null }
        cur = _validate.get_field(cur, segs[i])
    }
    return cur
}

fn _tpl_truthy(v) {
    if v == null { return false }
    if v == false { return false }
    if v == "" { return false }
    if v == 0 { return false }
    return true
}

// Shallow-copy `ctx` and override/add a single key — used to bind loop vars.
fn _tpl_bind(ctx, key, value) {
    let keys = [key]
    let vals = [value]
    if ctx != null {
        let ck = _validate.get_keys(ctx)
        for i in 0..ck.len() {
            if ck[i] != key {
                keys = keys.push(ck[i])
                vals = vals.push(_validate.get_field(ctx, ck[i]))
            }
        }
    }
    return http.create_struct(keys, vals)
}

// index_of starting at `from` (the builtin index_of always searches from 0).
fn _substr_index(s, needle, from) {
    if from >= s.len() { return -1 }
    let sub = s.substring(from, s.len())
    let idx = sub.index_of(needle)
    if idx < 0 { return -1 }
    return from + idx
}

// Find the next "<%" tag opener at or after `from`; returns its index or -1.
// (Brace-free delimiters are deliberate: Varian string literals use {expr}
//  interpolation, so any "{" inside an inline template literal would be eaten
//  by the lexer before render() ever ran. "<%" survives in both inline string
//  literals and templates loaded from files.)
fn _tpl_next_tag(tpl, from) {
    let i = from
    let n = tpl.len()
    while i < n - 1 {
        if tpl.code_at(i) == 60 and tpl.code_at(i + 1) == 37 {  // '<' '%'
            return i
        }
        i = i + 1
    }
    return -1
}

// Render the template region tpl[pos..stop) against ctx, returning a struct
// {out, pos, tag}. Recurses for nested if/for blocks. When `stop_tags` is
// non-null, rendering halts at the first "<% <kw> %>" whose keyword is in the
// list and reports that keyword back via "tag" so the caller (if/for) knows
// whether it hit else/endif/endfor.
//   <%= expr %>   interpolate, HTML-escaped
//   <%- expr %>   interpolate, raw
//   <% if/for/else/endif/endfor %>   control flow
fn _tpl_render_region(tpl, pos, stop, ctx, stop_tags) {
    let out = ""
    let i = pos
    while i < stop {
        let tag = _tpl_next_tag(tpl, i)
        if tag < 0 or tag >= stop {
            out = out + tpl.substring(i, stop)
            i = stop
        } else {
            out = out + tpl.substring(i, tag)
            let close = _substr_index(tpl, "%>", tag + 2)
            let marker = tpl.code_at(tag + 2)
            if marker == 61 or marker == 45 {       // '=' escaped, '-' raw
                let expr = _sanitize.trim(tpl.substring(tag + 3, close))
                let looked = _tpl_lookup(ctx, expr)
                let val = ""
                if looked != null { val = "" + looked }
                if marker == 45 {
                    out = out + val
                } else {
                    out = out + _sanitize.escape_html(val)
                }
                i = close + 2
            } else {                                // control-flow statement
                let directive = _sanitize.trim(tpl.substring(tag + 2, close))
                let after = close + 2
                if _tpl_is_stop(directive, stop_tags) {
                    return http.create_struct(["out", "pos", "tag"], [out, after, _tpl_keyword(directive)])
                }
                if directive.starts_with("if ") {
                    let res = _tpl_do_if(tpl, after, stop, ctx, _sanitize.trim(directive.substring(3, directive.len())))
                    out = out + _validate.get_field(res, "out")
                    i = _validate.get_field(res, "pos")
                } else if directive.starts_with("for ") {
                    let res = _tpl_do_for(tpl, after, stop, ctx, _sanitize.trim(directive.substring(4, directive.len())))
                    out = out + _validate.get_field(res, "out")
                    i = _validate.get_field(res, "pos")
                } else {
                    // Unknown directive: emit nothing, skip it.
                    i = after
                }
            }
        }
    }
    return http.create_struct(["out", "pos", "tag"], [out, i, ""])
}

fn _tpl_keyword(directive) {
    let sp = directive.index_of(" ")
    if sp < 0 { return directive }
    return directive.substring(0, sp)
}

fn _tpl_is_stop(directive, stop_tags) {
    if stop_tags == null { return false }
    let kw = _tpl_keyword(directive)
    for i in 0..stop_tags.len() {
        if stop_tags[i] == kw { return true }
    }
    return false
}

// Handle {% if expr %} body [{% else %} body] {% endif %}
fn _tpl_do_if(tpl, pos, stop, ctx, expr) {
    let truthy = _tpl_truthy(_tpl_lookup(ctx, expr))
    let first = _tpl_render_region(tpl, pos, stop, ctx, ["else", "endif"])
    let stopped = _validate.get_field(first, "tag")
    let out = ""
    if truthy {
        out = _validate.get_field(first, "out")
    }
    let cur = _validate.get_field(first, "pos")
    if stopped == "else" {
        let second = _tpl_render_region(tpl, cur, stop, ctx, ["endif"])
        if truthy == false {
            out = _validate.get_field(second, "out")
        }
        cur = _validate.get_field(second, "pos")
    }
    return http.create_struct(["out", "pos"], [out, cur])
}

// Handle {% for x in items %} body {% endfor %}
fn _tpl_do_for(tpl, pos, stop, ctx, header) {
    // header is "x in items"
    let inpos = header.index_of(" in ")
    let var_name = _sanitize.trim(header.substring(0, inpos))
    let list_expr = _sanitize.trim(header.substring(inpos + 4, header.len()))
    let items = _tpl_lookup(ctx, list_expr)
    let out = ""
    let body_end = pos
    if items != null {
        for j in 0..items.len() {
            let child = _tpl_bind(ctx, var_name, items[j])
            let res = _tpl_render_region(tpl, pos, stop, child, ["endfor"])
            out = out + _validate.get_field(res, "out")
            body_end = _validate.get_field(res, "pos")
        }
    }
    if body_end == pos {
        // Empty list: still consume the body up to {% endfor %} once.
        let res = _tpl_render_region(tpl, pos, stop, ctx, ["endfor"])
        body_end = _validate.get_field(res, "pos")
    }
    return http.create_struct(["out", "pos"], [out, body_end])
}

// Render a template string against a context struct.
fn render(template, ctx) {
    let res = _tpl_render_region(template, 0, template.len(), ctx, null)
    return _validate.get_field(res, "out")
}

// Convenience: a 200 text/html response from a rendered template.
fn render_response(template, ctx) {
    return Response {
        status: 200,
        body: render(template, ctx),
        content_type: "text/html",
        _keep_open: false
    }
}

use "examples/ecommerce/models.vn"
use "examples/ecommerce/db.vn"
use "examples/ecommerce/auth.vn"
use "examples/ecommerce/products.vn"
use "examples/ecommerce/finance.vn"

let app = new_app()
app.title = "Ecommerce API"

app.register_schema("AuthResult", AuthResult { error: "", token: "" })
app.register_schema("CheckoutResult", CheckoutResult { error: "", success: false, order_id: 0, total: 0.0 })
app.register_schema("FinanceResult", FinanceResult { error: "", success: false, new_balance: 0.0 })
app.register_schema("JwtPayload", JwtPayload { sub: 0, username: "" })
app.register_schema("RegisterRequest", RegisterRequest { username: "", password: "" })
app.register_schema("LoginRequest", LoginRequest { username: "", password: "" })
app.register_schema("CheckoutRequest", CheckoutRequest { product_id: 0, quantity: 0 })
app.register_schema("WithdrawRequest", WithdrawRequest { amount: 0.0 })
app.register_schema("ErrorResult", ErrorResult { error: "" })

app.add_middleware(|req, next| {
    print("[HTTP] " + req.method + " " + req.path)
    return next(req)
})

// Authentication Routes
app.post("/api/register", |req| {
    let username = req.json.username
    let password = req.json.password
    let res = auth_register(username, password)
    
    if res.error != null {
        return Response { status: 400, body: json_encode(http.create_struct(["error"], [res.error])), content_type: "application/json" }
    }
    return Response { status: 201, body: json_encode(http.create_struct(["token"], [res.token])), content_type: "application/json" }
}, "Register a new user", http.create_struct(
    ["request_schema", "response_schema", "response_status", "error_schema", "error_status"],
    ["RegisterRequest", "AuthResult", 201, "ErrorResult", 400]
))

app.post("/api/login", |req| {
    let username = req.json.username
    let password = req.json.password
    let res = auth_login(username, password)
    
    if res.error != null {
        return Response { status: 401, body: json_encode(http.create_struct(["error"], [res.error])), content_type: "application/json" }
    }
    return Response { status: 200, body: json_encode(http.create_struct(["token"], [res.token])), content_type: "application/json" }
}, "Login user", http.create_struct(
    ["request_schema", "response_schema", "error_schema", "error_status"],
    ["LoginRequest", "AuthResult", "ErrorResult", 401]
))

// Product Routes (Public)
app.get("/api/products", |req| {
    let products = list_products()
    return Response { status: 200, body: json_encode(products), content_type: "application/json" }
}, "List all products", null)

// Protected Routes (require JWT)
let secret = env.require("JWT_SECRET")
let require_auth = zenith_auth.jwt(secret)

// Store the checkout endpoint with the auth middleware
let checkout_handler = |req| {
    let uid = req.user.sub
    let pid = req.json.product_id
    let qty = req.json.quantity
    
    let res = checkout(uid, pid, qty)
    
    if !res.success {
        return Response { status: 400, body: json_encode(res), content_type: "application/json" }
    }
    return Response { status: 200, body: json_encode(res), content_type: "application/json" }
}

app.post("/api/checkout", |req| { return require_auth(req, checkout_handler) }, "Checkout a product", http.create_struct(
    ["request_schema", "response_schema", "error_schema", "error_status"],
    ["CheckoutRequest", "CheckoutResult", "ErrorResult", 400]
))

let withdraw_handler = |req| {
    let uid = req.user.sub
    let amount = req.json.amount
    let res = withdraw_funds(uid, amount)
    
    if !res.success {
        return Response { status: 400, body: json_encode(res), content_type: "application/json" }
    }
    return Response { status: 200, body: json_encode(res), content_type: "application/json" }
}

app.post("/api/withdraw", |req| { return require_auth(req, withdraw_handler) }, "Withdraw funds", http.create_struct(
    ["request_schema", "response_schema", "error_schema", "error_status"],
    ["WithdrawRequest", "FinanceResult", "ErrorResult", 400]
))

let balance_handler = |req| {
    let uid = req.user.sub
    let balance = get_balance(uid)
    return Response { status: 200, body: json_encode(http.create_struct(["balance"], [balance])), content_type: "application/json" }
}

app.get("/api/balance", |req| { return require_auth(req, balance_handler) }, "Get user balance", null)

app.enable_docs("/docs")

let port_str = env.get("PORT", "8080")
print("Modular Ecommerce Server running on http://localhost:" + port_str)
app.listen(8080)
