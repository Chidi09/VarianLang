// tests/lumen_m3_test.vn
// Test Milestone 3: Single-file component compilation, composition, and event routing

let COMP_LUMEN = "<template>" +
                 "<div class=\"child\">" +
                 "<p>Name: \{\{ name \}\}</p>" +
                 "<button @click=\"click_child\">Votes: \{\{ votes \}\}</button>" +
                 "</div>" +
                 "</template>" +
                 "<script>" +
                 "fn state() \{" +
                 "  return \{ votes: 0 \}" +
                 "\}" +
                 "fn click_child(s, v) \{" +
                 "  s.votes = s.votes + 1" +
                 "  return s" +
                 "\}" +
                 "</script>"

test "lumen_compile_source generates valid compiler output" {
    let code = lumen_compile_source("TestChild", COMP_LUMEN)
    assert_ne(code, null)
    assert_ne(code.index_of("fn _lumen_init_component_TestChild()"), -1)
    assert_ne(code.index_of("lumen_register_component(\"TestChild\""), -1)
    // Body must survive: these markers only exist if the emitted Varian braces
    // were escaped correctly (a raw "{" in the generator gets eaten by the
    // lexer as interpolation and silently truncates the function body).
    assert_ne(code.index_of("let _tpl ="), -1)
    assert_ne(code.index_of("return lumen_component("), -1)
    assert_ne(code.index_of("|s|"), -1)
    // The escaped template + extracted handler must be present.
    assert_ne(code.index_of("Name: "), -1)
    assert_ne(code.index_of("\"click_child\""), -1)
}

test "lumen_compile_source multi-line template is single-line-escaped" {
    // A template with real newlines must compile to a string literal with no
    // raw newlines, otherwise the generated .vn fails to parse.
    let src = "<template>\nLINE_A\nLINE_B\n</template>" +
              "<script>fn state() \{ return \{ x: 0 \} \}</script>"
    let code = lumen_compile_source("MultiLine", src)
    let tpl_start = code.index_of("let _tpl =")
    let tpl_line_end = code.index_of("\n", tpl_start)
    let tpl_line = code.substring(tpl_start, tpl_line_end)
    // The whole "let _tpl = \"...\"" assignment must fit on one physical line.
    assert_ne(tpl_line.index_of("LINE_A"), -1)
    assert_ne(tpl_line.index_of("LINE_B"), -1)
}

test "component composition and event routing" {
    let child_comp = lumen_component(
        | | { return { votes: 0 } },
        |s| { return lumen_render("<div class=\"child\"><p>Name: \{\{ name \}\}</p><button @click=\"click_child\">Votes: \{\{ votes \}\}</button></div>", s) },
        ["click_child"],
        [ |s, v| { s.votes = s.votes + 1; return s } ]
    )
    lumen_register_component("TestChild", child_comp)

    let parent_tpl = "<div><h1>Parent</h1><TestChild id=\"tc1\" name=\"Alice\" /></div>"
    let parent_state = { title: "App" }
    
    _lumen_active_child_states = {}
    let html = lumen_render(parent_tpl, parent_state)
    
    assert_ne(html.index_of("<div class=\"child\">"), -1)
    assert_ne(html.index_of("<p>Name: Alice</p>"), -1)
    assert_ne(html.index_of("data-lumen-click=\"tc1:click_child\""), -1)

    let child_state = _validate.get_field(_lumen_active_child_states, "tc1")
    assert_ne(child_state, null)
    assert_eq(child_state.name, "Alice")
    assert_eq(child_state.votes, 0)
}

test "lumen live round trip with child component event routing" {
    let child_comp = lumen_component(
        | | { return { votes: 0 } },
        |s| { return lumen_render("<div><button @click=\"click_child\">Votes: \{\{ votes \}\}</button></div>", s) },
        ["click_child"],
        [ |s, v| { s.votes = s.votes + 1; return s } ]
    )
    lumen_register_component("TestChildLive", child_comp)

    let parent_comp = lumen_component(
        | | { return { name: "Parent" } },
        |s| { return lumen_render("<div><TestChildLive id=\"tc_live\" /></div>", s) },
        [],
        []
    )

    let result = { msg: "" }
    let read_state = { count: 0 }
    
    let mock_ws = http.create_struct(
        ["read", "write"],
        [
            | | {
                if read_state.count == 0 {
                    read_state.count = 1
                    return "{" + "\"t\":\"event\",\"h\":\"tc_live:click_child\",\"v\":null" + "}"
                }
                return null
            },
            |msg| {
                result.msg = msg
            }
        ]
    )

    _lumen_live_loop(mock_ws, parent_comp, null, null)

    assert_ne(result.msg, "")
    assert_ne(result.msg.index_of("Votes: 1"), -1)
}
