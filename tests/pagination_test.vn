test "paginate page 1 defaults" {
    let p = paginate(1, 20)
    assert_eq(p.page, 1)
    assert_eq(p.per_page, 20)
    assert_eq(p.offset, 0)
    assert_eq(p.limit, 20)
}

test "paginate page 3 per_page 10" {
    let p = paginate(3, 10)
    assert_eq(p.page, 3)
    assert_eq(p.offset, 20)
    assert_eq(p.limit, 10)
}

test "paginate clamps page below 1" {
    let p = paginate(0, 10)
    assert_eq(p.page, 1)
}

test "paginate clamps per_page below 1" {
    let p = paginate(1, 0)
    assert_eq(p.per_page, 20)
}

test "paginate function exists" {
    assert_ne(paginate, null)
}
