__test_enable_arena()
let cache_a = null
let cache_b = null

fn make_and_store(key) {
    let s = Response { status: 200, body: "cached-" + key, content_type: "text/plain", _keep_open: false }
    if key == "a" {
        cache_a = s
    } else {
        cache_b = s
    }
    return s
}

make_and_store("a")
make_and_store("b")

// Force exactly what the scheduler's end-of-pass reap does to a recycled
// Task: reset the arena offset back to 0 so the NEXT allocation overwrites
// the same bytes the structs above used to occupy. If escape_promote()
// failed to copy cache_a/cache_b out of the arena when they were stored
// into these globals, this is the point where they'd start reading back
// garbage or another struct's data entirely.
__test_recycle_arena()

let i = 0
while (i < 200) {
    // Deliberately the same shape/size as the structs above, and a body
    // long enough to physically overwrite "cached-a"/"cached-b" if cache_a/
    // cache_b still pointed into the arena instead of a heap copy.
    let overwrite = Response { status: 999, body: "OVERWRITTEN-OVERWRITTEN-OVERWRITTEN-" + i, content_type: "junk", _keep_open: false }
    i = i + 1
}

assert_eq(cache_a.body, "cached-a")
assert_eq(cache_b.body, "cached-b")
print("arena escape test passed")
