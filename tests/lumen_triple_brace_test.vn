// Tests for {{{ }}} triple-brace raw unescaped interpolation
// {{{ expr }}} outputs the lookup value as raw HTML (no escape_html).
// {{ expr }} remains escaped (the default, safe behavior).

let O = "\{\{"
let C = "\}\}"
let TO = "\{\{\{"
let TC = "\}\}\}"

test "triple brace outputs raw HTML" {
    let tpl = "<div>" + TO + " title " + TC + "</div>"
    let html = lumen_render(tpl, http.create_struct(["title"], ["<b>bold</b>"]))
    assert_eq(html, "<div><b>bold</b></div>")
}

test "double brace still escapes HTML" {
    let tpl = "<p>" + O + " x " + C + "</p>"
    let html = lumen_render(tpl, http.create_struct(["x"], ["<br>"]))
    assert_eq(html, "<p>&lt;br&gt;</p>")
}

test "triple brace does not escape HTML" {
    let tpl = "<p>" + TO + " x " + TC + "</p>"
    let html = lumen_render(tpl, http.create_struct(["x"], ["<br>"]))
    assert_eq(html, "<p><br></p>")
}

test "triple brace no closing marker emits rest" {
    let tpl = "<div>" + TO + " no-close</div>"
    let html = lumen_render(tpl, http.create_struct([], []))
    assert_eq(html.contains("no-close"), true)
}
