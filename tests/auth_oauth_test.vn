test "normalize_oauth_user google" {
    let data = { id: "123", email: "a@b.com", name: "Alice", picture: "pic.jpg" }
    let n = _normalize_oauth_user("google", data)
    assert_eq(n.email, "a@b.com")
    assert_eq(n.provider, "google")
    assert_eq(n.name, "Alice")
}

test "normalize_oauth_user github" {
    let data = { id: 456, login: "octocat", email: "octo@github.com" }
    let n = _normalize_oauth_user("github", data)
    assert_eq(n.email, "octo@github.com")
    assert_eq(n.provider, "github")
}

test "normalize_oauth_user microsoft" {
    let data = { id: "xyz", mail: "user@contoso.com", displayName: "User" }
    let n = _normalize_oauth_user("microsoft", data)
    assert_eq(n.email, "user@contoso.com")
    assert_eq(n.provider, "microsoft")
}

test "normalize_oauth_user apple" {
    let data = { sub: "apple1", email: "a@privaterelay.apple.com" }
    let n = _normalize_oauth_user("apple", data)
    assert_eq(n.id, "apple1")
    assert_eq(n.provider, "apple")
}

test "normalize_oauth_user unknown returns null" {
    assert_eq(_normalize_oauth_user("unknown", {}), null)
}

test "url_encode basic" {
    assert_eq(_url_encode("abc"), "abc")
}

test "url_encode space" {
    assert_eq(_url_encode("a b"), "a+b")
}

test "url_encode null" {
    assert_eq(_url_encode(null), "")
}

test "hex_byte bounds" {
    assert_eq(_hex_byte(0), "00")
    assert_eq(_hex_byte(255), "FF")
    assert_eq(_hex_byte(65), "41")
}
