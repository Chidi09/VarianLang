    return "<div class=\"lmn-typing\"" + st + ">" +
        "<div class=\"lmn-typing-dot\"></div>" +
        "<div class=\"lmn-typing-dot\"></div>" +
        "<div class=\"lmn-typing-dot\"></div></div>"
}

// A tiny inline-SVG icon set (Lucide-style strokes) so <Feature icon="zap"> and
// friends need no asset pipeline. Unknown names render nothing.
fn lumen_icon(name) {
    let open = "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">"
    let close = "</svg>"
    if name == "zap"      { return open + "<polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\"></polygon>" + close }
    if name == "bolt"     { return lumen_icon("zap") }
    if name == "bars"     { return open + "<path d=\"M12 20v-6M6 20V10M18 20V4\"></path>" + close }
    if name == "code"     { return open + "<polyline points=\"16 18 22 12 16 6\"></polyline><polyline points=\"8 6 2 12 8 18\"></polyline>" + close }
    if name == "lock"     { return open + "<rect x=\"3\" y=\"11\" width=\"18\" height=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path>" + close }
    if name == "clock"    { return open + "<circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline>" + close }
    if name == "box"      { return open + "<path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"></path>" + close }
    if name == "layers"   { return open + "<polygon points=\"12 2 2 7 12 12 22 7 12 2\"></polygon><polyline points=\"2 17 12 22 22 17\"></polyline><polyline points=\"2 12 12 17 22 12\"></polyline>" + close }
    if name == "rocket"   { return open + "<path d=\"M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z\"></path><path d=\"M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z\"></path>" + close }
    if name == "check"    { return open + "<polyline points=\"20 6 9 17 4 12\"></polyline>" + close }
    if name == "shield"   { return open + "<path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path>" + close }
    return ""
}

// Register the built-in vocabulary. Runs at prelude load, so every template
// (live components and `vn dev` pages alike) can use these tags immediately.
lumen_register_component("Page", _ui_component(_ui_render_page))
lumen_register_component("Container", _ui_component(_ui_render_container))
lumen_register_component("Section", _ui_component(_ui_render_section))
lumen_register_component("Stack", _ui_component(_ui_render_stack))
