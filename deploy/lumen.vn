        name_html = "<div class=\"lmn-chat-msg-name\">" + _sanitize.escape_html("" + name) + "</div>"
    }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-chat-msg\" data-role=\"" + role + "\"" + st + ">" + name_html + content_html + "</div>"
}

fn _ui_render_chat_input(s) {
    let placeholder = _ui_prop(s, "placeholder", "Type a message...")
    let on = _validate.get_field(s, "on")
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    let click = ""
    if on != null { click = " @click=\"" + on + "\"" }
    return "<div class=\"lmn-chat-input\"" + st + ">" +
        "<input type=\"text\" placeholder=\"" + _sanitize.escape_html(placeholder) + "\" @keydown-enter=\"" + _sanitize.escape_html(_ui_prop(s, "on", "")) + "\" />" +
        "<button" + click + ">Send</button></div>"
}

fn _ui_render_typing_indicator(s) {
