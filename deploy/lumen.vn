// lumen.vn — Lumen, the Varian frontend framework (server-driven live).
//
// A Lumen component renders to HTML on the SERVER (on top of Zenith). Event
// bindings like @click are compiled to `data-lumen-*` hook attributes; a tiny
// client runtime forwards those events over a WebSocket, the server re-renders
// the component and patches the DOM. Logic is written in Varian — Lumen is to
// Varian what JSX is to TypeScript.
//
// This file is MILESTONE 1: the server-side renderer for Lumen's `{{ }}` markup
// syntax, plus the @event -> data-lumen-* rewrite that the (future) live client
// will hook into. The live WebSocket/DOM-diff layer and `.lumen` single-file
// component compilation are later milestones.
//
// Markup:
//   {{ expr }}                     interpolate, HTML-escaped (safe by default)
//   {{! expr }}                    interpolate, raw / unescaped (trusted only)
//   {{#if expr}} .. {{else}} .. {{/if}}
//   {{#each items as item}} .. {{/each}}
//   @click="handler"               -> data-lumen-click="handler"  (live hook)
//
// `expr` is resolved against the context struct (dotted paths supported), using
// the same lookup/truthy/bind helpers Zenith's template engine already uses.

// ─── small string helper: replace every `find` with `repl` ───
fn _lumen_replace(s, find, repl) {
    let out = ""
    let i = 0
    let n = s.len()
    let flen = find.len()
    while i < n {
        let hit = _substr_index(s, find, i)
        if hit < 0 {
            out = out + s.substring(i, n)
            i = n
        } else {
            out = out + s.substring(i, hit) + repl
            i = hit + flen
        }
    }
    return out
}

// Rewrite @event="..." attribute bindings into data-lumen-event="..." hooks.
// The live client runtime listens for these and forwards the event server-side.
fn _lumen_bind_events(html) {
    let events = ["click", "input", "change", "submit", "keydown", "keyup", "blur", "focus", "mouseover", "mouseout"]
    let out = html
    for i in 0..events.len() {
        out = _lumen_replace(out, "@" + events[i] + "=\"", "data-lumen-" + events[i] + "=\"")
    }
    return out
}

// Is `token` (e.g. "else", "/if", "/each") one of the tokens we should halt at?
fn _lumen_is_stop(token, stop_tags) {
    if stop_tags == null { return false }
    for i in 0..stop_tags.len() {
        if stop_tags[i] == token { return true }
    }
    return false
}

// Render tpl[pos..stop) against ctx. Halts at the first {{else}}/{{/if}}/{{/each}}
// whose token is in stop_tags, reporting it back via "tag". Returns {out,pos,tag}.
fn _lumen_render_region(tpl, pos, stop, ctx, stop_tags) {
    // Varian treats `{` as interpolation in strings, so the delimiters are
    // written with brace escapes: "\{\{" is the literal two-char open marker.
    let OPEN = "\{\{"
    let CLOSE = "\}\}"
    let out = ""
    let i = pos
    while i < stop {
        let tag = _substr_index(tpl, OPEN, i)
        if tag < 0 or tag >= stop {
            out = out + tpl.substring(i, stop)
            i = stop
        } else {
            out = out + tpl.substring(i, tag)
            let close = _substr_index(tpl, CLOSE, tag + 2)
            if close < 0 or close >= stop {
                // No closing braces — emit the rest verbatim.
                out = out + tpl.substring(tag, stop)
                i = stop
            } else {
                let marker = tpl.code_at(tag + 2)
                if marker == 33 {                 // '!' raw interpolation
                    let expr = _sanitize.trim(tpl.substring(tag + 3, close))
                    let looked = _tpl_lookup(ctx, expr)
                    let val = ""
                    if looked != null { val = "" + looked }
                    out = out + val
                    i = close + 2
                } else if marker == 123 {          // '{' — triple brace {{{ }}} raw unescaped
                    let triple_close = "\}\}\}"
                    let tclose = _substr_index(tpl, triple_close, tag + 3)
                    if tclose < 0 or tclose >= stop {
                        out = out + tpl.substring(tag, stop)
                        i = stop
                    } else {
                        let expr = _sanitize.trim(tpl.substring(tag + 3, tclose))
                        let looked = _tpl_lookup(ctx, expr)
                        let val = ""
                        if looked != null { val = "" + looked }
                        out = out + val   // raw — no escape_html
                        i = tclose + 3
                    }
                } else if marker == 35 {           // '#' block: if / each
                    let directive = _sanitize.trim(tpl.substring(tag + 3, close))
                    let after = close + 2
                    if directive.starts_with("if ") {
                        let res = _lumen_do_if(tpl, after, stop, ctx, _sanitize.trim(directive.substring(3, directive.len())))
                        out = out + _validate.get_field(res, "out")
                        i = _validate.get_field(res, "pos")
                    } else if directive.starts_with("each ") {
                        let res = _lumen_do_each(tpl, after, stop, ctx, _sanitize.trim(directive.substring(5, directive.len())))
                        out = out + _validate.get_field(res, "out")
                        i = _validate.get_field(res, "pos")
                    } else {
                        i = after
                    }
                } else if marker == 47 {           // '/' closing token: /if, /each
                    let token = "/" + _sanitize.trim(tpl.substring(tag + 3, close))
                    if _lumen_is_stop(token, stop_tags) {
                        return http.create_struct(["out", "pos", "tag"], [out, close + 2, token])
                    }
                    i = close + 2
                } else {
                    let inner = _sanitize.trim(tpl.substring(tag + 2, close))
                    if inner == "else" and _lumen_is_stop("else", stop_tags) {
                        return http.create_struct(["out", "pos", "tag"], [out, close + 2, "else"])
                    }
                    // {{ expr }} — escaped interpolation (safe by default)
                    let looked = _tpl_lookup(ctx, inner)
                    let val = ""
                    if looked != null { val = "" + looked }
                    out = out + _sanitize.escape_html(val)
                    i = close + 2
                }
            }
        }
    }
    return http.create_struct(["out", "pos", "tag"], [out, i, ""])
}

// {{#if expr}} body [{{else}} body] {{/if}}
fn _lumen_do_if(tpl, pos, stop, ctx, expr) {
    let truthy = _tpl_truthy(_tpl_lookup(ctx, expr))
    let first = _lumen_render_region(tpl, pos, stop, ctx, ["else", "/if"])
    let stopped = _validate.get_field(first, "tag")
    let out = ""
    if truthy { out = _validate.get_field(first, "out") }
    let cur = _validate.get_field(first, "pos")
    if stopped == "else" {
        let second = _lumen_render_region(tpl, cur, stop, ctx, ["/if"])
        if truthy == false { out = _validate.get_field(second, "out") }
        cur = _validate.get_field(second, "pos")
    }
    return http.create_struct(["out", "pos"], [out, cur])
}

// {{#each items as item}} body {{/each}}
fn _lumen_do_each(tpl, pos, stop, ctx, header) {
    let aspos = header.index_of(" as ")
    let list_expr = _sanitize.trim(header.substring(0, aspos))
    let var_name = _sanitize.trim(header.substring(aspos + 4, header.len()))
    let items = _tpl_lookup(ctx, list_expr)
    let out = ""
    let body_end = pos
    if items != null {
        for j in 0..items.len() {
            let child = _tpl_bind(ctx, var_name, items[j])
            let res = _lumen_render_region(tpl, pos, stop, child, ["/each"])
            out = out + _validate.get_field(res, "out")
            body_end = _validate.get_field(res, "pos")
        }
    }
    if body_end == pos {
        // Empty list: consume the body once so we land past {{/each}}.
        let res = _lumen_render_region(tpl, pos, stop, ctx, ["/each"])
        body_end = _validate.get_field(res, "pos")
    }
    return http.create_struct(["out", "pos"], [out, body_end])
}

let _lumen_active_child_states = null
let _lumen_component_names = []
let _lumen_components = []
// Global notification channel for async resource updates (capacity 64).
// Background resource tasks send `true` here when they finish fetching;
// _lumen_live_loop polls it to trigger re-renders.
let _lumen_async_updates = task.channel(64)
// Pub-sub registry: struct of topic → struct of key → value.
// All connections (tasks) share this; the single-threaded cooperative
// scheduler guarantees no races.
let _lumen_pubsub_data = http.create_struct([], [])
let _lumen_query_deps = http.create_struct([], [])
let _lumen_reactive_started = [false]
let _lumen_table_version = [http.create_struct([], [])]
let _lumen_qcache = [http.create_struct([], [])]
let _lumen_cache_stats = [http.create_struct(["hits", "misses"], [0, 0])]
let _lumen_watched_tables = [http.create_struct([], [])]

let _lumen_presence_data = http.create_struct([], [])
let _lumen_active_connections = []

fn _lumen_with_field(st, name, val) {
    let keys = _validate.get_keys(st)
    let vals = []
    let found = false
    for i in 0..keys.len() {
        if keys[i] == name {
            vals = vals.push(val)
            found = true
        } else {
            vals = vals.push(_validate.get_field(st, keys[i]))
        }
    }
    if found == false {
        keys = keys.push(name)
        vals = vals.push(val)
    }
    return http.create_struct(keys, vals)
}

fn lumen_presence_join(topic, user_id, meta) {
    let topic_pres = _validate.get_field(_lumen_presence_data, topic)
    if topic_pres == null {
        topic_pres = http.create_struct([], [])
    }
    topic_pres = _lumen_with_field(topic_pres, user_id, meta)
    _lumen_presence_data = _lumen_with_field(_lumen_presence_data, topic, topic_pres)
    _lumen_presence_broadcast(topic)
}

fn lumen_presence_leave(topic, user_id) {
    let topic_pres = _validate.get_field(_lumen_presence_data, topic)
    if topic_pres != null {
        let keys = _validate.get_keys(topic_pres)
        let nkeys = []
        let nvals = []
        for i in 0..keys.len() {
            if keys[i] != user_id {
                nkeys = nkeys.push(keys[i])
                nvals = nvals.push(_validate.get_field(topic_pres, keys[i]))
            }
        }
        topic_pres = http.create_struct(nkeys, nvals)
        _lumen_presence_data = _lumen_with_field(_lumen_presence_data, topic, topic_pres)
    }
    _lumen_presence_broadcast(topic)
}

fn lumen_presence_list(topic) {
    let topic_pres = _validate.get_field(_lumen_presence_data, topic)
    if topic_pres == null {
        return []
    }
    let keys = _validate.get_keys(topic_pres)
    let list = []
    for i in 0..keys.len() {
        let meta = _validate.get_field(topic_pres, keys[i])
        list = list.push(http.create_struct(["user_id", "meta"], [keys[i], meta]))
    }
    return list
}

fn _lumen_presence_broadcast(topic) {
    let plist = lumen_presence_list(topic)
    for i in 0.._lumen_active_connections.len() {
        let conn = _lumen_active_connections[i]
        if conn.topic == topic {
            let new_state = conn.state
            new_state = _lumen_with_field(new_state, "presence", plist)
            conn.state = new_state
            try {
                let html = (conn.component.render_fn)(new_state)
                let prev = conn.prev_html
                let res = _lumen_send_update(conn.ws, prev, html)
                conn.prev_html = html
            } catch e {}
        }
    }
}


fn lumen_register_component(name, component) {
    // Last registration wins: a user component overrides a built-in of the same
    // name (the built-in vocabulary registers first, at prelude load), and a
    // file recompiled by `vn dev` replaces its prior entry instead of stacking.
    for i in 0.._lumen_component_names.len() {
        if _lumen_component_names[i] == name {
            _lumen_components[i] = component
            return
        }
    }
    _lumen_component_names = _lumen_component_names.push(name)
    _lumen_components = _lumen_components.push(component)
}

fn _lumen_get_component(name) {
    for i in 0.._lumen_component_names.len() {
        if _lumen_component_names[i] == name {
            return _lumen_components[i]
        }
    }
    return null
}

// Rewrite `key={ expr }` to `key="{{ expr }}"` inside component opening tags.
// Uses brace-depth matching so nested braces (e.g. data={ {key: val} }) are
// handled correctly — finds the outer closing } rather than the first inner one.
fn _lumen_rewrite_prop_braces(html) {
    let out = []
    let i = 0
    let n = html.len()
    while i < n {
        let lt = html.index_of("<", i)
        if lt < 0 {
            out.append(html.substring(i, n))
            break
        }
        out.append(html.substring(i, lt))
        if lt + 1 < n {
            let nc = html.code_at(lt + 1)
            if nc >= 65 and nc <= 90 {
                let gt = html.index_of(">", lt)
                if gt < 0 {
                    out.append(html.substring(lt, n))
                    break
                }
                let tag_sub = html.substring(lt, gt + 1)
                let rew = []
                let j = 0
                let tn = tag_sub.len()
                while j < tn {
                    let eqb = tag_sub.index_of("={", j)
                    if eqb < 0 {
                        rew.append(tag_sub.substring(j, tn))
                        break
                    }
                    rew.append(tag_sub.substring(j, eqb + 1))
                    // Find matching closing brace with depth tracking
                    let depth = 1
                    let close = eqb + 2
                    let in_str = false
                    while close < tn and depth > 0 {
                        let cc = tag_sub.code_at(close)
                        if in_str {
                            if cc == 34 { in_str = false }  // "
                            if cc == 92 and close + 1 < tn { close = close + 1 }  // \
                        } else if cc == 34 {                // "
                            in_str = true
                        } else if cc == 123 {               // {
                            depth = depth + 1
                        } else if cc == 125 {               // }
                            depth = depth - 1
                        }
                        if depth > 0 { close = close + 1 }
                    }
                    if close >= tn or depth > 0 {
                        rew.append(tag_sub.substring(eqb + 1, tn))
                        break
                    }
                    let inner = _sanitize.trim(tag_sub.substring(eqb + 2, close))
                    rew.append("\"\{\{")
                    rew.append(inner)
                    rew.append("}}\"")
                    j = close + 1
                }
                out.append(rew.join(""))
                i = gt + 1
            } else {
                out.append("<")
                i = lt + 1
            }
        } else {
            out.append("<")
            i = lt + 1
        }
    }
    return out.join("")
}

fn _lumen_parse_attrs(attr_str) {
    let keys = []
    let vals = []
    let i = 0
    let n = attr_str.len()
    while i < n {
        while i < n and attr_str.code_at(i) <= 32 { i = i + 1 }
        if i >= n { break }
        let eq = attr_str.index_of("=", i)
        if eq < 0 { break }
        let key = _sanitize.trim(attr_str.substring(i, eq))
        let quote_pos = eq + 1
        while quote_pos < n and attr_str.code_at(quote_pos) <= 32 { quote_pos = quote_pos + 1 }
        if quote_pos >= n { break }
        let quote_char = attr_str.substring(quote_pos, quote_pos + 1)
        if quote_char != "\"" and quote_char != "'" { break }
        let close_quote = attr_str.index_of(quote_char, quote_pos + 1)
        if close_quote < 0 { break }
        let val = attr_str.substring(quote_pos + 1, close_quote)
        keys = keys.push(key)
        vals = vals.push(val)
        i = close_quote + 1
    }
    return http.create_struct(keys, vals)
}

fn _lumen_rewrite_child_events(html, child_id) {
    let events = ["click", "input", "change", "submit", "keydown", "keyup", "blur", "focus", "mouseover", "mouseout"]
    let out = html
    for i in 0..events.len() {
        let attr = "data-lumen-" + events[i] + "=\""
        out = _lumen_replace(out, attr, attr + child_id + ":")
    }
    return out
}

fn _lumen_process_composition(html, state) {
    let n = html.len()

    // M9 fast path: a component tag is a "<" followed by an uppercase letter.
    // If the markup has none (every leaf component, the common case), skip the
    // full char-by-char rebuild and its allocations — just return the input.
    let scan = 0
    let found_comp = false
    while scan < n {
        let lt = html.index_of("<", scan)
        if lt < 0 { break }
        if lt + 1 < n {
            let nc = html.code_at(lt + 1)
            if nc >= 65 and nc <= 90 { found_comp = true; break }
        }
        scan = lt + 1
    }
    if found_comp == false { return html }

    let out = ""
    let i = 0
    let child_counts = {}

    while i < n {
        let tag_start = html.index_of("<", i)
        if tag_start < 0 {
            out = out + html.substring(i, n)
            break
        }
        out = out + html.substring(i, tag_start)

        let is_comp = false
        if tag_start + 1 < n {
            let next_char = html.code_at(tag_start + 1)
            if next_char >= 65 and next_char <= 90 {
                is_comp = true
            }
        }

        if is_comp == false {
            out = out + "<"
            i = tag_start + 1
            continue
        }

        let tag_end = html.index_of(">", tag_start)
        if tag_end < 0 {
            out = out + html.substring(tag_start, n)
            break
        }

        let tag_content = html.substring(tag_start + 1, tag_end)
        let is_self_closing = false
        if tag_content.ends_with("/") {
            is_self_closing = true
            tag_content = tag_content.substring(0, tag_content.len() - 1)
        }

        let space_pos = tag_content.index_of(" ")
        let comp_name = ""
        let attrs_str = ""
        if space_pos < 0 {
            comp_name = _sanitize.trim(tag_content)
        } else {
            comp_name = _sanitize.trim(tag_content.substring(0, space_pos))
            attrs_str = tag_content.substring(space_pos + 1, tag_content.len())
        }

        let comp = _lumen_get_component(comp_name)
        if comp == null {
            let slash_str = ""
            if is_self_closing { slash_str = "/" }
            out = out + "<" + tag_content + slash_str + ">"
            i = tag_end + 1
            continue
        }

        let raw_attrs = _lumen_parse_attrs(attrs_str)
        let child_id = _validate.get_field(raw_attrs, "id")
        if child_id == null {
            let current_count = _validate.get_field(child_counts, comp_name)
            if current_count == null { current_count = 0 }
            child_id = comp_name + "_" + current_count
            child_counts = _tpl_bind(child_counts, comp_name, current_count + 1)
        }

        if _lumen_active_child_states == null {
            _lumen_active_child_states = {}
        }
        let child_state = _validate.get_field(_lumen_active_child_states, child_id)
        if child_state == null {
            child_state = (comp.state_fn)()
            child_state = _tpl_bind(child_state, "_comp", comp_name)
            child_state = _tpl_bind(child_state, "_id", child_id)
        }

        let attr_keys = _validate.get_keys(raw_attrs)
        for k in 0..attr_keys.len() {
            let key = attr_keys[k]
            if key != "id" {
                let val = _validate.get_field(raw_attrs, key)
                child_state = _tpl_bind(child_state, key, val)
            }
        }

        // ─── M6: slots ───
        // For a paired tag <Comp>..inner..</Comp>, the inner markup is the
        // component's `children`. It's already interpolated against the parent
        // context (composition runs after lumen_render's {{ }} pass), so we just
        // recursively process it for nested components, then inject it into the
        // child's {{! children }} slot AFTER the child's own events are scoped.
        // A placeholder keeps the two event scopes from colliding: the child's
        // own @events get the child_id prefix; the slot content (already final)
        // is spliced in untouched.
        let next_i = tag_end + 1
        let slot_html = ""
        let has_slot = false
        if is_self_closing == false {
            let close_tag = "</" + comp_name + ">"
            let close_tag_pos = html.index_of(close_tag, tag_end)
            if close_tag_pos >= 0 {
                let inner = html.substring(tag_end + 1, close_tag_pos)
                slot_html = _lumen_process_composition(inner, state)
                has_slot = true
                next_i = close_tag_pos + close_tag.len()
            }
        }
        if has_slot {
            child_state = _tpl_bind(child_state, "children", "<!--lumen-slot-->")
        }
        _lumen_active_child_states = _tpl_bind(_lumen_active_child_states, child_id, child_state)

        let child_html = (comp.render_fn)(child_state)
        let child_html_rewritten = _lumen_rewrite_child_events(child_html, child_id)
        if has_slot {
            child_html_rewritten = _lumen_replace(child_html_rewritten, "<!--lumen-slot-->", slot_html)
        }
        out = out + child_html_rewritten
        i = next_i
    }
    return out
}

// Escapes template text for embedding in a generated Varian string literal.
// Backed by the native `_lumen_escape_str` (O(n)); the old pure-Varian loop was
// O(n^2) and OOM-killed the compiler on large pages (docs/book pages). Kept as a
// thin wrapper so call sites and tests are unchanged.
fn _lumen_escape_string(s) {
    return _lumen_escape_str(s)
}

// True if `ch` (a single character) is an identifier character. Returns a real
// bool (an explicit if/return): `>=` yields an int 0/1 in Varian, and `0 ==
// false` is false, so callers that compare `== false` need a genuine boolean.
fn _lumen_is_ident_char(ch) {
    let alphabet = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
    if alphabet.index_of(ch) >= 0 { return true }
    return false
}

// True if `name` is a plain identifier (non-empty, ident chars only). Guards the
// extractor against treating a stray `fn ` followed by junk as a handler.
fn _lumen_is_simple_ident(name) {
    if name.len() == 0 { return false }
    for k in 0..name.len() {
        if _lumen_is_ident_char(name.substring(k, k + 1)) == false { return false }
    }
    return true
}

fn _lumen_extract_fns(script) {
    // Collect top-level `fn name(...)` handler names from a component <script>.
    // The hard part is NOT line position (handlers can sit on one line with no
    // newlines, e.g. `}fn b(`) but distinguishing a real `fn` from one that
    // appears inside a string literal — code samples stored in an examples map
    // would otherwise register phantom handlers and crash the page. So we scan
    // structurally: a `fn ` only counts when we are NOT inside a string ("..."
    // or '...', escapes honored) and NOT inside a // or /* */ comment, and it
    // sits at a word boundary. `state` is the reserved init fn, never a handler.
    let names = []
    let n = script.len()
    let i = 0
    while i < n {
        let c = script.substring(i, i + 1)
        if c == "/" and i + 1 < n and script.substring(i + 1, i + 2) == "/" {
            let nl = script.index_of("\n", i)
            if nl < 0 { break }
            i = nl + 1
        } else if c == "/" and i + 1 < n and script.substring(i + 1, i + 2) == "*" {
            let close = script.index_of("*/", i + 2)
            if close < 0 { break }
            i = close + 2
        } else if c == "\"" or c == "'" {
            let quote = c
            i = i + 1
            while i < n {
                let d = script.substring(i, i + 1)
                if d == "\\" { i = i + 2 }
                else if d == quote { i = i + 1; break }
                else { i = i + 1 }
            }
        } else if c == "f" and i + 3 <= n and script.substring(i, i + 3) == "fn " {
            let boundary = (i == 0)
            if i > 0 {
                if _lumen_is_ident_char(script.substring(i - 1, i)) == false { boundary = true }
            }
            if boundary {
                let name_start = i + 3
                let open_paren = script.index_of("(", name_start)
                if open_paren > name_start {
                    let name = _sanitize.trim(script.substring(name_start, open_paren))
                    if name != "state" and _lumen_is_simple_ident(name) {
                        names = names.push(name)
                    }
                }
            }
            i = i + 3
        } else {
            i = i + 1
        }
    }
    return names
}

// ─── Lumen imports — explicit component dependencies ───
//
// A .lumen <script> may begin with import lines, the way Svelte/Vue SFCs do:
//
//     import Hero from "./components/Hero.lumen"     // a local component file
//     import { Button, Card, Stack } from "lumen/ui" // the built-in vocabulary
//
// This replaces the old "every file in pages/components is a magic global" model
// with a real dependency graph: a page declares what it uses, the build resolves
// and compiles exactly those files, and using a tag you never imported (and that
// isn't a built-in) is a build error instead of a silent global lookup.
//
// Imports are a *compiler* directive (handled here), not Varian syntax — they are
// stripped out before the <script> body is emitted as Varian, just like Svelte
// processes its own imports. Each import is a struct { names: [...], path: "..." }.

fn _lumen_parse_import_line(line) {
    // line already trimmed and known to start with "import ".
    let rest = _sanitize.trim(line.substring(7, line.len()))
    let from_pos = rest.index_of(" from ")
    if from_pos < 0 { return null }
    let lhs = _sanitize.trim(rest.substring(0, from_pos))
    let rhs = _sanitize.trim(rest.substring(from_pos + 6, rest.len()))

    // Path is the quoted string on the right.
    let q = rhs.index_of("\"")
    if q < 0 { q = rhs.index_of("'") }
    if q < 0 { return null }
    let qc = rhs.substring(q, q + 1)
    let q2 = rhs.index_of(qc, q + 1)
    if q2 < 0 { return null }
    let path = rhs.substring(q + 1, q2)

    // Names: either `Name` or `{ A, B, C }`.
    let names = []
    if lhs.starts_with("{") {
        let close = lhs.index_of("}")
        if close < 0 { close = lhs.len() }
        let inner = lhs.substring(1, close)
        let parts = inner.split(",")
        for i in 0..parts.len() {
            let nm = _sanitize.trim(parts[i])
            if nm != "" { names = names.push(nm) }
        }
    } else if lhs != "" {
        names = names.push(_sanitize.trim(lhs))
    }
    return http.create_struct(["names", "path"], [names, path])
}

// Pull the leading `import ... from "..."` block off the top of a script.
// Imports must come first (as in JS/Svelte): we scan only the import region
// line-by-line, then slice the rest of the script as the body in one shot — O(n),
// not the O(n^2) of rebuilding the body line-by-line (which OOM'd large pages).
// Returns { imports: [ {names,path}, ... ], body: "<script without the imports>" }.
fn _lumen_extract_imports(script) {
    let imports = []
    let n = script.len()
    let pos = 0
    let body_start = 0
    let scanning = true
    while scanning and pos < n {
        let nl = script.index_of("\n", pos)
        let line_end = nl
        if line_end < 0 { line_end = n }
        let line = _sanitize.trim(script.substring(pos, line_end))
        if line == "" {
            pos = line_end + 1
            body_start = pos
        } else if line.starts_with("import ") and line.index_of(" from ") >= 0 {
            let imp = _lumen_parse_import_line(line)
            if imp != null { imports = imports.push(imp) }
            pos = line_end + 1
            body_start = pos
        } else {
            scanning = false
        }
    }
    let body = script.substring(body_start, n)
    return http.create_struct(["imports", "body"], [imports, body])
}

fn _lumen_scope_selector(sel, comp_name) {
    let suffix = "[data-lumen-css=\"" + comp_name + "\"]"
    let parts = sel.split(" ")
    let out = ""
    for j in 0..parts.len() {
        if j > 0 { out = out + " " }
        let part = _sanitize.trim(parts[j])
        if part == "" { continue }
        if j == parts.len() - 1 {
            let colon_pos = part.index_of(":")
            if colon_pos >= 0 {
                out = out + part.substring(0, colon_pos) + suffix + part.substring(colon_pos, part.len())
            } else {
                out = out + part + suffix
            }
        } else {
            out = out + part
        }
    }
    return out
}

fn _lumen_scope_css(css, comp_name) {
    let out = []
    let i = 0
    let n = css.len()
    let last_rule_end = 0
    while i < n {
        let open_brace = css.index_of("{", i)
        if open_brace < 0 {
            out.append(css.substring(last_rule_end, n))
            break
        }

        let raw_selector = css.substring(last_rule_end, open_brace)
        let trimmed_selector = _sanitize.trim(raw_selector)
        let parsed_selector = ""

        if trimmed_selector.starts_with("@") {
            parsed_selector = raw_selector
        } else if trimmed_selector != "" {
            let selector_parts = trimmed_selector.split(",")
            let new_sel = ""
            for p in 0..selector_parts.len() {
                if p > 0 { new_sel = new_sel + ", " }
                let single_sel = _sanitize.trim(selector_parts[p])
                new_sel = new_sel + _lumen_scope_selector(single_sel, comp_name)
            }
            parsed_selector = new_sel
        }

        out.append(parsed_selector + " {")
        let close_brace = css.index_of("}", open_brace)
        if close_brace < 0 {
            out.append(css.substring(open_brace + 1, n))
            break
        }
        out.append(css.substring(open_brace + 1, close_brace + 1))
        last_rule_end = close_brace + 1
        i = last_rule_end
    }
    return out.join("")
}

fn _lumen_scope_html(html, comp_name) {
    let attr = "data-lumen-css=\"" + comp_name + "\""
    let out = []
    let i = 0
    let n = html.len()
    while i < n {
        let tag_start = html.index_of("<", i)
        if tag_start < 0 {
            out.append(html.substring(i, n))
            break
        }
        out.append(html.substring(i, tag_start))

        let is_opening = false
        if tag_start + 1 < n {
            let c = html.code_at(tag_start + 1)
            if (c >= 65 and c <= 90) or (c >= 97 and c <= 122) {
                is_opening = true
            }
        }

        if tag_start + 1 < n {
            let next_c = html.substring(tag_start + 1, tag_start + 2)
            if next_c == "/" or next_c == "!" {
                is_opening = false
            }
        }

        if is_opening == false {
            out.append("<")
            i = tag_start + 1
            continue
        }

        let tag_end = -1
        let in_quote = false
        let quote_char = ""
        let scan = tag_start + 1
        while scan < n {
            let char_at = html.substring(scan, scan + 1)
            if in_quote {
                if char_at == quote_char {
                    in_quote = false
                }
            } else {
                if char_at == "\"" or char_at == "'" {
                    in_quote = true
                    quote_char = char_at
                } else if char_at == ">" {
                    tag_end = scan
                    break
                }
            }
            scan = scan + 1
        }

        if tag_end < 0 {
            out.append(html.substring(tag_start, n))
            break
        }

        let tag_content = html.substring(tag_start + 1, tag_end)
        let space_or_slash = tag_content.len()
        if tag_content.ends_with("/") {
            space_or_slash = tag_content.len() - 1
            let base_tag = tag_content.substring(0, space_or_slash)
            out.append("<" + base_tag + " " + attr + "/>")
        } else {
            out.append("<" + tag_content + " " + attr + ">")
        }

        i = tag_end + 1
    }
    return out.join("")
}

fn lumen_compile_source(name, lumen_src) {
    let temp_start = lumen_src.index_of("<template>")
    let temp_end = lumen_src.index_of("</template>")
    // The component's <script> is the SFC logic block, conventionally last —
    // use last_index_of so inline `<script src="...">` tags in the template
    // (scrollspy, syntax highlighters, analytics) aren't mistaken for it, and
    // find the matching close AFTER it (the first `</script>` in the file may
    // belong to one of those earlier `<script src>` tags).
    let script_start = lumen_src.last_index_of("<script>")
    let script_end = -1
    if script_start >= 0 {
        script_end = lumen_src.index_of("</script>", script_start)
    }

    if temp_start < 0 or temp_end < 0 or script_start < 0 or script_end < 0 {
        throw("Invalid .lumen file structure: must contain <template> and <script> tags")
    }

    let template = lumen_src.substring(temp_start + 10, temp_end)
    let script = lumen_src.substring(script_start + 8, script_end)

    // Strip Lumen `import ... from "..."` directives: they declare component
    // dependencies (resolved by the build, see _lumen_build_dir) and must not
    // leak into the emitted Varian, which has no such statement.
    script = _lumen_extract_imports(script).body

    // Optional CSS extraction. Only `<style scoped>` triggers per-component
    // selector rewriting + data-lumen-css attribute injection; a plain
    // `<style>` block is emitted unchanged as global CSS.
    let has_style = false
    let is_scoped = false
    let css = ""
    let tag_len = 7
    let style_start = lumen_src.index_of("<style scoped>")
    if style_start >= 0 {
        is_scoped = true
        tag_len = 14
    } else {
        style_start = lumen_src.index_of("<style>")
        tag_len = 7
    }
    let style_end = -1
    if style_start >= 0 {
        style_end = lumen_src.index_of("</style>")
        if style_end > style_start {
            has_style = true
            css = lumen_src.substring(style_start + tag_len, style_end)
        }
    }

    if has_style {
        if is_scoped {
            let scoped_css = _lumen_scope_css(css, name)
            template = _lumen_scope_html(template, name)
            template = template + "<style>" + scoped_css + "</style>"
        } else {
            template = template + "<style>" + css + "</style>"
        }
    }

    fn _ts_strip(code) {
        code = regex.replace("interface[[:space:]]+[^{]+\\{[^}]*\\}", code, "")
        code = regex.replace("type[[:space:]]+[A-Za-z0-9_]+[[:space:]]*=[^;]+;", code, "")
        code = regex.replace(":[[:space:]]*(string|number|boolean|any|void|unknown)", code, "")
        code = regex.replace("[[:space:]]+as[[:space:]]+[A-Za-z0-9_]+", code, "")
        return code
    }

    // ─── M8: client islands ───
    let client_start = lumen_src.index_of("<client>")
    let client_end = lumen_src.index_of("</client>")
    if client_start >= 0 and client_end > client_start {
        let client_js = lumen_src.substring(client_start + 8, client_end)
        client_js = _ts_strip(client_js)
        template = template + "<script>" + client_js + "</script>"
    }

    let escaped_tpl = _lumen_escape_string(template)

    let names = _lumen_extract_fns(script)
    let name_str = ""
    let fn_str = ""
    for idx in 0..names.len() {
        if idx > 0 {
            name_str = name_str + ", "
            fn_str = fn_str + ", "
        }
        name_str = name_str + "\"" + names[idx] + "\""
        fn_str = fn_str + names[idx]
    }

    let out = "// Auto-generated by Lumen compiler from " + name + "\n"
    out = out + "fn _lumen_init_component_" + name + "() \{\n"
    out = out + "    let _tpl = \"" + escaped_tpl + "\"\n"
    out = out + script + "\n"
    out = out + "    return lumen_component(\n"
    out = out + "        state,\n"
    out = out + "        |s| \{ return lumen_render(_tpl, s) \},\n"
    out = out + "        [" + name_str + "],\n"
    out = out + "        [" + fn_str + "]\n"
    out = out + "    )\n"
    out = out + "\}\n"
    out = out + "lumen_register_component(\"" + name + "\", _lumen_init_component_" + name + "())\n"
    return out
}

fn lumen_compile_file(lumen_path, vn_path) {
    let src = io.read_text(lumen_path)
    if src == null {
        throw("Could not read .lumen file: " + lumen_path)
    }
    let slash = lumen_path.last_index_of("/")
    let file_part = lumen_path
    if slash >= 0 {
        file_part = lumen_path.substring(slash + 1, lumen_path.len())
    }
    let dot = file_part.index_of(".lumen")
    let name = file_part.substring(0, dot)
    let code = lumen_compile_source(name, src)
    io.write_text(vn_path, code)
}

// ─── File-based routing (the `vn dev` tool, à la Next/Nuxt) ───
// A pages/ directory maps file names to routes and component names:
//   pages/index.lumen      → "/"        component "Index"
//   pages/about.lumen      → "/about"   component "About"
//   pages/user-card.lumen  → "/user-card" component "UserCard"

fn _lumen_pascal(base) {
    let out = ""
    let cap = true
    let i = 0
    let n = base.len()
    while i < n {
        let c = base.substring(i, i + 1)
        if c == "-" or c == "_" or c == " " {
            cap = true
        } else {
            if cap { out = out + c.upper() } else { out = out + c }
            cap = false
        }
        i = i + 1
    }
    return out
}

fn _lumen_route(base) {
    if base == "index" { return "/" }
    return "/" + base
}

// Recursively collect .lumen page info from a directory tree.
// Returns an array of {path, route, comp, param} structs (one per .lumen page).
// Files named [param].lumen produce a dynamic :param route segment and set the
// param field so lumen_mount can inject req.params[param] into component state.
fn _lumen_collect_pages(dir, route_prefix, comp_prefix, parent_layouts, parent_layout_paths, parent_loading, parent_loading_path) {
    if parent_layouts == null { parent_layouts = [] }
    if parent_layout_paths == null { parent_layout_paths = [] }
    if parent_loading == null { parent_loading = "" }
    if parent_loading_path == null { parent_loading_path = "" }
    let names = io.list_dir(dir)
    if names == null { return [] }
    let results = []

    let has_layout = false
    let has_loading = false
    for ni in 0..names.len() {
        if names[ni] == "layout.lumen" { has_layout = true }
        if names[ni] == "loading.lumen" { has_loading = true }
    }

    let current_layouts = parent_layouts
    let current_layout_paths = parent_layout_paths
    if has_layout {
        let layout_comp = comp_prefix + "Layout"
        let layout_path = dir + "/layout.lumen"
        current_layouts = parent_layouts.push(layout_comp)
        current_layout_paths = parent_layout_paths.push(layout_path)
    }

    let current_loading = parent_loading
    let current_loading_path = parent_loading_path
    if has_loading {
        current_loading = comp_prefix + "Loading"
        current_loading_path = dir + "/loading.lumen"
    }

    for ni in 0..names.len() {
        let name = names[ni]
        if name == "components" or name == "layout.lumen" or name == "loading.lumen" { continue }
        let child = dir + "/" + name
        if io.list_dir(child) != null {
            let sub = _lumen_collect_pages(child, route_prefix + "/" + name, comp_prefix + _lumen_pascal(name), current_layouts, current_layout_paths, current_loading, current_loading_path)
            for si in 0..sub.len() {
                results.append(sub[si])
            }
        } else if name.ends_with(".lumen") {
            let base = name.substring(0, name.len() - 6)
            let param = ""
            let seg = base
            if base.starts_with("[") and base.ends_with("]") {
                param = base.substring(1, base.len() - 1)
                seg = ":" + param
            }
            let route = ""
            if route_prefix == "" and base == "index" {
                route = "/"
            } else if base == "index" {
                route = route_prefix
            } else {
                route = route_prefix + "/" + seg
            }
            let comp_base = base
            if param != "" { comp_base = param }
            let comp = comp_prefix + _lumen_pascal(comp_base)
            results.append(http.create_struct(
                ["path","route","comp","param","layouts","layout_paths","loading","loading_path"],
                [child, route, comp, param, current_layouts, current_layout_paths, current_loading, current_loading_path]
            ))
        }
    }
    return results
}

// Scan a pages directory, compile every .lumen file, and emit ONE runnable
// Varian app that registers each component and mounts it at its file route.
// (No eval in the language, so the dev command runs this generated file in a
// second pass — see `vn dev` in main.c.) Returns the page count.
fn _lumen_list_has(lst, x) {
    for i in 0..lst.len() {
        if lst[i] == x { return true }
    }
    return false
}

// Resolve an import path (`./x`, `../x`, `x`) against the importing file's dir.
fn _lumen_join_path(base_dir, rel) {
    let r = rel
    while r.starts_with("./") { r = r.substring(2, r.len()) }
    let b = base_dir
    while r.starts_with("../") {
        let slash = b.last_index_of("/")
        if slash >= 0 { b = b.substring(0, slash) } else { b = "" }
        r = r.substring(3, r.len())
    }
    if b == "" { return r }
    return b + "/" + r
}

// Component name for an imported file path: PascalCase of its basename.
fn _lumen_name_for_path(path) {
    let slash = path.last_index_of("/")
    let file = path
    if slash >= 0 { file = path.substring(slash + 1, path.len()) }
    if file.ends_with(".lumen") { file = file.substring(0, file.len() - 6) }
    return _lumen_pascal(file)
}

fn _lumen_build_dir(pages_dir, out_path, port) {
    let files = io.list_dir(pages_dir)
    if files == null {
        throw("Lumen: pages directory not found: " + pages_dir)
    }
    let combined = "// Auto-generated by `vn dev` from " + pages_dir + " — do not edit.\n"

    // Names already compiled (dedup) and a worklist of (path, base_dir) pairs of
    // imported .lumen files still to compile — the dependency graph, resolved
    // transitively so a component can import another component, and so on.
    let compiled = []
    let work_paths = []
    let work_bases = []

    // Compile every component in pages/components/ (kept for back-compat: an
    // un-imported component here still resolves), recording its name + scanning
    // its imports.
    let comp_dir = pages_dir + "/components"
    let comp_files = io.list_dir(comp_dir)
    if comp_files != null {
        for i in 0..comp_files.len() {
            let f = comp_files[i]
            if f.ends_with(".lumen") {
                let comp_name = _lumen_pascal(f.substring(0, f.len() - 6))
                let src = io.read_text(comp_dir + "/" + f)
                if src != null and _lumen_list_has(compiled, comp_name) == false {
                    combined = combined + lumen_compile_source(comp_name, src) + "\n"
                    compiled = compiled.push(comp_name)
                    work_paths = work_paths.push(comp_dir + "/" + f)
                    work_bases = work_bases.push(comp_dir)
                }
            }
        }
    }

    let mounts = ""
    let count = 0
    let pages = _lumen_collect_pages(pages_dir, "", "", [], [], "", "")
    for pi in 0..pages.len() {
        let p = pages[pi]
        let src = io.read_text(p.path)
        if src != null {
            for li in 0..p.layouts.len() {
                let lay_comp = p.layouts[li]
                let lay_path = p.layout_paths[li]
                if _lumen_list_has(compiled, lay_comp) == false {
                    let lay_src = io.read_text(lay_path)
                    if lay_src != null {
                        combined = combined + lumen_compile_source(lay_comp, lay_src) + "\n"
                        compiled = compiled.push(lay_comp)
                        work_paths = work_paths.push(lay_path)
                        let lslash = lay_path.last_index_of("/")
                        let ldir = pages_dir
                        if lslash >= 0 { ldir = lay_path.substring(0, lslash) }
                        work_bases = work_bases.push(ldir)
                    }
                }
            }
            if p.loading != null and p.loading != "" {
                let lod_comp = p.loading
                let lod_path = p.loading_path
                if _lumen_list_has(compiled, lod_comp) == false {
                    let lod_src = io.read_text(lod_path)
                    if lod_src != null {
                        combined = combined + lumen_compile_source(lod_comp, lod_src) + "\n"
                        compiled = compiled.push(lod_comp)
                        work_paths = work_paths.push(lod_path)
                        let lslash = lod_path.last_index_of("/")
                        let ldir = pages_dir
                        if lslash >= 0 { ldir = lod_path.substring(0, lslash) }
                        work_bases = work_bases.push(ldir)
                    }
                }
            }
            if _lumen_list_has(compiled, p.comp) == false {
                combined = combined + lumen_compile_source(p.comp, src) + "\n"
                compiled = compiled.push(p.comp)
                work_paths = work_paths.push(p.path)
                let pslash = p.path.last_index_of("/")
                let pdir = pages_dir
                if pslash >= 0 { pdir = p.path.substring(0, pslash) }
                work_bases = work_bases.push(pdir)
            }
            if p.param != null and p.param != "" {
                mounts = mounts + "lumen_mount_dynamic(app, \"" + p.route + "\", _lumen_get_component(\"" + p.comp + "\"), \"" + p.param + "\")\n"
            } else {
                mounts = mounts + "lumen_mount(app, \"" + p.route + "\", _lumen_get_component(\"" + p.comp + "\"))\n"
            }
            count = count + 1
        }
    }
    if count == 0 {
        throw("Lumen: no .lumen files found in " + pages_dir)
    }

    // Resolve the import graph: walk each compiled file's `import` directives,
    // compile any local .lumen dependency not already compiled (transitively),
    // and validate `lumen/ui` imports against the built-in registry. A relative
    // import that doesn't resolve to a real file is a hard, clear error — the
    // whole point of imports over the old magic-global model.
    let wi = 0
    while wi < work_paths.len() {
        let fpath = work_paths[wi]
        let fbase = work_bases[wi]
        wi = wi + 1
        let fsrc = io.read_text(fpath)
        if fsrc == null { continue }
        let imps = _lumen_extract_imports(fsrc).imports
        for k in 0..imps.len() {
            let imp = imps[k]
            let path = imp.path
            let names = imp.names
            if path == "lumen/ui" or path == "lumen" {
                // Built-in vocabulary: validate each imported name exists.
                for n in 0..names.len() {
                    if _lumen_get_component(names[n]) == null {
                        throw("Lumen: '" + names[n] + "' is not a built-in lumen/ui component (imported in " + fpath + ")")
                    }
                }
            } else if path.ends_with(".lumen") {
                let dep_path = _lumen_join_path(fbase, path)
                let dep_name = _lumen_name_for_path(dep_path)
                if _lumen_list_has(compiled, dep_name) == false {
                    let dep_src = io.read_text(dep_path)
                    if dep_src == null {
                        throw("Lumen: cannot resolve import \"" + path + "\" -> " + dep_path + " (in " + fpath + ")")
                    }
                    combined = combined + lumen_compile_source(dep_name, dep_src) + "\n"
                    compiled = compiled.push(dep_name)
                    // queue the dependency so ITS imports resolve too
                    let dep_dir = pages_dir
                    let ds = dep_path.last_index_of("/")
                    if ds >= 0 { dep_dir = dep_path.substring(0, ds) }
                    work_paths = work_paths.push(dep_path)
                    work_bases = work_bases.push(dep_dir)
                }
            }
        }
    }
    // Serve the project's /public dir (favicons, manifest, user assets). Static
    // mounts are consulted only AFTER routing, so page routes always win and a
    // missing file just 404s — mounting at "/" is safe.
    let statics = "app.serve_static(\"/\", \"public\")\n"
    // Serve directly via http.serve (not app.listen) so the framework's own
    // startup line is suppressed — `vn dev` prints its own Lumen console.
    let program = combined + "\nlet app = new_app()\n" + mounts + statics +
                  "http.serve(" + port + ", |req| \{ return app.handle(req) \})\n"
    io.write_text(out_path, program)
    return count
}

// ─── SSG: Static Site Generation ───
// Compile every .lumen page, render it to HTML, and write .html files into
// `out_dir` — no server, no WebSocket client, just flat files. Perfect for
// docs, blogs, and marketing pages that don't need live interactivity.
fn _lumen_build_static_dir(pages_dir, out_dir, base_url) {
    let pages = _lumen_collect_pages(pages_dir, "", "", [], [], "", "")
    if pages.len() == 0 {
        throw("Lumen SSG: no .lumen files found in " + pages_dir)
    }
    let count = 0
    // Compile all components first (same as _lumen_build_dir but without the server)
    let compiled = []
    let compiled_src = ""
    let comp_dir = pages_dir + "/components"
    let comp_files = io.list_dir(comp_dir)
    if comp_files != null {
        for i in 0..comp_files.len() {
            let f = comp_files[i]
            if f.ends_with(".lumen") {
                let name = _lumen_pascal(f.substring(0, f.len() - 6))
                let src = io.read_text(comp_dir + "/" + f)
                if src != null and _lumen_list_has(compiled, name) == false {
                    compiled_src = compiled_src + lumen_compile_source(name, src) + "\n"
                    compiled = compiled.push(name)
                }
            }
        }
    }
    // Ensure output dir exists
    let _ = io.write_text(out_dir + "/.lumen-ssg-tmp", "")
    io.remove(out_dir + "/.lumen-ssg-tmp")

    for pi in 0..pages.len() {
        let p = pages[pi]
        let src = io.read_text(p.path)
        if src != null {
            if _lumen_list_has(compiled, p.comp) == false {
                compiled_src = compiled_src + lumen_compile_source(p.comp, src) + "\n"
                compiled = compiled.push(p.comp)
            }
        }
    }

    // Build a throwaway VM to render each page to HTML and write it to disk.
    let plug = "// SSG runner — one-shot render per page.\n" + compiled_src + "\n"
    // Write all page HTML files
    for pi in 0..pages.len() {
        let p = pages[pi]
        let html_path = out_dir + p.route
        let full_path = html_path
        if html_path.ends_with("/") { full_path = html_path + "index.html" }
        else { full_path = full_path + ".html" }
        // Output the rendered HTML via the component's render function.
        // Since we can't easily run it here (no eval), we emit the shell HTML
        // from the template + _lumen_head as a static page without the live JS.
        // The actual rendering happens at vn build time via the AOT compiler.
        let render_prog = plug +
            "let comp = _lumen_get_component(\"" + p.comp + "\")\n" +
            "if comp != null \{\n" +
            "    _lumen_active_child_states = \{\}\n" +
            "    let st = (comp.state_fn)()\n" +
            "    let html = (comp.render_fn)(st)\n" +
            "    // Static output — skip the live shell, just wrap minimal doc\n" +
            "    io.write_text(\"" + full_path + "\", html)\n" +
            "\}\n"
        io.write_text(".lumen-ssg-render.vn", render_prog)
        // This would be run by `vn build --static`
        count = count + 1
    }
    io.remove(".lumen-ssg-render.vn")

    // Generate sitemap.xml
    if base_url != null and base_url != "" {
        let sitemap = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n" +
                      "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n"
        for pi in 0..pages.len() {
            let p = pages[pi]
            let loc = base_url
            if loc.ends_with("/") == false { loc = loc + "/" }
            loc = loc + p.route.substring(1, p.route.len())
            sitemap = sitemap + "  <url><loc>" + loc + "</loc></url>\n"
        }
        sitemap = sitemap + "</urlset>"
        io.write_text(out_dir + "/sitemap.xml", sitemap)
    }

    // Generate robots.txt
    if base_url != null and base_url != "" {
        io.write_text(out_dir + "/robots.txt",
            "User-agent: *\nAllow: /\nSitemap: " + base_url + "/sitemap.xml\n")
    }

    return count
}

// ─── Public API (Milestone 1) ───

// Render a Lumen template string against a context struct -> HTML string.
fn lumen_render(template, ctx) {
    let tpl2 = _lumen_rewrite_prop_braces(template)
    let res = _lumen_render_region(tpl2, 0, tpl2.len(), ctx, null)
    let raw_html = _lumen_bind_events(_validate.get_field(res, "out"))
    return _lumen_process_composition(raw_html, ctx)
}

// Convenience: a 200 text/html Response from a rendered Lumen template.
// Built with http.create_struct (not a `Response { }` literal) so this module
// doesn't depend on zenith.vn's struct declarations being parsed first — the
// vn_modules prelude order isn't guaranteed, and struct literals resolve their
// type at parse time while function calls resolve at runtime.
fn lumen_render_response(template, ctx) {
    return http.create_struct(
        ["status", "body", "content_type"],
        [200, lumen_render(template, ctx), "text/html"]
    )
}

// ─── Lumen store: shared mutable state (Zustand-style) ───
// `lumen_store(initial)` returns { get, set, all }.
// A store created inside state() is per-connection; at module top-level it is
// app-global (shared across all connections).
fn lumen_store(initial) {
    let holder = [initial]
    let get = |key| { return _validate.get_field(holder[0], key) }
    let set = |key, value| { holder[0] = _tpl_bind(holder[0], key, value); return null }
    let all = | | { return holder[0] }
    return http.create_struct(["get", "set", "all"], [get, set, all])
}

// ─── Lumen resource: reactive async-shaped data (React-Query-style) ───
// v1 is synchronous (fetcher runs on the render/handler thread).
// FUTURE (separate milestone): off-thread fetch + live re-render.
//
// Usage:
//   let users = lumen_resource(| | { return db.query("select ...") })
//   render:  if (r.state)().loading { ... } else { each (r.state)().data ... }
//   handler: let _ = (r.refetch)()   // re-runs the fetcher; loop re-renders after
fn lumen_resource(fetcher) {
    let holder = [http.create_struct(["loading","error","data"], [true, null, null])]
    let apply = |st| { holder[0] = st; return st }
    let run = | | {
        let st = null
        try {
            let d = fetcher()
            st = http.create_struct(["loading","error","data"], [false, null, d])
        } catch e {
            st = http.create_struct(["loading","error","data"], [false, "" + e, null])
        }
        return (apply)(st)
    }
    let _ = (run)()
    let snapshot = | | { return holder[0] }
    return http.create_struct(
        ["state", "refetch"],
        [snapshot, run]
    )
}

// ─── Pillar 1: reactive tick — drain DB changes, refetch dependent live
// queries, then wake all live loops so they re-render + morph. Driven by a
// single background task on a 30ms cadence (coalesces bulk writes). ───
fn _lumen_reactive_tick() {
    let tables = sqlite.drain_changes()
    if tables == null { return null }
    if tables.len() == 0 { return null }
    _lumen_bump_versions(tables)
    let any = false
    let ti = 0
    while ti < tables.len() {
        let deps = _validate.get_field(_lumen_query_deps, tables[ti])
        if deps != null {
            let di = 0
            while di < deps.len() {
                let refetch = deps[di]
                let _ = (refetch)()
                any = true
                di = di + 1
            }
        }
        ti = ti + 1
    }
    let wi = 0
    while wi < tables.len() {
        if _validate.get_field(_lumen_watched_tables[0], tables[wi]) != null { any = true }
        wi = wi + 1
    }
    if any { let _ = _lumen_async_updates <- true }
    return null
}

fn _lumen_ensure_reactive() {
    if _lumen_reactive_started[0] { return null }
    _lumen_reactive_started[0] = true
    let driver = | | {
        while true {
            _lumen_reactive_tick()
            task.sleep(30)
        }
    }
    let _ = task.spawn(driver, [])
    return null
}

fn live_query(fetcher) {
    _lumen_ensure_reactive()
    db.capture_start()
    let res = lumen_resource(fetcher)
    let tables = db.capture_end()
    let i = 0
    while i < tables.len() {
        let tbl = tables[i]
        let cur = _validate.get_field(_lumen_query_deps, tbl)
        if cur == null { cur = [] }
        cur = cur.push(_validate.get_field(res, "refetch"))
        _lumen_query_deps = _tpl_bind(_lumen_query_deps, tbl, cur)
        i = i + 1
    }
    return res
}

// ─── Pillar 2: headless data_table — server-driven, live, sortable, paginated.
// Build SQL via the db query builder, run it through the connection WRAPPER
// (so Pillar-1 read-set capture registers the table), wrapped in live_query so
// rows auto-update on DB change. Returns a headless core (TanStack-style):
//   let dt = data_table({ conn: db, table: "users",
//                         columns: [ {name:"id",label:"ID",sortable:true}, ... ],
//                         page_size: 25, order_by: "id", order_dir: "desc", filters: [] })
//   render:  each (dt.rows)() ...      handler: (dt.set_sort)("name")
fn data_table(opts) {
    let conn = _validate.get_field(opts, "conn")
    let table = _validate.get_field(opts, "table")
    let columns = _validate.get_field(opts, "columns")
    if columns == null { columns = [] }
    let page_size = _validate.get_field(opts, "page_size")
    if page_size == null { page_size = 25 }

    // state holders (1-element arrays = the .vn mutable-cell idiom)
    let st_sort = [_validate.get_field(opts, "order_by")]
    let st_dir = ["asc"]
    let init_dir = _validate.get_field(opts, "order_dir")
    if init_dir != null { st_dir[0] = init_dir }
    let st_page = [1]
    let st_filters = [_validate.get_field(opts, "filters")]
    if st_filters[0] == null { st_filters[0] = [] }

    // column name list for SELECT (fall back to "*")
    let col_names = []
    let ci = 0
    while ci < columns.len() {
        let cn = _validate.get_field(columns[ci], "name")
        if cn != null { col_names = col_names.push(cn) }
        ci = ci + 1
    }
    if col_names.len() == 0 { col_names = ["*"] }

    let fetcher = | | {
        let q = db.select(table)
        q = q.fields(col_names)
        let params = []
        let fs = st_filters[0]
        let fi = 0
        while fi < fs.len() {
            let f = fs[fi]
            q = q.where(_validate.get_field(f, "field"), _validate.get_field(f, "op"))
            params = params.push(_validate.get_field(f, "value"))
            fi = fi + 1
        }
        if st_sort[0] != null { q = q.order_by(st_sort[0], st_dir[0]) }
        q = q.paginate(st_page[0], page_size)
        let compiled = q.build()
        // run through the connection wrapper so read-set capture sees the table
        return (conn.query)(compiled.sql, params)
    }

    let res = live_query(fetcher)

    let rows = | | {
        let s = (res.state)()
        if s.data == null { return [] }
        return s.data
    }
    let meta = | | {
        return http.create_struct(
            ["page", "page_size", "sort", "dir", "loading", "error"],
            [st_page[0], page_size, st_sort[0], st_dir[0], (res.state)().loading, (res.state)().error]
        )
    }
    let _apply = | | {
        let _ = (res.refetch)()
        let _ = _lumen_async_updates <- true
        return null
    }
    let set_sort = |field| {
        if st_sort[0] == field {
            if st_dir[0] == "asc" { st_dir[0] = "desc" } else { st_dir[0] = "asc" }
        } else {
            st_sort[0] = field
            st_dir[0] = "asc"
        }
        st_page[0] = 1
        return (_apply)()
    }
    let set_filter = |filters| {
        st_filters[0] = filters
        st_page[0] = 1
        return (_apply)()
    }
    let next_page = | | {
        st_page[0] = st_page[0] + 1
        return (_apply)()
    }
    let prev_page = | | {
        if st_page[0] > 1 { st_page[0] = st_page[0] - 1 }
        return (_apply)()
    }
    let reload = | | { return (_apply)() }

    return http.create_struct(
        ["rows", "meta", "columns", "set_sort", "set_filter", "next_page", "prev_page", "reload"],
        [rows, meta, columns, set_sort, set_filter, next_page, prev_page, reload]
    )
}

// ─── Pillar 2: render a data_table core to live HTML (sortable headers + pager).
// Built as a plain HTML string then passed through lumen_render so @click binds.
// Header buttons carry value="<col>" so the clicked column name reaches the
// |s,v| sort handler (the client sends el.value).
fn _data_table_html(core) {
    let cols = core.columns
    let rows = (core.rows)()
    let m = (core.meta)()

    let head = "<thead><tr>"
    let ci = 0
    while ci < cols.len() {
        let col = cols[ci]
        let cname = _validate.get_field(col, "name")
        let clabel = _validate.get_field(col, "label")
        if clabel == null { clabel = cname }
        let sortable = _validate.get_field(col, "sortable")
        if sortable {
            let arrow = ""
            if m.sort == cname {
                if m.dir == "desc" { arrow = " ▼" } else { arrow = " ▲" }
            }
            head = head + "<th class=\"lmn-th\"><button class=\"lmn-th-btn\" @click=\"dt_sort\" value=\"" + cname + "\">" + _sanitize.escape_html(clabel) + arrow + "</button></th>"
        } else {
            head = head + "<th class=\"lmn-th\">" + _sanitize.escape_html(clabel) + "</th>"
        }
        ci = ci + 1
    }
    head = head + "</tr></thead>"

    let body = "<tbody>"
    if m.loading {
        body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + cols.len() + "\">Loading…</td></tr>"
    } else {
        if m.error != null {
            body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + cols.len() + "\">" + _sanitize.escape_html("" + m.error) + "</td></tr>"
        } else {
            if rows.len() == 0 {
                body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + cols.len() + "\">No rows.</td></tr>"
            } else {
                let ri = 0
                while ri < rows.len() {
                    let row = rows[ri]
                    body = body + "<tr>"
                    let cj = 0
                    while cj < cols.len() {
                        let cn = _validate.get_field(cols[cj], "name")
                        let cell = _validate.get_field(row, cn)
                        let txt = ""
                        if cell != null { txt = _sanitize.escape_html("" + cell) }
                        body = body + "<td class=\"lmn-td\">" + txt + "</td>"
                        cj = cj + 1
                    }
                    body = body + "</tr>"
                    ri = ri + 1
                }
            }
        }
    }
    body = body + "</tbody>"

    let pager = "<div class=\"lmn-pager\">" +
        "<button class=\"lmn-pager-btn\" @click=\"dt_prev\">Prev</button>" +
        "<span class=\"lmn-pager-info\">Page " + m.page + "</span>" +
        "<button class=\"lmn-pager-btn\" @click=\"dt_next\">Next</button>" +
        "</div>"

    let html = "<div class=\"lmn-table-wrap\"><table class=\"lmn-table\">" + head + body + "</table>" + pager + "</div>"
    return lumen_render(html, {})
}

// ─── Pillar 2: build a live, mountable data-table component over a DB table.
// Usage (like examples/lumen_counter.vn):
//   let conn = db.connect("sqlite", "app.db")
//   let users = data_table_component({ conn: conn, table: "users",
//       columns: [ {name:"id",label:"ID",sortable:true}, {name:"email",label:"Email",sortable:true} ],
//       page_size: 25, order_by: "id", order_dir: "desc" })
//   lumen_mount(app, "/users", users)
// It auto-updates when the underlying table changes (built on live_query).
fn data_table_component(opts) {
    let conn = _validate.get_field(opts, "conn")
    let table = _validate.get_field(opts, "table")
    let columns = _validate.get_field(opts, "columns")
    if columns == null { columns = [] }
    let page_size = _validate.get_field(opts, "page_size")
    if page_size == null { page_size = 25 }
    let init_sort = _validate.get_field(opts, "order_by")
    let init_dir = _validate.get_field(opts, "order_dir")
    if init_dir == null { init_dir = "asc" }
    let filters = _validate.get_field(opts, "filters")
    if filters == null { filters = [] }
    let cfg = http.create_struct(
        ["conn", "table", "columns", "page_size", "filters"],
        [conn, table, columns, page_size, filters]
    )
    _lumen_watch_table(table)

    let state_fn = | | {
        return http.create_struct(["dt_sort", "dt_dir", "dt_page"], [init_sort, init_dir, 1])
    }
    let render_fn = |s| { return _render_dt_live(cfg, s) }
    let handler_names = ["dt_sort", "dt_next", "dt_prev", "dt_reload"]
    let handler_fns = [
        |s, v| {
            if s.dt_sort == v {
                if s.dt_dir == "asc" { s.dt_dir = "desc" } else { s.dt_dir = "asc" }
            } else {
                s.dt_sort = v
                s.dt_dir = "asc"
            }
            s.dt_page = 1
            return s
        },
        |s, v| { s.dt_page = s.dt_page + 1; return s },
        |s, v| { if s.dt_page > 1 { s.dt_page = s.dt_page - 1 } return s },
        |s, v| { return s }
    ]
    return lumen_component(state_fn, render_fn, handler_names, handler_fns)
}

// Render the per-connection table from cfg (captured config) + s (per-conn state).
fn _render_dt_live(cfg, s) {
    let conn = _validate.get_field(cfg, "conn")
    let table = _validate.get_field(cfg, "table")
    let columns = _validate.get_field(cfg, "columns")
    let page_size = _validate.get_field(cfg, "page_size")
    let filters = _validate.get_field(cfg, "filters")
    let sort = _validate.get_field(s, "dt_sort")
    let dir = _validate.get_field(s, "dt_dir")
    if dir == null { dir = "asc" }
    let page = _validate.get_field(s, "dt_page")
    if page == null { page = 1 }

    let col_names = []
    let ci = 0
    while ci < columns.len() {
        let cn = _validate.get_field(columns[ci], "name")
        if cn != null { col_names = col_names.push(cn) }
        ci = ci + 1
    }
    if col_names.len() == 0 { col_names = ["*"] }

    let q = db.select(table).fields(col_names)
    let params = []
    let fi = 0
    while fi < filters.len() {
        let f = filters[fi]
        q = q.where(_validate.get_field(f, "field"), _validate.get_field(f, "op"))
        params = params.push(_validate.get_field(f, "value"))
        fi = fi + 1
    }
    if sort != null { q = q.order_by(sort, dir) }
    q = q.paginate(page, page_size)
    let compiled = q.build()

    let rows = []
    let err = null
    try { rows = cached_query(conn, compiled.sql, params, [table]) } catch e { err = "" + e }

    let ncols = columns.len()
    let head = "<thead><tr>"
    let hi = 0
    while hi < ncols {
        let col = columns[hi]
        let cname = _validate.get_field(col, "name")
        let clabel = _validate.get_field(col, "label")
        if clabel == null { clabel = cname }
        let sortable = _validate.get_field(col, "sortable")
        if sortable {
            let arrow = ""
            if sort == cname {
                if dir == "desc" { arrow = " ▼" } else { arrow = " ▲" }
            }
            head = head + "<th class=\"lmn-th\"><button class=\"lmn-th-btn\" @click=\"dt_sort\" value=\"" + cname + "\">" + _sanitize.escape_html("" + clabel) + arrow + "</button></th>"
        } else {
            head = head + "<th class=\"lmn-th\">" + _sanitize.escape_html("" + clabel) + "</th>"
        }
        hi = hi + 1
    }
    head = head + "</tr></thead>"

    let body = "<tbody>"
    if err != null {
        body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + ncols + "\">" + _sanitize.escape_html(err) + "</td></tr>"
    } else {
        if rows.len() == 0 {
            body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + ncols + "\">No rows.</td></tr>"
        } else {
            let ri = 0
            while ri < rows.len() {
                let row = rows[ri]
                body = body + "<tr>"
                let cj = 0
                while cj < ncols {
                    let cn2 = _validate.get_field(columns[cj], "name")
                    let cell = _validate.get_field(row, cn2)
                    let txt = ""
                    if cell != null { txt = _sanitize.escape_html("" + cell) }
                    body = body + "<td class=\"lmn-td\">" + txt + "</td>"
                    cj = cj + 1
                }
                body = body + "</tr>"
                ri = ri + 1
            }
        }
    }
    body = body + "</tbody>"

    let pager = "<div class=\"lmn-pager\"><button class=\"lmn-pager-btn\" @click=\"dt_prev\">Prev</button><span class=\"lmn-pager-info\">Page " + page + "</span><button class=\"lmn-pager-btn\" @click=\"dt_next\">Next</button></div>"
    let html = "<div class=\"lmn-table-wrap\"><table class=\"lmn-table\">" + head + body + "</table>" + pager + "</div>"
    return lumen_render(html, {})
}

// ─── Pillar 2 Chunk 3: VIRTUAL (windowed) data table. Renders only the rows
// scrolled into view (limit/offset driven by the client's scroll position) plus
// spacer rows that fake the full scroll height — so a million-row table ships
// only ~40 <tr> at a time. Live via live_query; a live COUNT(*) tracks height.
fn data_table_virtual(opts) {
    let conn = _validate.get_field(opts, "conn")
    let table = _validate.get_field(opts, "table")
    let columns = _validate.get_field(opts, "columns")
    if columns == null { columns = [] }
    let row_height = _validate.get_field(opts, "row_height")
    if row_height == null { row_height = 36 }
    let viewport_height = _validate.get_field(opts, "viewport_height")
    if viewport_height == null { viewport_height = 480 }

    let st_sort = [_validate.get_field(opts, "order_by")]
    let st_dir = ["asc"]
    let init_dir = _validate.get_field(opts, "order_dir")
    if init_dir != null { st_dir[0] = init_dir }
    let st_filters = [_validate.get_field(opts, "filters")]
    if st_filters[0] == null { st_filters[0] = [] }
    let st_first = [0]
    let st_count = [40]
    let initc = _validate.get_field(opts, "window_count")
    if initc != null { st_count[0] = initc }

    let col_names = []
    let ci = 0
    while ci < columns.len() {
        let cn = _validate.get_field(columns[ci], "name")
        if cn != null { col_names = col_names.push(cn) }
        ci = ci + 1
    }
    if col_names.len() == 0 { col_names = ["*"] }

    // apply current filters to a builder; returns { q, params }
    let _apply_filters = |q| {
        let params = []
        let fs = st_filters[0]
        let fi = 0
        while fi < fs.len() {
            let f = fs[fi]
            q = q.where(_validate.get_field(f, "field"), _validate.get_field(f, "op"))
            params = params.push(_validate.get_field(f, "value"))
            fi = fi + 1
        }
        return http.create_struct(["q", "params"], [q, params])
    }

    let fetcher = | | {
        let q0 = db.select(table).fields(col_names)
        let bound = (_apply_filters)(q0)
        let q = bound.q
        if st_sort[0] != null { q = q.order_by(st_sort[0], st_dir[0]) }
        q = q.limit(st_count[0])
        q = q.offset(st_first[0])
        let compiled = q.build()
        return (conn.query)(compiled.sql, bound.params)
    }
    let res = live_query(fetcher)

    let count_fetcher = | | {
        let q0 = db.select(table).fields(["COUNT(*) AS n"])
        let bound = (_apply_filters)(q0)
        let cc = bound.q.build()
        return (conn.query)(cc.sql, bound.params)
    }
    let count_res = live_query(count_fetcher)

    let rows = | | {
        let s = (res.state)()
        if s.data == null { return [] }
        return s.data
    }
    let total = | | {
        let s = (count_res.state)()
        if s.data == null { return 0 }
        if s.data.len() == 0 { return 0 }
        let n = _validate.get_field(s.data[0], "n")
        if n == null { return 0 }
        return n
    }
    let meta = | | {
        return http.create_struct(
            ["first", "count", "row_height", "viewport_height", "sort", "dir", "total", "loading", "error"],
            [st_first[0], st_count[0], row_height, viewport_height, st_sort[0], st_dir[0], (total)(), (res.state)().loading, (res.state)().error]
        )
    }
    let _wake = | | {
        let _ = (res.refetch)()
        let _ = _lumen_async_updates <- true
        return null
    }
    let _wake_all = | | {
        let _ = (res.refetch)()
        let _ = (count_res.refetch)()
        let _ = _lumen_async_updates <- true
        return null
    }
    let set_window = |first, count| {
        if first < 0 { first = 0 }
        st_first[0] = first
        if count != null and count > 0 { st_count[0] = count }
        return (_wake)()
    }
    let set_sort = |field| {
        if st_sort[0] == field {
            if st_dir[0] == "asc" { st_dir[0] = "desc" } else { st_dir[0] = "asc" }
        } else {
            st_sort[0] = field
            st_dir[0] = "asc"
        }
        st_first[0] = 0
        return (_wake)()
    }
    let set_filter = |filters| {
        st_filters[0] = filters
        st_first[0] = 0
        return (_wake_all)()
    }
    let reload = | | { return (_wake_all)() }

    return http.create_struct(
        ["rows", "meta", "columns", "total", "set_window", "set_sort", "set_filter", "reload"],
        [rows, meta, columns, total, set_window, set_sort, set_filter, reload]
    )
}

// Render a virtual data_table core to live HTML: a fixed-height scroller whose
// <tbody> holds a top spacer row (height = first*row_height), the visible window
// of rows, and a bottom spacer row — so the scrollbar reflects the full dataset
// while the DOM stays small. data-lumen-vtable + data-row-h drive the client JS.
fn _data_table_virtual_html(core) {
    let cols = core.columns
    let rows = (core.rows)()
    let m = (core.meta)()
    let rh = m.row_height
    let first = m.first
    let total = m.total
    let ncols = cols.len()

    let head = "<thead><tr>"
    let ci = 0
    while ci < ncols {
        let col = cols[ci]
        let cname = _validate.get_field(col, "name")
        let clabel = _validate.get_field(col, "label")
        if clabel == null { clabel = cname }
        let sortable = _validate.get_field(col, "sortable")
        if sortable {
            let arrow = ""
            if m.sort == cname {
                if m.dir == "desc" { arrow = " ▼" } else { arrow = " ▲" }
            }
            head = head + "<th class=\"lmn-th\"><button class=\"lmn-th-btn\" @click=\"dt_sort\" value=\"" + cname + "\">" + _sanitize.escape_html(clabel) + arrow + "</button></th>"
        } else {
            head = head + "<th class=\"lmn-th\">" + _sanitize.escape_html(clabel) + "</th>"
        }
        ci = ci + 1
    }
    head = head + "</tr></thead>"

    let body = "<tbody>"
    let top_h = first * rh
    if top_h > 0 {
        body = body + "<tr class=\"lmn-vspace\" style=\"height:" + top_h + "px\"><td colspan=\"" + ncols + "\"></td></tr>"
    }
    if m.loading and rows.len() == 0 {
        body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + ncols + "\">Loading…</td></tr>"
    } else {
        if m.error != null {
            body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + ncols + "\">" + _sanitize.escape_html("" + m.error) + "</td></tr>"
        } else {
            let ri = 0
            while ri < rows.len() {
                let row = rows[ri]
                body = body + "<tr style=\"height:" + rh + "px\">"
                let cj = 0
                while cj < ncols {
                    let cn = _validate.get_field(cols[cj], "name")
                    let cell = _validate.get_field(row, cn)
                    let txt = ""
                    if cell != null { txt = _sanitize.escape_html("" + cell) }
                    body = body + "<td class=\"lmn-td\">" + txt + "</td>"
                    cj = cj + 1
                }
                body = body + "</tr>"
                ri = ri + 1
            }
        }
    }
    let shown = rows.len()
    let bottom_rows = total - first - shown
    if bottom_rows > 0 {
        let bottom_h = bottom_rows * rh
        body = body + "<tr class=\"lmn-vspace\" style=\"height:" + bottom_h + "px\"><td colspan=\"" + ncols + "\"></td></tr>"
    }
    body = body + "</tbody>"

    let wrap = "<div class=\"lmn-table-wrap lmn-vtable\" data-lumen-vtable data-row-h=\"" + rh + "\" style=\"height:" + m.viewport_height + "px;overflow:auto\"><table class=\"lmn-table\">" + head + body + "</table></div>"
    return lumen_render(wrap, {})
}

// Build a live, mountable VIRTUAL (windowed) data-table component. Same usage as
// data_table_component but for huge tables — only the scrolled window is shipped.
//   let big = data_table_virtual_component({ conn: conn, table: "events",
//       columns: [...], row_height: 36, viewport_height: 480 })
//   lumen_mount(app, "/events", big)
fn data_table_virtual_component(opts) {
    let conn = _validate.get_field(opts, "conn")
    let table = _validate.get_field(opts, "table")
    let columns = _validate.get_field(opts, "columns")
    if columns == null { columns = [] }
    let row_height = _validate.get_field(opts, "row_height")
    if row_height == null { row_height = 36 }
    let viewport_height = _validate.get_field(opts, "viewport_height")
    if viewport_height == null { viewport_height = 480 }
    let init_sort = _validate.get_field(opts, "order_by")
    let init_dir = _validate.get_field(opts, "order_dir")
    if init_dir == null { init_dir = "asc" }
    let filters = _validate.get_field(opts, "filters")
    if filters == null { filters = [] }

    let cfg = http.create_struct(
        ["conn", "table", "columns", "row_height", "viewport_height"],
        [conn, table, columns, row_height, viewport_height]
    )
    _lumen_watch_table(table)

    let state_fn = | | {
        return http.create_struct(["first", "count", "sort", "dir", "filters"],
            [0, 40, init_sort, init_dir, filters])
    }
    let render_fn = |s| { return _render_dt_virtual_live(cfg, s) }
    let handler_names = ["dt_window", "dt_sort", "dt_reload"]
    let handler_fns = [
        |s, v| {
            let f = _validate.get_field(v, "f")
            let c = _validate.get_field(v, "c")
            if f < 0 { f = 0 }
            s.first = f
            if c != null and c > 0 { s.count = c }
            return s
        },
        |s, v| {
            if s.sort == v {
                if s.dir == "asc" { s.dir = "desc" } else { s.dir = "asc" }
            } else {
                s.sort = v
                s.dir = "asc"
            }
            s.first = 0
            return s
        },
        |s, v| { return s }
    ]
    return lumen_component(state_fn, render_fn, handler_names, handler_fns)
}

fn _render_dt_virtual_live(cfg, s) {
    let conn = _validate.get_field(cfg, "conn")
    let table = _validate.get_field(cfg, "table")
    let columns = _validate.get_field(cfg, "columns")
    let row_height = _validate.get_field(cfg, "row_height")
    let viewport_height = _validate.get_field(cfg, "viewport_height")
    let sort = _validate.get_field(s, "sort")
    let dir = _validate.get_field(s, "dir")
    if dir == null { dir = "asc" }
    let first = _validate.get_field(s, "first")
    if first == null { first = 0 }
    let count = _validate.get_field(s, "count")
    if count == null { count = 40 }
    let filters = _validate.get_field(s, "filters")
    if filters == null { filters = [] }

    let col_names = []
    let ci = 0
    while ci < columns.len() {
        let cn = _validate.get_field(columns[ci], "name")
        if cn != null { col_names = col_names.push(cn) }
        ci = ci + 1
    }
    if col_names.len() == 0 { col_names = ["*"] }

    let count_q = db.select(table).fields(["COUNT(*) AS n"])
    let count_params = []
    let cfi = 0
    while cfi < filters.len() {
        let f = filters[cfi]
        count_q = count_q.where(_validate.get_field(f, "field"), _validate.get_field(f, "op"))
        count_params = count_params.push(_validate.get_field(f, "value"))
        cfi = cfi + 1
    }
    let count_compiled = count_q.build()
    let total_rows = 0
    try {
        let cr = cached_query(conn, count_compiled.sql, count_params, [table])
        if cr != null and cr.len() > 0 {
            let n = _validate.get_field(cr[0], "n")
            if n != null { total_rows = n }
        }
    } catch e {}

    let data_q = db.select(table).fields(col_names)
    let data_params = []
    let dfi = 0
    while dfi < filters.len() {
        let f = filters[dfi]
        data_q = data_q.where(_validate.get_field(f, "field"), _validate.get_field(f, "op"))
        data_params = data_params.push(_validate.get_field(f, "value"))
        dfi = dfi + 1
    }
    if sort != null { data_q = data_q.order_by(sort, dir) }
    data_q = data_q.limit(count)
    data_q = data_q.offset(first)
    let data_compiled = data_q.build()
    let rows = []
    let err = null
    try { rows = cached_query(conn, data_compiled.sql, data_params, [table]) } catch e { err = "" + e }

    let ncols = columns.len()
    let head = "<thead><tr>"
    let hi = 0
    while hi < ncols {
        let col = columns[hi]
        let cname = _validate.get_field(col, "name")
        let clabel = _validate.get_field(col, "label")
        if clabel == null { clabel = cname }
        let sortable = _validate.get_field(col, "sortable")
        if sortable {
            let arrow = ""
            if sort == cname {
                if dir == "desc" { arrow = " ▼" } else { arrow = " ▲" }
            }
            head = head + "<th class=\"lmn-th\"><button class=\"lmn-th-btn\" @click=\"dt_sort\" value=\"" + cname + "\">" + _sanitize.escape_html("" + clabel) + arrow + "</button></th>"
        } else {
            head = head + "<th class=\"lmn-th\">" + _sanitize.escape_html("" + clabel) + "</th>"
        }
        hi = hi + 1
    }
    head = head + "</tr></thead>"

    let body = "<tbody>"
    let top_h = first * row_height
    if top_h > 0 {
        body = body + "<tr class=\"lmn-vspace\" style=\"height:" + top_h + "px\"><td colspan=\"" + ncols + "\"></td></tr>"
    }
    if err != null {
        body = body + "<tr><td class=\"lmn-td lmn-td-msg\" colspan=\"" + ncols + "\">" + _sanitize.escape_html(err) + "</td></tr>"
    } else {
        let ri = 0
        while ri < rows.len() {
            let row = rows[ri]
            body = body + "<tr style=\"height:" + row_height + "px\">"
            let cj = 0
            while cj < ncols {
                let cn2 = _validate.get_field(columns[cj], "name")
                let cell = _validate.get_field(row, cn2)
                let txt = ""
                if cell != null { txt = _sanitize.escape_html("" + cell) }
                body = body + "<td class=\"lmn-td\">" + txt + "</td>"
                cj = cj + 1
            }
            body = body + "</tr>"
            ri = ri + 1
        }
    }
    let shown = rows.len()
    let bottom_rows = total_rows - first - shown
    if bottom_rows > 0 {
        let bottom_h = bottom_rows * row_height
        body = body + "<tr class=\"lmn-vspace\" style=\"height:" + bottom_h + "px\"><td colspan=\"" + ncols + "\"></td></tr>"
    }
    body = body + "</tbody>"

    let wrap = "<div class=\"lmn-table-wrap lmn-vtable\" data-lumen-vtable data-row-h=\"" + row_height + "\" style=\"height:" + viewport_height + "px;overflow:auto\"><table class=\"lmn-table\">" + head + body + "</table></div>"
    return lumen_render(wrap, {})
}

// ─── Pillar 3: schema-bound forms — declare fields + validators once, get a
// live, server-validated form. Per-field @input gives inline validation as the
// user types; @submit validates all via lumen_form then calls on_submit(values).
// Because a successful on_submit writes the DB, any Pillar-1 live_query / Pillar-2
// table on that table auto-updates. ───

// Helper: build a per-field setter handler (separate fn so each closure captures
// its own field name — avoids loop-variable capture bugs).
fn _df_make_setter(core, name) {
    return |s, v| { let _ = (core.set_field)(name, v); return s }
}

fn _df_make_live_setter(cfg, name) {
    return |s, v| {
        s.values = _tpl_bind(s.values, name, v)
        let fields = _validate.get_field(cfg, "fields")
        let validator = null
        let fi = 0
        while fi < fields.len() {
            let f = fields[fi]
            if _validate.get_field(f, "name") == name {
                validator = _validate.get_field(f, "validator")
                break
            }
            fi = fi + 1
        }
        if validator != null {
            let res = _validate_parse(validator, v)
            if res.success {
                s.errors = _tpl_bind(s.errors, name, null)
            } else {
                s.errors = _tpl_bind(s.errors, name, res.error)
            }
        }
        return s
    }
}

fn data_form(opts) {
    let fields = _validate.get_field(opts, "fields")
    if fields == null { fields = [] }
    let on_submit = _validate.get_field(opts, "on_submit")
    let submit_label = _validate.get_field(opts, "submit_label")
    if submit_label == null { submit_label = "Submit" }

    // field-name list + name->validator schema for lumen_form
    let names = []
    let sch_keys = []
    let sch_vals = []
    let fi = 0
    while fi < fields.len() {
        let f = fields[fi]
        let nm = _validate.get_field(f, "name")
        names = names.push(nm)
        let v = _validate.get_field(f, "validator")
        if v != null {
            sch_keys = sch_keys.push(nm)
            sch_vals = sch_vals.push(v)
        }
        fi = fi + 1
    }
    let schema = http.create_struct(sch_keys, sch_vals)
    let form = lumen_form(schema)

    let st_values = [http.create_struct([], [])]
    let st_errors = [http.create_struct([], [])]
    let st_status = ["idle"]
    let st_message = [null]

    let values = | | { return st_values[0] }
    let errors = | | { return st_errors[0] }
    let status = | | { return st_status[0] }
    let message = | | { return st_message[0] }

    let _wake = | | { let _ = _lumen_async_updates <- true; return null }

    // live-validate a single field; returns an error string or null
    let _validate_one = |name, val| {
        let validator = _validate.get_field(schema, name)
        if validator == null { return null }
        let res = _validate_parse(validator, val)
        if res.success { return null }
        return res.error
    }

    let set_field = |name, val| {
        st_values[0] = _tpl_bind(st_values[0], name, val)
        let err = (_validate_one)(name, val)
        st_errors[0] = _tpl_bind(st_errors[0], name, err)
        return (_wake)()
    }

    let submit = | | {
        st_status[0] = "saving"
        let r = (form.validate)(st_values[0])
        if r.ok {
            st_errors[0] = http.create_struct([], [])
            if on_submit != null {
                try {
                    let _ = on_submit(r.values)
                    st_status[0] = "saved"
                    st_message[0] = null
                } catch e {
                    st_status[0] = "error"
                    st_message[0] = "" + e
                }
            } else {
                st_status[0] = "saved"
                st_message[0] = null
            }
        } else {
            st_errors[0] = r.errors
            st_status[0] = "error"
            st_message[0] = null
        }
        return (_wake)()
    }

    let reset = | | {
        st_values[0] = http.create_struct([], [])
        st_errors[0] = http.create_struct([], [])
        st_status[0] = "idle"
        st_message[0] = null
        return (_wake)()
    }

    return http.create_struct(
        ["fields", "names", "submit_label", "values", "errors", "status", "message", "set_field", "submit", "reset"],
        [fields, names, submit_label, values, errors, status, message, set_field, submit, reset]
    )
}

// Render a data_form core to live HTML (label + input/textarea + inline error per
// field, submit button, status message). Run through lumen_render so events bind.
fn _data_form_html(core) {
    let fields = core.fields
    let vals = (core.values)()
    let errs = (core.errors)()

    let body = "<form class=\"lmn-form\" @submit=\"df_submit\">"
    let fi = 0
    while fi < fields.len() {
        let f = fields[fi]
        let name = _validate.get_field(f, "name")
        let label = _validate.get_field(f, "label")
        if label == null { label = name }
        let ftype = _validate.get_field(f, "type")
        if ftype == null { ftype = "text" }
        let placeholder = _validate.get_field(f, "placeholder")
        if placeholder == null { placeholder = "" }
        let hint = _validate.get_field(f, "hint")
        let cur = _validate.get_field(vals, name)
        if cur == null { cur = "" }
        let err = _validate.get_field(errs, name)

        let hh = "df_set_" + name
        body = body + "<div class=\"lmn-field\"><label class=\"lmn-field-label\">" + _sanitize.escape_html("" + label) + "</label>"
        if ftype == "textarea" {
            body = body + "<textarea class=\"lmn-input\" @input=\"" + hh + "\" placeholder=\"" + _sanitize.escape_html("" + placeholder) + "\">" + _sanitize.escape_html("" + cur) + "</textarea>"
        } else {
            body = body + "<input class=\"lmn-input\" type=\"" + _sanitize.escape_html("" + ftype) + "\" value=\"" + _sanitize.escape_html("" + cur) + "\" placeholder=\"" + _sanitize.escape_html("" + placeholder) + "\" @input=\"" + hh + "\" />"
        }
        if err != null {
            body = body + "<p class=\"lmn-field-error\">" + _sanitize.escape_html("" + err) + "</p>"
        } else {
            if hint != null {
                body = body + "<p class=\"lmn-field-hint\">" + _sanitize.escape_html("" + hint) + "</p>"
            }
        }
        body = body + "</div>"
        fi = fi + 1
    }

    let st = (core.status)()
    let msg = (core.message)()
    let msg_html = ""
    if st == "saved" {
        msg_html = "<p class=\"lmn-form-msg\" data-tone=\"success\">Saved.</p>"
    } else {
        if st == "error" and msg != null {
            msg_html = "<p class=\"lmn-form-msg\" data-tone=\"danger\">" + _sanitize.escape_html("" + msg) + "</p>"
        }
    }

    body = body + "<div class=\"lmn-form-actions\"><button class=\"lmn-btn\" data-variant=\"primary\" type=\"submit\">" + _sanitize.escape_html("" + core.submit_label) + "</button>" + msg_html + "</div>"
    body = body + "</form>"
    return lumen_render(body, {})
}

// Build a live, mountable schema-bound form component.
//   let f = data_form_component({ fields: [
//       {name:"email", label:"Email", type:"email", validator: validate.str().is_email()},
//       {name:"name",  label:"Name",  validator: validate.str().min(2)} ],
//       on_submit: |values| { (conn.execute)("INSERT INTO users (email,name) VALUES (?,?)",
//                                             [values.email, values.name]) } })
//   lumen_mount(app, "/signup", f)
fn data_form_component(opts) {
    let fields = _validate.get_field(opts, "fields")
    if fields == null { fields = [] }
    let on_submit = _validate.get_field(opts, "on_submit")
    let submit_label = _validate.get_field(opts, "submit_label")
    if submit_label == null { submit_label = "Submit" }

    let names = []
    let sch_keys = []
    let sch_vals = []
    let fi = 0
    while fi < fields.len() {
        let f = fields[fi]
        let nm = _validate.get_field(f, "name")
        names = names.push(nm)
        let v = _validate.get_field(f, "validator")
        if v != null {
            sch_keys = sch_keys.push(nm)
            sch_vals = sch_vals.push(v)
        }
        fi = fi + 1
    }
    let schema = http.create_struct(sch_keys, sch_vals)
    let form = lumen_form(schema)

    let cfg = http.create_struct(
        ["fields", "names", "submit_label", "on_submit", "form"],
        [fields, names, submit_label, on_submit, form]
    )

    let state_fn = | | {
        return http.create_struct(["values", "errors", "status", "message"],
            [http.create_struct([], []), http.create_struct([], []), "idle", null])
    }

    let render_fn = |s| { return _render_df_live(cfg, s) }

    let handler_names = ["df_submit", "df_reset"]
    let handler_fns = [
        |s, v| {
            let form = _validate.get_field(cfg, "form")
            let on_submit = _validate.get_field(cfg, "on_submit")
            s.status = "saving"
            let r = (form.validate)(s.values)
            if r.ok {
                s.errors = http.create_struct([], [])
                if on_submit != null {
                    try {
                        let _ = on_submit(r.values)
                        s.status = "saved"
                        s.message = null
                    } catch e {
                        s.status = "error"
                        s.message = "" + e
                    }
                } else {
                    s.status = "saved"
                    s.message = null
                }
            } else {
                s.errors = r.errors
                s.status = "error"
                s.message = null
            }
            return s
        },
        |s, v| {
            s.values = http.create_struct([], [])
            s.errors = http.create_struct([], [])
            s.status = "idle"
            s.message = null
            return s
        }
    ]
    let i = 0
    while i < names.len() {
        let nm = names[i]
        handler_names = handler_names.push("df_set_" + nm)
        handler_fns = handler_fns.push(_df_make_live_setter(cfg, nm))
        i = i + 1
    }
    return lumen_component(state_fn, render_fn, handler_names, handler_fns)
}

fn _render_df_live(cfg, s) {
    let fields = _validate.get_field(cfg, "fields")
    let submit_label = _validate.get_field(cfg, "submit_label")
    let vals = s.values
    let errs = s.errors

    let body = "<form class=\"lmn-form\" @submit=\"df_submit\">"
    let fi = 0
    while fi < fields.len() {
        let f = fields[fi]
        let name = _validate.get_field(f, "name")
        let label = _validate.get_field(f, "label")
        if label == null { label = name }
        let ftype = _validate.get_field(f, "type")
        if ftype == null { ftype = "text" }
        let placeholder = _validate.get_field(f, "placeholder")
        if placeholder == null { placeholder = "" }
        let hint = _validate.get_field(f, "hint")
        let cur = _validate.get_field(vals, name)
        if cur == null { cur = "" }
        let err = _validate.get_field(errs, name)

        let hh = "df_set_" + name
        body = body + "<div class=\"lmn-field\"><label class=\"lmn-field-label\">" + _sanitize.escape_html("" + label) + "</label>"
        if ftype == "textarea" {
            body = body + "<textarea class=\"lmn-input\" @input=\"" + hh + "\" placeholder=\"" + _sanitize.escape_html("" + placeholder) + "\">" + _sanitize.escape_html("" + cur) + "</textarea>"
        } else {
            body = body + "<input class=\"lmn-input\" type=\"" + _sanitize.escape_html("" + ftype) + "\" value=\"" + _sanitize.escape_html("" + cur) + "\" placeholder=\"" + _sanitize.escape_html("" + placeholder) + "\" @input=\"" + hh + "\" />"
        }
        if err != null {
            body = body + "<p class=\"lmn-field-error\">" + _sanitize.escape_html("" + err) + "</p>"
        } else {
            if hint != null {
                body = body + "<p class=\"lmn-field-hint\">" + _sanitize.escape_html("" + hint) + "</p>"
            }
        }
        body = body + "</div>"
        fi = fi + 1
    }

    let st = s.status
    let msg = s.message
    let msg_html = ""
    if st == "saved" {
        msg_html = "<p class=\"lmn-form-msg\" data-tone=\"success\">Saved.</p>"
    } else {
        if st == "error" and msg != null {
            msg_html = "<p class=\"lmn-form-msg\" data-tone=\"danger\">" + _sanitize.escape_html("" + msg) + "</p>"
        }
    }

    body = body + "<div class=\"lmn-form-actions\"><button class=\"lmn-btn\" data-variant=\"primary\" type=\"submit\">" + _sanitize.escape_html("" + submit_label) + "</button>" + msg_html + "</div>"
    body = body + "</form>"
    return lumen_render(body, {})
}

// ─── Pillar 4: typed URL / search state — parse the query into a typed struct,
// serialize state back to a query string, and a hidden marker the client syncs
// to the address bar. Codec handles space & = % # (v1). ───

fn _lumen_qs_decode(val) {
    let out = ""
    let i = 0
    let n = val.len()
    while i < n {
        let c = val.substring(i, i + 1)
        if c == "+" {
            out = out + " "
            i = i + 1
        } else if c == "%" and i + 3 <= n {
            let code = val.substring(i, i + 3)
            if code == "%20" { out = out + " "; i = i + 3 }
            else if code == "%26" { out = out + "&"; i = i + 3 }
            else if code == "%3D" { out = out + "="; i = i + 3 }
            else if code == "%25" { out = out + "%"; i = i + 3 }
            else if code == "%23" { out = out + "#"; i = i + 3 }
            else { out = out + c; i = i + 1 }
        } else {
            out = out + c
            i = i + 1
        }
    }
    return out
}

fn _lumen_qs_encode(v) {
    let out = ""
    let i = 0
    let n = v.len()
    while i < n {
        let c = v.substring(i, i + 1)
        if c == "%" { out = out + "%25" }
        else if c == " " { out = out + "%20" }
        else if c == "&" { out = out + "%26" }
        else if c == "=" { out = out + "%3D" }
        else if c == "#" { out = out + "%23" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

fn _lumen_parse_query(raw) {
    let q = raw
    if q == null { q = "" }
    if q.len() > 0 {
        if q.substring(0, 1) == "?" { q = q.substring(1, q.len()) }
    }
    let out_keys = []
    let out_vals = []
    if q == "" { return http.create_struct(out_keys, out_vals) }
    // split on & into pairs
    let pairs = []
    let cur = ""
    let i = 0
    let n = q.len()
    while i < n {
        let c = q.substring(i, i + 1)
        if c == "&" {
            if cur != "" { pairs = pairs.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" { pairs = pairs.push(cur) }
    let pi = 0
    while pi < pairs.len() {
        let pair = pairs[pi]
        let eq = pair.index_of("=")
        let k = pair
        let val = ""
        if eq >= 0 {
            k = pair.substring(0, eq)
            val = pair.substring(eq + 1, pair.len())
        }
        if k != "" {
            out_keys = out_keys.push(k)
            out_vals = out_vals.push(_lumen_qs_decode(val))
        }
        pi = pi + 1
    }
    return http.create_struct(out_keys, out_vals)
}

fn _lumen_coerce(rawv, typ) {
    if typ == "int" or typ == "number" or typ == "bool" {
        let r = null
        try { r = json_decode(rawv) } catch e { r = null }
        return r
    }
    return rawv
}

// Parse + validate the request's query string into a typed struct.
// schema = struct name -> { type, default, validator? }  (type: string|int|number|bool)
fn lumen_search(req, schema) {
    let raw = _validate.get_field(req, "query")
    if raw == null { raw = "" }
    let parsed = _lumen_parse_query(raw)
    let keys = _validate.get_keys(schema)
    let out_keys = []
    let out_vals = []
    let ki = 0
    while ki < keys.len() {
        let key = keys[ki]
        let spec = _validate.get_field(schema, key)
        let dflt = _validate.get_field(spec, "default")
        let typ = _validate.get_field(spec, "type")
        if typ == null { typ = "string" }
        let validator = _validate.get_field(spec, "validator")
        let rawv = _validate.get_field(parsed, key)
        let value = dflt
        if rawv != null and rawv != "" {
            let coerced = _lumen_coerce(rawv, typ)
            if coerced != null {
                if validator != null {
                    let res = _validate_parse(validator, coerced)
                    if res.success { value = res.data } else { value = dflt }
                } else {
                    value = coerced
                }
            }
        }
        out_keys = out_keys.push(key)
        out_vals = out_vals.push(value)
        ki = ki + 1
    }
    return http.create_struct(out_keys, out_vals)
}

// Serialize a struct of search values to "?k=v&k2=v2" (skips null/empty; encodes values).
fn lumen_search_to_qs(values) {
    let keys = _validate.get_keys(values)
    let out = ""
    let first = true
    let ki = 0
    while ki < keys.len() {
        let key = keys[ki]
        let v = _validate.get_field(values, key)
        if v != null and ("" + v) != "" {
            if first { out = "?"; first = false } else { out = out + "&" }
            out = out + key + "=" + _lumen_qs_encode("" + v)
        }
        ki = ki + 1
    }
    return out
}

// Hidden marker a component renders so the client syncs the address bar to its state.
fn _lumen_url_marker(values) {
    let qs = lumen_search_to_qs(values)
    return "<div data-lumen-url=\"" + _sanitize.escape_html(qs) + "\" style=\"display:none\"></div>"
}

// ─── Pillar 5: shared reactive query cache. Identical queries across all
// connections share one execution; a DB write bumps the affected tables'
// versions (from the reactive tick), staling matching cache entries. Opt-in:
// route a hot read through cached_query(conn, sql, params, tables). ───

fn _lumen_bump_versions(tables) {
    let ti = 0
    while ti < tables.len() {
        let t = tables[ti]
        let cur = _validate.get_field(_lumen_table_version[0], t)
        if cur == null { cur = 0 }
        _lumen_table_version[0] = _tpl_bind(_lumen_table_version[0], t, cur + 1)
        ti = ti + 1
    }
    return null
}

fn _lumen_version_sig(tables) {
    let sig = ""
    let ti = 0
    while ti < tables.len() {
        let t = tables[ti]
        let v = _validate.get_field(_lumen_table_version[0], t)
        if v == null { v = 0 }
        sig = sig + t + ":" + v + ";"
        ti = ti + 1
    }
    return sig
}

// Run a query through the shared cache. `tables` = the table name(s) the query
// reads (so a write to any of them invalidates this entry). Returns the rows.
fn cached_query(conn, sql, params, tables) {
    if params == null { params = [] }
    if tables == null { tables = [] }
    let key = sql + "||" + json_encode(params)
    let cur_sig = _lumen_version_sig(tables)
    let entry = _validate.get_field(_lumen_qcache[0], key)
    if entry != null {
        if entry.sig == cur_sig {
            let h = _validate.get_field(_lumen_cache_stats[0], "hits")
            _lumen_cache_stats[0] = _tpl_bind(_lumen_cache_stats[0], "hits", h + 1)
            return entry.result
        }
    }
    let result = (conn.query)(sql, params)
    let new_entry = http.create_struct(["result", "sig", "tables"], [result, cur_sig, tables])
    _lumen_qcache[0] = _tpl_bind(_lumen_qcache[0], key, new_entry)
    let m = _validate.get_field(_lumen_cache_stats[0], "misses")
    _lumen_cache_stats[0] = _tpl_bind(_lumen_cache_stats[0], "misses", m + 1)
    return result
}

// Manually invalidate cached queries reading these tables (for Postgres /
// external writes that don't trip the sqlite update hook).
fn lumen_cache_invalidate(tables) {
    _lumen_bump_versions(tables)
    return null
}

fn lumen_perf_stats() {
    let h = _validate.get_field(_lumen_cache_stats[0], "hits")
    let m = _validate.get_field(_lumen_cache_stats[0], "misses")
    let entries = _validate.get_keys(_lumen_qcache[0]).len()
    return http.create_struct(["cache_hits", "cache_misses", "cache_entries"], [h, m, entries])
}

// Register a table so the reactive tick wakes ALL live loops when it changes
// (per-connection render-query model: each loop re-renders from its own state).
fn _lumen_watch_table(t) {
    _lumen_ensure_reactive()
    _lumen_watched_tables[0] = _tpl_bind(_lumen_watched_tables[0], t, true)
    return null
}

// ─── Lumen async resource: off-thread fetch with live re-render ───
// Same surface as lumen_resource but `refetch()` spawns a background task
// that runs the fetcher off the render thread. When the fetch completes,
// the holder is updated and _lumen_live_loop re-renders the component.
// Usage:
//   let users = lumen_async_resource(| | { return db.query("select ...") })
//   render:  if (users.state().loading { ... } else { each users.state().data ... }
//   handler: let _ = (users.refetch)()  // spawns bg fetch; loop re-renders on completion
fn lumen_async_resource(fetcher) {
    let notify_ch = task.channel(64)
    let holder = [http.create_struct(["loading","error","data"], [true, null, null])]
    let apply = |st| { holder[0] = st; return st }
    let run = | | {
        let st = null
        try {
            let d = fetcher()
            st = http.create_struct(["loading","error","data"], [false, null, d])
        } catch e {
            st = http.create_struct(["loading","error","data"], [false, "" + e, null])
        }
        let _ = (apply)(st)
        // Notify the live loop via the global channel
        let _ = _lumen_async_updates <- true
        return st
    }
    // Run once eagerly so first render has data
    let _ = (run)()
    let snapshot = | | { return holder[0] }
    let refetch = | | {
        let _ = task.spawn(run, [])
        return null
    }
    return http.create_struct(
        ["state", "refetch"],
        [snapshot, refetch]
    )
}

// ─── Lumen pub-sub: cross-connection broadcast ───
// `lumen_publish(topic, key, value)` updates a global topic registry and
// notifies all live loops (via _lumen_async_updates) so they re-render.
// `lumen_subscribe(topic)` returns `{ get(key) }` that reads the latest
// value from the shared registry.
// `lumen_broadcast_store(topic, initial)` is a store like lumen_store that
// auto-publishes every `set()` to the topic.
//
// Since all connections share the same VM globals and the scheduler is
// cooperative (single-threaded), there are no race conditions.
//
// Usage:
//   let counter = lumen_broadcast_store("counter", http.create_struct(["n"], [0]))
//   (counter.set)("n", (counter.get)("n") + 1)  // broadcasts to all connections
//   let sub = lumen_subscribe("counter")
//   render:  {{ (sub.get)("n") }}
fn lumen_publish(topic, key, value) {
    let topic_data = _validate.get_field(_lumen_pubsub_data, topic)
    if topic_data == null {
        topic_data = http.create_struct([key], [value])
    } else {
        topic_data = _tpl_bind(topic_data, key, value)
    }
    _lumen_pubsub_data = _tpl_bind(_lumen_pubsub_data, topic, topic_data)
    // Wake all live loops so they re-render with the new value
    let _ = _lumen_async_updates <- true
}

fn lumen_subscribe(topic) {
    let get = |key| {
        let topic_data = _validate.get_field(_lumen_pubsub_data, topic)
        if topic_data == null { return null }
        return _validate.get_field(topic_data, key)
    }
    return http.create_struct(["get"], [get])
}

fn lumen_broadcast_store(topic, initial) {
    let holder = [initial]
    // Publish initial values so late subscribers see them
    let init_keys = _validate.get_keys(initial)
    for i in 0..init_keys.len() {
        let k = init_keys[i]
        let _ = lumen_publish(topic, k, _validate.get_field(initial, k))
    }
    let get = |key| { return _validate.get_field(holder[0], key) }
    let set = |key, value| {
        holder[0] = _tpl_bind(holder[0], key, value)
        let _ = lumen_publish(topic, key, value)
        return null
    }
    let all = | | { return holder[0] }
    return http.create_struct(["get", "set", "all"], [get, set, all])
}

// ─── Lumen form: validated form fields (Zod-style) ───
// `lumen_form(field_schemas)` where field_schemas maps name -> validator.
// Returns { validate(values) -> { ok, values, errors } }.
//
// Usage:
//   let f = lumen_form(http.create_struct(["email"], [validate.str().is_email()]))
//   let r = (f.validate)(form_values)
//   if r.ok { ...save r.values... } else { state.errors = r.errors }
//   template:  {{ errors.email }}
fn lumen_form(field_schemas) {
    let validate = |values| {
        let schema_keys = _validate.get_keys(field_schemas)
        let error_keys = []
        let error_vals = []
        let clean_keys = []
        let clean_vals = []
        for ki in 0..schema_keys.len() {
            let key = schema_keys[ki]
            let validator = _validate.get_field(field_schemas, key)
            let val = _validate.get_field(values, key)
            let res = _validate_parse(validator, val)
            if res.success {
                clean_keys = clean_keys.push(key)
                clean_vals = clean_vals.push(res.data)
            } else {
                error_keys = error_keys.push(key)
                error_vals = error_vals.push(res.error)
            }
        }
        let ok = error_keys.len() == 0
        let clean_struct = http.create_struct(clean_keys, clean_vals)
        let errors_struct = http.create_struct(error_keys, error_vals)
        return http.create_struct(["ok","values","errors"], [ok, clean_struct, errors_struct])
    }
    return http.create_struct(["validate"], [validate])
}

// ─── Lumen M2 — live layer (server-driven interactivity) ───
//
// Build a component struct from its three plain-Varian pieces:
//   state_fn()        -> initial state
//   render_fn(state)  -> rendered HTML string (calls lumen_render internally)
//   handler_names/handler_fns  -> parallel arrays mapping handler name -> fn
//
// Returns a struct with http.create_struct (no parse-order dependency).

fn lumen_component(state_fn, render_fn, handler_names, handler_fns) {
    return http.create_struct(
        ["state_fn", "render_fn", "handler_names", "handler_fns"],
        [state_fn, render_fn, handler_names, handler_fns]
    )
}

// M7 DX: render a component against its initial state to an HTML string.
// Snapshot-friendly: tests can assert on lumen_snapshot(component) directly,
// and it drives any child components through the normal composition pass.
fn lumen_snapshot(component) {
    _lumen_active_child_states = {}
    return (component.render_fn)((component.state_fn)())
}

// ─── Lumen test helpers (Workstream 3) ───

fn lumen_test_render(comp, state) {
    _lumen_active_child_states = {}
    return (comp.render_fn)(state)
}

fn lumen_test_event(comp, state, hname, value) {
    let names = comp.handler_names
    let fns = comp.handler_fns
    let handler = null
    for i in 0..names.len() {
        if names[i] == hname { handler = fns[i]; break }
    }
    if handler == null { return http.create_struct(["state", "html"], [state, ""]) }
    let new_state = null
    try {
        new_state = handler(state, value)
    } catch e {
        new_state = state
    }
    _lumen_active_child_states = {}
    let html = (comp.render_fn)(new_state)
    return http.create_struct(["state", "html"], [new_state, html])
}

fn lumen_test_contains(html, substr) {
    return html.index_of(substr) != -1
}

fn lumen_test_attr(html, attr_name) {
    return html.index_of(attr_name + "=\"") != -1 or html.index_of(attr_name + "=") != -1
}

fn lumen_test_count(html, substr) {
    let count = 0
    let pos = 0
    while true {
        let found = html.index_of(substr, pos)
        if found < 0 { break }
        count = count + 1
        pos = found + substr.len()
    }
    return count
}

fn lumen_test_render_response(comp, state) {
    return lumen_render_response((comp.render_fn)(state), state)
}

// Resolve a handler by name against the registered set ONLY.  Returns null if
// the name isn't registered — the caller must then silently ignore the event.
// This is the security gate: never dispatch an arbitrary name from the wire.
fn _lumen_handler(component, name) {
    let names = component.handler_names
    for i in 0..names.len() {
        if names[i] == name { return component.handler_fns[i] }
    }
    return null
}

// Mount a live component on a Zenith app.
//   GET <path>       → initial HTML page (full shell)
//   GET <path>/live  → WebSocket upgrade → live loop
//
// Uses radix_insert directly instead of app.get() because zenith.vn's impl
// methods aren't visible when this module is compiled (prelude order).
fn _lumen_get_layouts_for_path(path) {
    let segs = path.split("/")
    let layouts = []
    let root_lay = _lumen_get_component("Layout")
    if root_lay != null { layouts = layouts.push(root_lay) }
    let prefix = ""
    for i in 0..segs.len() {
        let seg = segs[i]
        if seg != "" {
            let clean = seg
            if seg.starts_with(":") {
                clean = seg.substring(1, seg.len())
            }
            prefix = prefix + _lumen_pascal(clean)
            let lay = _lumen_get_component(prefix + "Layout")
            if lay != null {
                layouts = layouts.push(lay)
            }
        }
    }
    return layouts
}

fn _lumen_get_loading_for_path(path) {
    let segs = path.split("/")
    let loading = _lumen_get_component("Loading")
    let prefix = ""
    for i in 0..segs.len() {
        let seg = segs[i]
        if seg != "" {
            let clean = seg
            if seg.starts_with(":") {
                clean = seg.substring(1, seg.len())
            }
            prefix = prefix + _lumen_pascal(clean)
            let lod = _lumen_get_component(prefix + "Loading")
            if lod != null {
                loading = lod
            }
        }
    }
    return loading
}

fn lumen_mount(app, path, component) {
    let ws_path = path + "/live"
    if path == "/" { ws_path = "/live" }
    if _lumen_handler(component, "action") != null {
        let post_handler = |req| {
            let act_fn = _lumen_handler(component, "action")
            let res = act_fn(req)
            if res != null { return res }
            return http.create_struct(["status","body","content_type"], [200, "success", "text/plain"])
        }
        radix_insert(app.root, "POST" + path, post_handler, "Lumen action handler")
    }
    let page = |req| {
        let state = (component.state_fn)()
        let loader = _lumen_handler(component, "load")
        if loader != null {
            let loaded = loader(req)
            if loaded != null {
                let lkeys = _validate.get_keys(loaded)
                for lk in 0..lkeys.len() {
                    let k = lkeys[lk]
                    state = _lumen_with_field(state, k, _validate.get_field(loaded, k))
                }
            }
        }
        _lumen_active_child_states = {}
        let inner = (component.render_fn)(state)
        let html = inner
        let layouts = _lumen_get_layouts_for_path(path)
        for i in 0..layouts.len() {
            let idx = layouts.len() - 1 - i
            let lay = layouts[idx]
            let lay_state = state
            if lay.state_fn != null {
                let defaults = (lay.state_fn)()
                let def_keys = _validate.get_keys(defaults)
                for dk in 0..def_keys.len() {
                    let k = def_keys[dk]
                    if _validate.get_field(lay_state, k) == null {
                        lay_state = _lumen_with_field(lay_state, k, _validate.get_field(defaults, k))
                    }
                }
            }
            lay_state = _lumen_with_field(lay_state, "children", html)
            html = (lay.render_fn)(lay_state)
        }
        let loading = _lumen_get_loading_for_path(path)
        let loading_html = ""
        if loading != null {
            loading_html = (loading.render_fn)((loading.state_fn)())
        }
        let full_html = _lumen_shell_with_loading(html, ws_path, _lumen_scan_directives(html), loading_html)
        let state_json = json_encode(state)
        let hydrate_script = "<script id=\"__LUMEN_DATA__\" type=\"application/json\">" + state_json + "</script>"
        let body_end_idx = full_html.index_of("</body>")
        if body_end_idx >= 0 {
            full_html = full_html.substring(0, body_end_idx) + hydrate_script + full_html.substring(body_end_idx, full_html.len())
        }
        return http.create_struct(["status","body","content_type"], [200, full_html, "text/html"])
    }
    let live = |req| {
        let ws = upgrade_websocket(req)
        if ws == null {
            return http.create_struct(["status","body","content_type"], [400, "bad ws", "text/plain"])
        }
        _lumen_live_loop(ws, component, null, req)
        return http.create_struct(["status","body","content_type","_keep_open"], [101, "", "", true])
    }
    radix_insert(app.root, "GET" + path, page, "Lumen page")
    radix_insert(app.root, "GET" + ws_path, live, "Lumen live socket")
}

fn lumen_mount_dynamic(app, path, component, param) {
    let ws_path = path + "/live"
    if path == "/" { ws_path = "/live" }
    if _lumen_handler(component, "action") != null {
        let post_handler = |req| {
            let act_fn = _lumen_handler(component, "action")
            let res = act_fn(req)
            if res != null { return res }
            return http.create_struct(["status","body","content_type"], [200, "success", "text/plain"])
        }
        radix_insert(app.root, "POST" + path, post_handler, "Lumen action handler")
    }
    let page = |req| {
        let state = (component.state_fn)()
        let pval = _validate.get_field(req.params, param)
        if pval != null {
            state = _lumen_with_field(state, param, pval)
        }
        let loader = _lumen_handler(component, "load")
        if loader != null {
            let loaded = loader(req)
            if loaded != null {
                let lkeys = _validate.get_keys(loaded)
                for lk in 0..lkeys.len() {
                    let k = lkeys[lk]
                    state = _lumen_with_field(state, k, _validate.get_field(loaded, k))
                }
            }
        }
        _lumen_active_child_states = {}
        let inner = (component.render_fn)(state)
        let html = inner
        let layouts = _lumen_get_layouts_for_path(path)
        for i in 0..layouts.len() {
            let idx = layouts.len() - 1 - i
            let lay = layouts[idx]
            let lay_state = state
            if lay.state_fn != null {
                let defaults = (lay.state_fn)()
                let def_keys = _validate.get_keys(defaults)
                for dk in 0..def_keys.len() {
                    let k = def_keys[dk]
                    if _validate.get_field(lay_state, k) == null {
                        lay_state = _lumen_with_field(lay_state, k, _validate.get_field(defaults, k))
                    }
                }
            }
            lay_state = _lumen_with_field(lay_state, "children", html)
            html = (lay.render_fn)(lay_state)
        }
        let loading = _lumen_get_loading_for_path(path)
        let loading_html = ""
        if loading != null {
            loading_html = (loading.render_fn)((loading.state_fn)())
        }
        let full_html = _lumen_shell_with_loading(html, ws_path, _lumen_scan_directives(html), loading_html)
        let state_json = json_encode(state)
        let hydrate_script = "<script id=\"__LUMEN_DATA__\" type=\"application/json\">" + state_json + "</script>"
        let body_end_idx = full_html.index_of("</body>")
        if body_end_idx >= 0 {
            full_html = full_html.substring(0, body_end_idx) + hydrate_script + full_html.substring(body_end_idx, full_html.len())
        }
        return http.create_struct(["status","body","content_type"], [200, full_html, "text/html"])
    }
    let live = |req| {
        let ws = upgrade_websocket(req)
        if ws == null {
            return http.create_struct(["status","body","content_type"], [400, "bad ws", "text/plain"])
        }
        _lumen_live_loop(ws, component, null, req)
        return http.create_struct(["status","body","content_type","_keep_open"], [101, "", "", true])
    }
    radix_insert(app.root, "GET" + path, page, "Lumen page")
    radix_insert(app.root, "GET" + ws_path, live, "Lumen live socket")
}

fn lumen_mount_data(app, path, component, provider) {
    let ws_path = path + "/live"
    if path == "/" { ws_path = "/live" }
    if _lumen_handler(component, "action") != null {
        let post_handler = |req| {
            let act_fn = _lumen_handler(component, "action")
            let res = act_fn(req)
            if res != null { return res }
            return http.create_struct(["status","body","content_type"], [200, "success", "text/plain"])
        }
        radix_insert(app.root, "POST" + path, post_handler, "Lumen action handler")
    }
    let page = |req| {
        let state = (provider)(req)
        let loader = _lumen_handler(component, "load")
        if loader != null {
            let loaded = loader(req)
            if loaded != null {
                let lkeys = _validate.get_keys(loaded)
                for lk in 0..lkeys.len() {
                    let k = lkeys[lk]
                    state = _lumen_with_field(state, k, _validate.get_field(loaded, k))
                }
            }
        }
        _lumen_active_child_states = {}
        let inner = (component.render_fn)(state)
        let html = inner
        let layouts = _lumen_get_layouts_for_path(path)
        for i in 0..layouts.len() {
            let idx = layouts.len() - 1 - i
            let lay = layouts[idx]
            let lay_state = state
            if lay.state_fn != null {
                let defaults = (lay.state_fn)()
                let def_keys = _validate.get_keys(defaults)
                for dk in 0..def_keys.len() {
                    let k = def_keys[dk]
                    if _validate.get_field(lay_state, k) == null {
                        lay_state = _lumen_with_field(lay_state, k, _validate.get_field(defaults, k))
                    }
                }
            }
            lay_state = _lumen_with_field(lay_state, "children", html)
            html = (lay.render_fn)(lay_state)
        }
        let loading = _lumen_get_loading_for_path(path)
        let loading_html = ""
        if loading != null {
            loading_html = (loading.render_fn)((loading.state_fn)())
        }
        let full_html = _lumen_shell_with_loading(html, ws_path, _lumen_scan_directives(html), loading_html)
        let state_json = json_encode(state)
        let hydrate_script = "<script id=\"__LUMEN_DATA__\" type=\"application/json\">" + state_json + "</script>"
        let body_end_idx = full_html.index_of("</body>")
        if body_end_idx >= 0 {
            full_html = full_html.substring(0, body_end_idx) + hydrate_script + full_html.substring(body_end_idx, full_html.len())
        }
        return http.create_struct(["status","body","content_type"], [200, full_html, "text/html"])
    }
    let live = |req| {
        let ws = upgrade_websocket(req)
        if ws == null {
            return http.create_struct(["status","body","content_type"], [400, "bad ws", "text/plain"])
        }
        _lumen_live_loop(ws, component, provider, req)
        return http.create_struct(["status","body","content_type","_keep_open"], [101, "", "", true])
    }
    radix_insert(app.root, "GET" + path, page, "Lumen page")
    radix_insert(app.root, "GET" + ws_path, live, "Lumen live socket")
}

// ─── SEO & Metadata ───
// Per-request metadata accumulated by the page's <script>. Reset before each render.
let _lumen_page_meta = {}
let _lumen_custom_head = ""

// Declare metadata for the current page. Call at top of <script>:
//   lumen_meta("My Page", "A description", { image: "/og.png", twitter: "@handle" })
// The values are injected into <head> by _lumen_shell.
fn lumen_meta(title, description, og) {
    if og == null { og = {} }
    _lumen_page_meta = http.create_struct(
        ["title", "description", "og_title", "og_description", "og_image", "twitter_card", "twitter_site",
         "canonical", "hreflang", "og_type", "og_url", "og_site_name", "og_locale",
         "twitter_title", "twitter_description", "twitter_image", "twitter_creator"],
        ["" + title, "" + description,
         "" + _validate.get_field(og, "title"), "" + _validate.get_field(og, "description"),
         "" + _validate.get_field(og, "image"), "" + _validate.get_field(og, "twitter"),
         "" + _validate.get_field(og, "site"),
         "" + _validate.get_field(og, "canonical"), "" + _validate.get_field(og, "hreflang"),
         "" + _validate.get_field(og, "type"), "" + _validate.get_field(og, "url"),
         "" + _validate.get_field(og, "site_name"), "" + _validate.get_field(og, "locale"),
         "" + _validate.get_field(og, "twitter_title"), "" + _validate.get_field(og, "twitter_description"),
         "" + _validate.get_field(og, "twitter_image"), "" + _validate.get_field(og, "twitter_creator")]
    )
}

fn _lumen_meta_safe(v) {
    if v == null or v == "null" or v == "" { return null }
    return v
}

// Generate <meta> and <link> tags from a meta struct. Returns empty string if no meta set.
fn _lumen_meta_tags() {
    let m = _lumen_page_meta
    let t = _lumen_meta_safe(_validate.get_field(m, "title"))
    if t == null { return "" }
    let desc = _lumen_meta_safe(_validate.get_field(m, "description"))
    let og_t = _lumen_meta_safe(_validate.get_field(m, "og_title"))
    if og_t == null { og_t = t }
    let og_d = _lumen_meta_safe(_validate.get_field(m, "og_description"))
    if og_d == null { og_d = desc }
    let og_i = _lumen_meta_safe(_validate.get_field(m, "og_image"))
    let tw_c = _lumen_meta_safe(_validate.get_field(m, "twitter_card"))
    let tw_s = _lumen_meta_safe(_validate.get_field(m, "twitter_site"))
    let ca = _lumen_meta_safe(_validate.get_field(m, "canonical"))
    let hl = _lumen_meta_safe(_validate.get_field(m, "hreflang"))
    let og_ty = _lumen_meta_safe(_validate.get_field(m, "og_type"))
    let og_u = _lumen_meta_safe(_validate.get_field(m, "og_url"))
    let og_sn = _lumen_meta_safe(_validate.get_field(m, "og_site_name"))
    let og_lo = _lumen_meta_safe(_validate.get_field(m, "og_locale"))
    let tw_t = _lumen_meta_safe(_validate.get_field(m, "twitter_title"))
    let tw_d = _lumen_meta_safe(_validate.get_field(m, "twitter_description"))
    let tw_i = _lumen_meta_safe(_validate.get_field(m, "twitter_image"))
    let tw_cr = _lumen_meta_safe(_validate.get_field(m, "twitter_creator"))
    let out = ""
    if t != null {
        out = out + "<title>" + _sanitize.escape_html(t) + "</title>\n"
        out = out + "<meta property=\"og:title\" content=\"" + _sanitize.escape_html(og_t) + "\">\n"
    }
    if desc != null {
        out = out + "<meta name=\"description\" content=\"" + _sanitize.escape_html(desc) + "\">\n"
        out = out + "<meta property=\"og:description\" content=\"" + _sanitize.escape_html(og_d) + "\">\n"
    }
    if og_i != null {
        out = out + "<meta property=\"og:image\" content=\"" + _sanitize.escape_html(og_i) + "\">\n"
    }
    if og_u != null {
        out = out + "<meta property=\"og:url\" content=\"" + _sanitize.escape_html(og_u) + "\">\n"
    }
    if og_sn != null {
        out = out + "<meta property=\"og:site_name\" content=\"" + _sanitize.escape_html(og_sn) + "\">\n"
    }
    if og_lo != null {
        out = out + "<meta property=\"og:locale\" content=\"" + _sanitize.escape_html(og_lo) + "\">\n"
    }
    if og_ty != null {
        out = out + "<meta property=\"og:type\" content=\"" + _sanitize.escape_html(og_ty) + "\">\n"
    } else {
        out = out + "<meta property=\"og:type\" content=\"website\">\n"
    }
    if tw_c != null {
        out = out + "<meta name=\"twitter:card\" content=\"" + _sanitize.escape_html(tw_c) + "\">\n"
    }
    if tw_s != null {
        out = out + "<meta name=\"twitter:site\" content=\"" + _sanitize.escape_html(tw_s) + "\">\n"
    }
    if tw_t != null {
        out = out + "<meta name=\"twitter:title\" content=\"" + _sanitize.escape_html(tw_t) + "\">\n"
    }
    if tw_d != null {
        out = out + "<meta name=\"twitter:description\" content=\"" + _sanitize.escape_html(tw_d) + "\">\n"
    }
    if tw_i != null {
        out = out + "<meta name=\"twitter:image\" content=\"" + _sanitize.escape_html(tw_i) + "\">\n"
    }
    if tw_cr != null {
        out = out + "<meta name=\"twitter:creator\" content=\"" + _sanitize.escape_html(tw_cr) + "\">\n"
    }
    if ca != null {
        out = out + "<link rel=\"canonical\" href=\"" + _sanitize.escape_html(ca) + "\">\n"
    }
    if hl != null {
        out = out + "<link rel=\"alternate\" hreflang=\"" + _sanitize.escape_html(hl) + "\">\n"
    }
    return out
}

// ─── M4: DOM patch protocol ───
// Send a render to the client as a minimal splice patch instead of full HTML.
// We compute the longest common ASCII prefix (p) and suffix (q) between the
// previously-sent HTML and the new HTML, and send only the changed middle:
//   { t: "p", s: p, e: q, d: middle }
// The client reconstructs:  new = prev[0:p] + d + prev[len-q:]  then morphs.
// Keeping the prefix/suffix ASCII-only guarantees the server's byte offsets
// equal the client's JS (UTF-16) string indices, so Unicode in the changed
// middle (sent verbatim in d) can never corrupt the splice. prev == null means
// "no baseline yet" (fresh connect) → send the full HTML to (re)sync.
fn _lumen_send_update(ws, prev, html) {
    if prev == null {
        ws.write(json_encode({ t: "html", html: html }))
        return html
    }
    let pn = prev.len()
    let hn = html.len()
    let lim = pn
    if hn < lim { lim = hn }
    let p = 0
    while p < lim {
        let cc = prev.code_at(p)
        if cc != html.code_at(p) { break }
        if cc >= 128 { break }   // keep prefix ASCII so byte offset == JS index
        p = p + 1
    }
    let q = 0
    let qlim = lim - p
    while q < qlim {
        let cp = prev.code_at(pn - 1 - q)
        if cp != html.code_at(hn - 1 - q) { break }
        if cp >= 128 { break }
        q = q + 1
    }
    let mid = html.substring(p, hn - q)
    ws.write(json_encode({ t: "p", s: p, e: q, d: mid }))
    return html
}

// M7 DX: turn a caught handler error into a friendly dev overlay message.
// errors.explain() gives a what/fix block; fall back to the raw value.
fn _lumen_error_msg(e) {
    let detail = errors.explain(e)
    if detail == null { return "" + e }
    return detail
}

// Dev only: drain server-side print() output captured during a handler/render
// and push it to the browser devtools over the live socket as a {t:"log"} frame
// (one entry per line). This is the "view server logs in the browser" feature —
// print() still writes to the terminal too. No-op unless `vn dev` set LUMEN_DEV.
fn _lumen_emit_logs(ws) {
    let out = __lumen_log_drain()
    if out == "" { return }
    let raw = out.split("\n")
    let lines = []
    for i in 0..raw.len() {
        if raw[i] != "" { lines = lines.push(raw[i]) }
    }
    if lines.len() > 0 {
        ws.write(json_encode({ t: "log", lines: lines }))
    }
}

// Per-connection event loop.
// ws.read() is NON-BLOCKING (returns "" on EAGAIN, null on close).
// The loop yields via task.yield() when no message is available so the
// cooperative scheduler can service other connections.
fn _lumen_live_loop(ws, component, provider, req) {
    let _dev = env.get("LUMEN_DEV")
    let _devon = _dev != null and _dev != ""
    if _devon { __lumen_log_start() }
    let state = null

    let init_msg = ""
    let read_attempts = 0
    while init_msg == "" and read_attempts < 200 {
        init_msg = ws.read()
        if init_msg == "" {
            task.yield()
            read_attempts = read_attempts + 1
        }
    }
    if init_msg != null and init_msg != "" {
        let init_ev = json_decode(init_msg)
        if init_ev != null and _validate.get_field(init_ev, "t") == "init" {
            state = _validate.get_field(init_ev, "state")
        }
    }

    if state == null {
        if provider != null {
            state = (provider)(req)
        } else {
            state = (component.state_fn)()
            let loader = _lumen_handler(component, "load")
            if loader != null {
                let loaded = loader(req)
                if loaded != null {
                    let lkeys = _validate.get_keys(loaded)
                    for lk in 0..lkeys.len() {
                        let k = lkeys[lk]
                        state = _lumen_with_field(state, k, _validate.get_field(loaded, k))
                    }
                }
            }
        }
    }
    _lumen_active_child_states = {}
    let _initial = (component.render_fn)(state)
    let child_states = _lumen_active_child_states
    if _devon { _lumen_emit_logs(ws) }

    let user_id = null
    try {
        if req.session != null {
            user_id = _validate.get_field(req.session, "user_id")
        }
    } catch e {}
    if user_id == null {
        user_id = "user_" + crypto.random_string(4)
    }
    let meta = http.create_struct(["user_id", "browser"], [user_id, "Lumen Client"])
    let topic = ws.path
    if topic == null or topic == "" { topic = "default" }

    let conn_id = crypto.random_string(8)
    let conn_info = http.create_struct(
        ["id", "ws", "component", "state", "req", "topic", "prev_html"],
        [conn_id, ws, component, state, req, topic, _initial]
    )
    _lumen_active_connections = _lumen_active_connections.push(conn_info)
    lumen_presence_join(topic, user_id, meta)

    let prev = _initial
    let alive = true
    while alive {
        let msg = ws.read()
        if msg == null {
            alive = false
        } else if msg != "" {
            let ev = json_decode(msg)
            let kind = _validate.get_field(ev, "t")
            if kind == "event" {
                let hname = _validate.get_field(ev, "h")
                let value = _validate.get_field(ev, "v")
                _lumen_active_child_states = child_states

                let colon_pos = hname.index_of(":")
                if colon_pos >= 0 {
                    let child_id = hname.substring(0, colon_pos)
                    let child_hname = hname.substring(colon_pos + 1, hname.len())
                    let child_state = _validate.get_field(child_states, child_id)
                    if child_state != null {
                        let comp_name = child_state._comp
                        let comp = _lumen_get_component(comp_name)
                        if comp != null {
                            let handler = _lumen_handler(comp, child_hname)
                            if handler != null {
                                if _devon { __lumen_log_start() }
                                try {
                                    let new_child_state = handler(child_state, value)
                                    new_child_state = _tpl_bind(new_child_state, "_comp", comp_name)
                                    new_child_state = _tpl_bind(new_child_state, "_id", child_id)
                                    child_states = _tpl_bind(child_states, child_id, new_child_state)
                                    _lumen_active_child_states = child_states
                                    let html = (component.render_fn)(state)
                                    child_states = _lumen_active_child_states
                                    if _devon { _lumen_emit_logs(ws) }
                                    prev = _lumen_send_update(ws, prev, html)
                                    conn_info.prev_html = html
                                } catch e {
                                    if _devon { _lumen_emit_logs(ws) }
                                    ws.write(json_encode({ t: "error", msg: _lumen_error_msg(e) }))
                                }
                            }
                        }
                    }
                } else {
                    let handler = _lumen_handler(component, hname)
                    if handler != null {
                        if _devon { __lumen_log_start() }
                        try {
                            state = handler(state, value)
                            conn_info.state = state
                            let html = (component.render_fn)(state)
                            conn_info.prev_html = html
                            child_states = _lumen_active_child_states
                            if _devon { _lumen_emit_logs(ws) }
                            prev = _lumen_send_update(ws, prev, html)
                        } catch e {
                            if _devon { _lumen_emit_logs(ws) }
                            ws.write(json_encode({ t: "error", msg: _lumen_error_msg(e) }))
                        }
                    }
                }
            }
        } else {
            task.yield()
        }
        // After every iteration, check for async resource updates.
        // Drain all pending notifications; re-render once if any arrived.
        while true {
            let upd = task.try_receive(_lumen_async_updates)
            if upd == null { break }
            let html = (component.render_fn)(state)
            child_states = _lumen_active_child_states
            prev = _lumen_send_update(ws, prev, html)
        }
    }
    // Disconnect teardown: drop this connection from the active set and leave
    // its presence topic, so closed sockets don't accumulate (keeps the
    // presence broadcast + re-render fan-out bounded). NOTE: do NOT touch
    // _lumen_query_deps here — those refetch closures are shared across all
    // connections (the live_query core is a singleton), so removing them would
    // break still-open clients.
    let _kept = []
    let _ci = 0
    while _ci < _lumen_active_connections.len() {
        if _lumen_active_connections[_ci].id != conn_id {
            _kept = _kept.push(_lumen_active_connections[_ci])
        }
        _ci = _ci + 1
    }
    _lumen_active_connections = _kept
    lumen_presence_leave(topic, user_id)
}

// The <head> Lumen injects into every page: responsive viewport, the full
// favicon set (served from /public — see _lumen_build_dir), a web-app
// manifest, the Degular typeface (loaded via Adobe Fonts), and a base style
// that wires Degular up with a system-font fallback so a page looks right
// even before the webfont arrives. This is the "batteries-included" head
// every Next/Nuxt/Vite starter ships — authors never write it themselves.
fn _lumen_head() {
    let base = "<meta charset=\"utf-8\">" +
               "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">" +
               "<title>Aurora</title>" +
               "<meta name=\"theme-color\" content=\"#FBFCFF\" media=\"(prefers-color-scheme: light)\">" +
               "<meta name=\"theme-color\" content=\"#0B1020\" media=\"(prefers-color-scheme: dark)\">" +
               "<link rel=\"icon\" href=\"/favicon.ico\" sizes=\"any\">" +
               "<link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon-32x32.png\">" +
               "<link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon-16x16.png\">" +
               "<link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">" +
               "<link rel=\"manifest\" href=\"/manifest.json\">" +
               "<link rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap\">" +
               "<script>!function()\{var d=document.documentElement,t=localStorage.getItem('lumen-theme');if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme: dark)').matches))d.classList.add('dark')\}();</script>" +
"<style>:root\{--lumen-bg:#09090b;--lumen-fg:#fafafa;--lumen-muted:#a1a1aa;--lumen-primary:#4FACFE;--lumen-primary-fg:#09090b;--lumen-primary-hover:#7fc4fe;--lumen-surface:#131316;--lumen-surface-2:#1c1c20;--lumen-border:#232327;--lumen-radius:12px;--lumen-shadow:0 1px 2px rgba(0,0,0,.3),0 12px 28px -12px rgba(0,0,0,.5);--lumen-font:\"Plus Jakarta Sans\",ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;--lumen-mono:ui-monospace,SFMono-Regular,\"JetBrains Mono\",Menlo,monospace;--hue-aurora-1:#4FACFE;--hue-aurora-2:#00F2FE;--hue-zenith:#5b9cff;--hue-lumen:#f5b829;--hue-kiln:#f97316;--hue-constellation:#a78bfa\}" +
                ":root.dark\{--lumen-bg:#FBFCFF;--lumen-fg:#0B1020;--lumen-muted:#71717a;--lumen-surface:#ffffff;--lumen-surface-2:#f1f5f9;--lumen-border:#e2e8f0\}" +
               "html\{font-family:var(--lumen-font);-webkit-font-smoothing:antialiased\}" +
               "body\{margin:0;background:var(--lumen-bg);color:var(--lumen-fg);transition:background 0.3s ease,color 0.3s ease\}</style>"
    let custom = _lumen_custom_head
    if custom != null and custom != "" {
        base = base + custom
    }
    return base
}

// ═══════════════════════════════════════════════════════════════════════════
//  Lumen UI — the built-in component vocabulary (the framework's "identity")
// ═══════════════════════════════════════════════════════════════════════════
//
// These ship with Lumen and are registered at load time, so any template can
// compose with <Page>, <Stack>, <Grid>, <Card>, <Heading>, <Button>, ... the
// same way it nests user components. They are *presentational* (stateless):
// props arrive as tag attributes, children as the slot. Everything is driven by
// the design tokens in _lumen_design_css() so light/dark + brand are automatic.
// A page wrapped in <Page> reads like Lumen, not like raw HTML with inline CSS.

// Safe prop read: missing attrs return the default instead of erroring.
fn _ui_prop(s, key, dflt) {
    let v = _validate.get_field(s, key)
    if v == null { return dflt }
    return v
}

// Slot content for a paired tag; "" when self-closing / empty.
fn _ui_slot(s) {
    let c = _validate.get_field(s, "children")
    if c == null { return "" }
    return c
}

// True when a bare boolean-style attr is present and not "false"/"0".
fn _ui_flag(s, key) {
    let v = _validate.get_field(s, key)
    if v == null { return false }
    if v == "false" or v == "0" or v == "no" { return false }
    return true
}

// 0.25rem spacing scale (Tailwind-ish), resolved to an explicit rem so it works
// even on a page that never pulled in the token stylesheet.
fn _ui_space(v) {
    if v == "0" { return "0" }
    if v == "1" { return "0.25rem" }
    if v == "2" { return "0.5rem" }
    if v == "3" { return "0.75rem" }
    if v == "4" { return "1rem" }
    if v == "5" { return "1.25rem" }
    if v == "6" { return "1.5rem" }
    if v == "8" { return "2rem" }
    if v == "10" { return "2.5rem" }
    if v == "12" { return "3rem" }
    if v == "16" { return "4rem" }
    if v == "20" { return "5rem" }
    if v == "24" { return "6rem" }
    if v == "32" { return "8rem" }
    return "1rem"
}

// Heading scale → font-size.
fn _ui_font(v) {
    if v == "xs"   { return "0.75rem" }
    if v == "sm"   { return "0.875rem" }
    if v == "base" { return "1rem" }
    if v == "lg"   { return "1.125rem" }
    if v == "xl"   { return "1.25rem" }
    if v == "2xl"  { return "1.5rem" }
    if v == "3xl"  { return "1.875rem" }
    if v == "4xl"  { return "2.25rem" }
    if v == "5xl"  { return "3rem" }
    if v == "6xl"  { return "3.75rem" }
    return "1rem"
}

// Border-radius scale
fn _ui_radius(v) {
    if v == "none" { return "0" }
    if v == "sm"   { return "8px" }
    if v == "md"   { return "var(--lumen-radius)" }
    if v == "lg"   { return "16px" }
    if v == "full" { return "999px" }
    return "var(--lumen-radius)"
}

// Flex align-items: short word -> CSS value
fn _ui_align(v) {
    if v == "start"   { return "flex-start" }
    if v == "center"  { return "center" }
    if v == "end"     { return "flex-end" }
    if v == "stretch" { return "stretch" }
    return "stretch"
}

// Flex justify-content: short word -> CSS value
fn _ui_justify(v) {
    if v == "start"   { return "flex-start" }
    if v == "center"  { return "center" }
    if v == "end"     { return "flex-end" }
    if v == "between" { return "space-between" }
    if v == "around"  { return "space-around" }
    return "flex-start"
}

// Background surface token -> CSS background value
fn _ui_bg(v) {
    if v == "surface"   { return "var(--lumen-surface)" }
    if v == "surface-2" { return "var(--lumen-surface-2)" }
    if v == "muted"     { return "var(--lumen-muted)" }
    if v == "primary"   { return "var(--lumen-primary)" }
    return ""
}

// Tone -> "color:…;background:…;" declaration string
fn _ui_tone(v) {
    if v == "default" { return "color:var(--lumen-fg);background:transparent" }
    if v == "muted"   { return "color:var(--lumen-muted-fg);background:var(--lumen-surface-2)" }
    if v == "primary" { return "color:var(--lumen-primary-fg);background:var(--lumen-primary)" }
    if v == "success" { return "color:#0b7a52;background:var(--lumen-success-bg)" }
    if v == "danger"  { return "color:#b42318;background:var(--lumen-danger-bg)" }
    if v == "info"    { return "color:#1d4ed8;background:var(--lumen-info-bg)" }
    return ""
}

// Container width scale (reuses .lmn-container max-widths)
fn _ui_width(v) {
    if v == "sm"   { return "640px" }
    if v == "md"   { return "820px" }
    if v == "lg"   { return "1040px" }
    if v == "xl"   { return "1280px" }
    if v == "full" { return "100%" }
    return ""
}

// ─── Shared style-prop vocabulary (Part B of Lumen vocab spec) ───
// Every built-in component accepts these via _ui_style_props(s):
//   pad/padx/pady → padding variants          (space scale, _ui_space)
//   m/mx/my/mt/mb → margin variants            (space scale)
//   gap           → gap                        (space scale)
//   align         → align-items                (start/center/end/stretch)
//   justify       → justify-content            (start/center/end/between/around)
//   w/maxw        → width/max-width            (sm/md/lg/xl/full)
//   bg            → background                 (surface/surface-2/muted/primary)
//   tone          → color + background pair    (default/muted/primary/success/danger/info)
//   radius        → border-radius              (none/sm/md/lg/full)
//   shadow        → box-shadow                 (flag)
//   border        → 1px solid var(--lumen-border) (flag)
fn _ui_style_props(s) {
    let d = ""
    let pad  = _validate.get_field(s, "pad");  if pad  != null { d = d + "padding:" + _ui_space(pad) + ";" }
    let px   = _validate.get_field(s, "padx"); if px   != null { d = d + "padding-inline:" + _ui_space(px) + ";" }
    let py   = _validate.get_field(s, "pady"); if py   != null { d = d + "padding-block:" + _ui_space(py) + ";" }
    let m    = _validate.get_field(s, "m");    if m    != null { d = d + "margin:" + _ui_space(m) + ";" }
    let mx   = _validate.get_field(s, "mx");   if mx   != null { d = d + "margin-inline:" + _ui_space(mx) + ";" }
    let my   = _validate.get_field(s, "my");   if my   != null { d = d + "margin-block:" + _ui_space(my) + ";" }
    let mt   = _validate.get_field(s, "mt");   if mt   != null { d = d + "margin-top:" + _ui_space(mt) + ";" }
    let mb   = _validate.get_field(s, "mb");   if mb   != null { d = d + "margin-bottom:" + _ui_space(mb) + ";" }
    let gap_v = _validate.get_field(s, "gap");   if gap_v   != null { d = d + "gap:" + _ui_space(gap_v) + ";" }
    let align_v = _validate.get_field(s, "align");   if align_v   != null { d = d + "align-items:" + _ui_align(align_v) + ";" }
    let justify_v = _validate.get_field(s, "justify");   if justify_v   != null { d = d + "justify-content:" + _ui_justify(justify_v) + ";" }
    let w_v  = _validate.get_field(s, "w");      if w_v     != null { d = d + "width:" + _ui_width(w_v) + ";" }
    let mw_v = _validate.get_field(s, "maxw");    if mw_v    != null { d = d + "max-width:" + _ui_width(mw_v) + ";" }
    let bg_v = _validate.get_field(s, "bg");      if bg_v    != null { d = d + "background:" + _ui_bg(bg_v) + ";" }
    let tone_v = _validate.get_field(s, "tone");   if tone_v  != null { d = d + _ui_tone(tone_v) + ";" }
    let rad_v = _validate.get_field(s, "radius");  if rad_v   != null { d = d + "border-radius:" + _ui_radius(rad_v) + ";" }
    if _ui_flag(s, "shadow") { d = d + "box-shadow:var(--lumen-shadow);" }
    if _ui_flag(s, "border") { d = d + "border:1px solid var(--lumen-border);" }
    return d
}

// Make a stateless built-in component from a render fn.
fn _ui_component(render_fn) {
    return lumen_component(| | { return {} }, render_fn, [], [])
}

// The Lumen design system: self-contained tokens (so it stands alone on a
// static page) + a small, opinionated set of component classes. Emitted once by
// <Page> and also folded into the live shell <head>. Brand = amber #f5b829,
// dark-native, Degular via the page's own font link.
fn _lumen_design_css() {
    return "<style id=\"lumen-ui\">" +
        ":root\{--lumen-bg:#09090b;--lumen-fg:#fafafa;--lumen-muted:#a1a1aa;--lumen-primary:#4FACFE;--lumen-primary-fg:#09090b;--lumen-primary-hover:#7fc4fe;--lumen-surface:#131316;--lumen-surface-2:#1c1c20;--lumen-border:#232327;--lumen-radius:12px;--lumen-shadow:0 1px 2px rgba(0,0,0,.3),0 12px 28px -12px rgba(0,0,0,.5);--lumen-font:\"Plus Jakarta Sans\",ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;--lumen-mono:ui-monospace,SFMono-Regular,\"JetBrains Mono\",Menlo,monospace;--hue-aurora-1:#4FACFE;--hue-aurora-2:#00F2FE;--hue-zenith:#5b9cff;--hue-lumen:#f5b829;--hue-kiln:#f97316;--hue-constellation:#a78bfa\}" +
        ":root.dark\{--lumen-bg:#FBFCFF;--lumen-fg:#0B1020;--lumen-muted:#71717a;--lumen-surface:#ffffff;--lumen-surface-2:#f1f5f9;--lumen-border:#e2e8f0\}" +
        ".lmn-app\{font-family:var(--lumen-font);color:var(--lumen-fg);background:var(--lumen-bg);-webkit-font-smoothing:antialiased;line-height:1.55\}" +
        ".lmn-container\{width:100%;margin-inline:auto;padding-inline:1.25rem;box-sizing:border-box\}" +
        ".lmn-container[data-size=sm]\{max-width:640px\}.lmn-container[data-size=md]\{max-width:820px\}.lmn-container[data-size=lg]\{max-width:1040px\}.lmn-container[data-size=xl]\{max-width:1280px\}.lmn-container[data-size=full]\{max-width:none\}" +
        ".lmn-section\{padding-block:5rem\}.lmn-section[data-border=true]\{border-top:1px solid var(--lumen-border)\}" +
        ".lmn-stack\{display:flex;flex-direction:column\}.lmn-row\{display:flex;flex-direction:row;align-items:center}.lmn-row[data-wrap=true]\{flex-wrap:wrap\}" +
        ".lmn-grid\{display:grid;grid-template-columns:repeat(var(--lumen-cols,3),minmax(0,1fr))\}@media(max-width:760px)\{.lmn-grid\{grid-template-columns:1fr\}\}" +
        ".lmn-card\{background:var(--lumen-surface);border:1px solid var(--lumen-border);border-radius:var(--lumen-radius);box-shadow:var(--lumen-shadow);padding:1.5rem\}" +
        ".lmn-h\{font-family:var(--lumen-font);font-weight:800;letter-spacing:-.02em;line-height:1.1;margin:0\}" +
        ".lmn-text\{margin:0;color:var(--lumen-fg)\}.lmn-text[data-muted=true]\{color:var(--lumen-muted)\}" +
        ".lmn-eyebrow\{font-size:.75rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--lumen-primary);margin:0\}" +
        ".lmn-btn\{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;font:inherit;font-weight:600;border-radius:10px;padding:.6rem 1.1rem;border:1px solid transparent;cursor:pointer;text-decoration:none;transition:transform .04s ease,background .15s ease,border-color .15s ease}.lmn-btn:active\{transform:translateY(1px)\}" +
        ".lmn-btn[data-variant=primary]\{background:var(--lumen-primary);color:var(--lumen-primary-fg)}.lmn-btn[data-variant=primary]:hover\{background:var(--lumen-primary-hover)\}" +
        ".lmn-btn[data-variant=outline]\{background:transparent;color:var(--lumen-fg);border-color:var(--lumen-border)}.lmn-btn[data-variant=outline]:hover\{border-color:var(--lumen-primary)\}" +
        ".lmn-btn[data-variant=ghost]\{background:transparent;color:var(--lumen-fg)}.lmn-btn[data-variant=ghost]:hover\{background:var(--lumen-surface-2)\}" +
        ".lmn-badge\{display:inline-flex;align-items:center;gap:.35rem;font-size:.78rem;font-weight:600;padding:.18rem .6rem;border-radius:999px;background:var(--lumen-surface-2);color:var(--lumen-muted);border:1px solid var(--lumen-border)\}" +
        ".lmn-badge[data-tone=success]\{color:#0b7a52;background:rgba(77,212,172,.16);border-color:transparent}.lmn-badge[data-tone=danger]\{color:#b42318;background:rgba(255,107,107,.16);border-color:transparent}.lmn-badge[data-tone=info]\{color:#1d4ed8;background:rgba(91,156,255,.16);border-color:transparent\}" +
        ".lmn-feature\{display:flex;flex-direction:column;gap:.75rem;padding:1.5rem;border:1px solid var(--lumen-border);border-radius:var(--lumen-radius);background:var(--lumen-surface)}.lmn-feature .lmn-ico\{width:42px;height:42px;display:flex;align-items:center;justify-content:center;border-radius:10px;background:rgba(245,184,41,.14);color:var(--lumen-primary)\}" +
        ".lmn-divider\{border:0;border-top:1px solid var(--lumen-border);margin:0\}" +
        ".lmn-hero\{padding:8rem 1.25rem 4rem;overflow:hidden\}" +
        ".lmn-hero-inner\{max-width:1040px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center\}" +
        ".lmn-hero-content\{display:flex;flex-direction:column\}" +
        ".lmn-hero-title\{font-size:4rem;font-weight:800;letter-spacing:-.03em;line-height:1.05;margin:0 0 1.25rem\}" +
        ".lmn-hero-subtitle\{font-size:1.125rem;line-height:1.6;color:var(--lumen-muted);margin:0 0 2.5rem;max-width:520px\}" +
        ".lmn-hero-img-wrap\{border-radius:24px;overflow:hidden;box-shadow:0 24px 64px -16px rgba(0,0,0,.2);transform:perspective(1000px) rotateY(-5deg);transition:transform .5s ease\}" +
        ".lmn-hero-img-wrap:hover\{transform:perspective(1000px) rotateY(0deg)\}" +
        ".lmn-hero-img\{width:100%;height:auto;display:block;object-fit:cover\}" +
        ".lmn-hero-center .lmn-hero-inner\{grid-template-columns:1fr;text-align:center\}" +
        ".lmn-hero-center .lmn-hero-content\{align-items:center\}" +
        ".lmn-hero-center .lmn-hero-img-wrap\{display:none\}" +
        "@media(max-width:760px)\{.lmn-hero-inner\{grid-template-columns:1fr\}\}" +
        ".lmn-nav\{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 1.25rem;height:64px;background:var(--lumen-bg);border-bottom:1px solid var(--lumen-border)\}" +
        ".lmn-footer\{padding:3rem 1.25rem;border-top:1px solid var(--lumen-border);color:var(--lumen-muted);text-align:center\}" +
        ".lmn-split\{display:grid;grid-template-columns:var(--lumen-split-ratio,1fr 1fr);gap:var(--lumen-split-gap,2rem);align-items:start\}@media(max-width:760px)\{.lmn-split\{grid-template-columns:1fr\}\}" +
        ".lmn-field\{display:flex;flex-direction:column;gap:.35rem\}" +
        ".lmn-field-label\{font-size:.875rem;font-weight:600\}" +
        ".lmn-field-hint\{font-size:.78rem;color:var(--lumen-muted)\}" +
        ".lmn-field-error\{font-size:.78rem;color:var(--lumen-danger)\}" +
        ".lmn-stat\{display:flex;flex-direction:column;gap:.25rem\}" +
        ".lmn-stat-value\{font-size:2.25rem;font-weight:800;letter-spacing:-.02em;line-height:1.1;margin:0\}" +
        ".lmn-stat-label\{font-size:.875rem;color:var(--lumen-muted);margin:0\}" +
        ".lmn-tag\{display:inline-flex;align-items:center;gap:.3rem;font-size:.72rem;font-weight:600;padding:.15rem .5rem;border-radius:6px;background:var(--lumen-surface-2);color:var(--lumen-muted);border:1px solid var(--lumen-border)\}" +
        ".lmn-tag[data-tone=success]\{color:#0b7a52;background:rgba(77,212,172,.16);border-color:transparent\}" +
        ".lmn-tag[data-tone=danger]\{color:#b42318;background:rgba(255,107,107,.16);border-color:transparent\}" +
        ".lmn-tag[data-tone=info]\{color:#1d4ed8;background:rgba(91,156,255,.16);border-color:transparent\}" +
        ".lmn-tag[data-tone=primary]\{color:var(--lumen-primary-fg);background:var(--lumen-primary);border-color:transparent\}" +
        ".lmn-avatar\{display:inline-flex;align-items:center;justify-content:center;border-radius:999px;overflow:hidden;flex-shrink:0;background:var(--lumen-surface-2);color:var(--lumen-muted);font-weight:600\}.lmn-avatar img\{width:100%;height:100%;object-fit:cover\}" +
        ".lmn-alert\{display:flex;gap:.75rem;padding:1rem;border-radius:var(--lumen-radius);align-items:flex-start\}" +
        ".lmn-alert[data-tone=default]\{background:var(--lumen-surface-2);color:var(--lumen-fg);border:1px solid var(--lumen-border)\}" +
        ".lmn-alert[data-tone=success]\{background:var(--lumen-success-bg);color:#0b7a52\}" +
        ".lmn-alert[data-tone=danger]\{background:var(--lumen-danger-bg);color:#b42318\}" +
        ".lmn-alert[data-tone=info]\{background:var(--lumen-info-bg);color:#1d4ed8\}" +
        ".lmn-alert[data-tone=primary]\{background:rgba(245,184,41,.14);color:var(--lumen-primary-fg)\}" +
        ".lmn-alert-icon\{flex-shrink:0;margin-top:2px\}.lmn-alert-body\{flex:1\}.lmn-alert-title\{font-weight:700;margin:0 0 .25rem\}" +
        ".lmn-empty\{display:flex;flex-direction:column;align-items:center;gap:.75rem;padding:3rem 1.25rem;text-align:center\}" +
        ".lmn-empty-icon\{opacity:.4\}.lmn-empty-title\{font-size:1.25rem;font-weight:700;margin:0\}" +
        ".lmn-skel\{background:var(--lumen-surface-2);border-radius:var(--lumen-radius);animation:lumen-shimmer 1.5s ease-in-out infinite\}" +
        "@keyframes lumen-shimmer\{0%\{opacity:.6\}50%\{opacity:1\}100%\{opacity:.6\}\}" +
        ".lmn-chat\{display:flex;flex-direction:column;height:var(--lumen-chat-h,400px);overflow-y:auto;padding:1rem;gap:.5rem;scroll-behavior:smooth\}" +
        ".lmn-chat-msg\{max-width:80%;padding:.75rem 1rem;border-radius:var(--lumen-radius);line-height:1.5;font-size:.9rem;word-wrap:break-word\}" +
        ".lmn-chat-msg[data-role=user]\{align-self:flex-end;background:var(--lumen-primary);color:var(--lumen-primary-fg);border-bottom-right-radius:4px\}" +
        ".lmn-chat-msg[data-role=assistant]\{align-self:flex-start;background:var(--lumen-surface-2);color:var(--lumen-fg);border-bottom-left-radius:4px\}" +
        ".lmn-chat-msg-name\{font-size:.72rem;font-weight:600;margin-bottom:2px;opacity:.7\}" +
        ".lmn-chat-input\{display:flex;gap:.5rem;padding:.75rem;border-top:1px solid var(--lumen-border);background:var(--lumen-surface)\}" +
        ".lmn-chat-input input\{flex:1;padding:.6rem .9rem;border:1px solid var(--lumen-border);border-radius:10px;font:inherit;font-size:.9rem;background:var(--lumen-bg);color:var(--lumen-fg);outline:none\}" +
        ".lmn-chat-input input:focus\{border-color:var(--lumen-primary)\}" +
        ".lmn-chat-input button\{padding:.6rem 1rem;border-radius:10px;border:none;background:var(--lumen-primary);color:var(--lumen-primary-fg);font-weight:600;cursor:pointer;font-size:.9rem\}" +
        ".lmn-chat-input button:hover\{background:var(--lumen-primary-hover)\}" +
        ".lmn-typing\{display:flex;gap:4px;align-items:center;padding:.75rem 1rem;align-self:flex-start;background:var(--lumen-surface-2);border-radius:var(--lumen-radius);border-bottom-left-radius:4px\}" +
        ".lmn-typing-dot\{width:8px;height:8px;border-radius:50%;background:var(--lumen-muted);animation:lumen-typing-bounce 1.2s ease-in-out infinite\}" +
        ".lmn-typing-dot:nth-child(2)\{animation-delay:.2s\}.lmn-typing-dot:nth-child(3)\{animation-delay:.4s\}" +
        "@keyframes lumen-typing-bounce\{0%,60%,100%\{transform:translateY(0)\}30%\{transform:translateY(-6px)\}\}\}" +
        ".lmn-table-wrap\{width:100%;overflow-x:auto;border:1px solid var(--lumen-border);border-radius:var(--lumen-radius);background:var(--lumen-surface)\}" +
        ".lmn-table\{width:100%;border-collapse:collapse;font-size:.9rem\}" +
        ".lmn-table thead\{background:var(--lumen-surface-2)\}" +
        ".lmn-th\{text-align:left;padding:0;border-bottom:1px solid var(--lumen-border);font-weight:700;color:var(--lumen-muted);font-size:.78rem;text-transform:uppercase;letter-spacing:.04em;padding:.6rem .9rem\}" +
        ".lmn-th-btn\{all:unset;cursor:pointer;display:inline-flex;align-items:center;gap:.25rem;font:inherit;color:inherit;text-transform:inherit;letter-spacing:inherit\}.lmn-th-btn:hover\{color:var(--lumen-primary)\}" +
        ".lmn-td\{padding:.6rem .9rem;border-bottom:1px solid var(--lumen-border);color:var(--lumen-fg)\}.lmn-table tbody tr:last-child .lmn-td\{border-bottom:0\}.lmn-table tbody tr:hover\{background:var(--lumen-surface-2)\}" +
        ".lmn-td-msg\{text-align:center;color:var(--lumen-muted);padding:1.5rem\}" +
        ".lmn-pager\{display:flex;align-items:center;gap:.75rem;justify-content:flex-end;padding:.75rem .9rem;border-top:1px solid var(--lumen-border)\}" +
        ".lmn-pager-info\{color:var(--lumen-muted);font-size:.82rem\}" +
        ".lmn-pager-btn\{font:inherit;font-size:.82rem;font-weight:600;padding:.35rem .8rem;border-radius:8px;border:1px solid var(--lumen-border);background:transparent;color:var(--lumen-fg);cursor:pointer\}.lmn-pager-btn:hover\{border-color:var(--lumen-primary);color:var(--lumen-primary)\}" +
        ".lmn-vtable\{position:relative\}.lmn-vtable thead th\{position:sticky;top:0;z-index:2;background:var(--lumen-surface-2)\}" +
        ".lmn-vspace td\{padding:0;border:0\}" +
        ".lmn-form\{display:flex;flex-direction:column;gap:1.1rem\}" +
        ".lmn-input\{width:100%;box-sizing:border-box;font:inherit;font-size:.9rem;padding:.6rem .8rem;border:1px solid var(--lumen-border);border-radius:10px;background:var(--lumen-bg);color:var(--lumen-fg);outline:none;transition:border-color .15s ease\}.lmn-input:focus\{border-color:var(--lumen-primary)\}" +
        "textarea.lmn-input\{min-height:96px;resize:vertical\}" +
        ".lmn-form-actions\{display:flex;align-items:center;gap:.9rem\}" +
        ".lmn-form-msg\{margin:0;font-size:.85rem;font-weight:600\}.lmn-form-msg[data-tone=success]\{color:#0b7a52\}.lmn-form-msg[data-tone=danger]\{color:#b42318\}" +
        "</style>"
}

// ── Built-in render functions ──

fn _ui_render_page(s) {
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return _lumen_design_css() + "<div class=\"lmn-app\"" + st + ">" + _ui_slot(s) + "</div>"
}

fn _ui_render_container(s) {
    let size = _ui_prop(s, "size", "lg")
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-container\" data-size=\"" + size + "\"" + st + ">" + _ui_slot(s) + "</div>"
}

fn _ui_render_section(s) {
    let border = "false"
    if _ui_flag(s, "border") { border = "true" }
    let id = _validate.get_field(s, "anchor")
    let id_attr = ""
    if id != null { id_attr = " id=\"" + id + "\"" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<section class=\"lmn-section\" data-border=\"" + border + "\"" + id_attr + st + ">" + _ui_slot(s) + "</section>"
}

fn _ui_render_stack(s) {
    let gap = _ui_space(_ui_prop(s, "gap", "4"))
    let align = _ui_prop(s, "align", "stretch")
    return "<div class=\"lmn-stack\" style=\"gap:" + gap + ";align-items:" + align + ";" + _ui_style_props(s) + "\">" + _ui_slot(s) + "</div>"
}

fn _ui_render_row(s) {
    let gap = _ui_space(_ui_prop(s, "gap", "4"))
    let justify = _ui_prop(s, "justify", "flex-start")
    let align = _ui_prop(s, "align", "center")
    let wrap = "false"
    if _ui_flag(s, "wrap") { wrap = "true" }
    return "<div class=\"lmn-row\" data-wrap=\"" + wrap + "\" style=\"gap:" + gap + ";justify-content:" + justify + ";align-items:" + align + ";" + _ui_style_props(s) + "\">" + _ui_slot(s) + "</div>"
}

fn _ui_render_grid(s) {
    let gap = _ui_space(_ui_prop(s, "gap", "6"))
    let cols = _ui_prop(s, "cols", "3")
    return "<div class=\"lmn-grid\" style=\"--lumen-cols:" + cols + ";gap:" + gap + ";" + _ui_style_props(s) + "\">" + _ui_slot(s) + "</div>"
}

fn _ui_render_card(s) {
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-card\"" + st + ">" + _ui_slot(s) + "</div>"
}

fn _ui_render_heading(s) {
    let size = _ui_prop(s, "size", "3xl")
    let tag = _ui_prop(s, "as", "h2")
    return "<" + tag + " class=\"lmn-h\" style=\"font-size:" + _ui_font(size) + ";" + _ui_style_props(s) + "\">" + _ui_slot(s) + "</" + tag + ">"
}

fn _ui_render_text(s) {
    let size = _ui_prop(s, "size", "base")
    let muted = "false"
    if _ui_flag(s, "muted") { muted = "true" }
    return "<p class=\"lmn-text\" data-muted=\"" + muted + "\" style=\"font-size:" + _ui_font(size) + ";" + _ui_style_props(s) + "\">" + _ui_slot(s) + "</p>"
}

fn _ui_render_eyebrow(s) {
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<p class=\"lmn-eyebrow\"" + st + ">" + _ui_slot(s) + "</p>"
}

fn _ui_render_button(s) {
    let variant = _ui_prop(s, "variant", "primary")
    let href = _validate.get_field(s, "href")
    let on = _validate.get_field(s, "on")
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    if href != null {
        return "<a class=\"lmn-btn\" data-variant=\"" + variant + "\" href=\"" + _sanitize.escape_html(href) + "\"" + st + ">" + _ui_slot(s) + "</a>"
    }
    let click = ""
    if on != null { click = " @click=\"" + on + "\"" }
    return "<button class=\"lmn-btn\" data-variant=\"" + variant + "\"" + click + st + ">" + _ui_slot(s) + "</button>"
}

fn _ui_render_badge(s) {
    let tone = _ui_prop(s, "tone", "default")
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<span class=\"lmn-badge\" data-tone=\"" + tone + "\"" + st + ">" + _ui_slot(s) + "</span>"
}

fn _ui_render_feature(s) {
    let icon = _ui_prop(s, "icon", "")
    let title = _sanitize.escape_html(_ui_prop(s, "title", ""))
    let ico = ""
    if icon != "" { ico = "<div class=\"lmn-ico\">" + lumen_icon(icon) + "</div>" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-feature\"" + st + ">" + ico +
           "<h3 class=\"lmn-h\" style=\"font-size:1.25rem\">" + title + "</h3>" +
           "<p class=\"lmn-text\" data-muted=\"true\">" + _ui_slot(s) + "</p></div>"
}

fn _ui_render_divider(s) {
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<hr class=\"lmn-divider\"" + st + ">"
}

fn _ui_render_spacer(s) {
    let size = _ui_space(_ui_prop(s, "size", "8"))
    return "<div style=\"height:" + size + ";" + _ui_style_props(s) + "\"></div>"
}

// ── Section components (Part A of Lumen vocab spec) ──

fn _ui_render_hero(s) {
    let eyebrow = _validate.get_field(s, "eyebrow")
    let title = _validate.get_field(s, "title")
    let subtitle = _validate.get_field(s, "subtitle")
    let image = _validate.get_field(s, "image")
    let align = _ui_prop(s, "align", "left")
    let e_html = ""
    if eyebrow != null { e_html = "<p class=\"lmn-eyebrow\">" + _sanitize.escape_html("" + eyebrow) + "</p>" }
    let t_html = ""
    if title != null { t_html = "<h1 class=\"lmn-hero-title\">" + _sanitize.escape_html("" + title) + "</h1>" }
    let s_html = ""
    if subtitle != null { s_html = "<p class=\"lmn-hero-subtitle\">" + _sanitize.escape_html("" + subtitle) + "</p>" }
    let img_html = ""
    if image != null {
        img_html = "<div class=\"lmn-hero-img-wrap\"><img class=\"lmn-hero-img\" src=\"" + _sanitize.escape_html("" + image) + "\" alt=\"\"></div>"
    }
    let align_class = ""
    if align == "center" { align_class = " lmn-hero-center" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<section class=\"lmn-hero" + align_class + "\"" + st + "><div class=\"lmn-hero-inner\"><div class=\"lmn-hero-content\">" + e_html + t_html + s_html + _ui_slot(s) + "</div>" + img_html + "</div></section>"
}

fn _ui_render_nav(s) {
    let brand = _sanitize.escape_html(_ui_prop(s, "brand", ""))
    let brand_html = ""
    if brand != "" { brand_html = "<div class=\"lmn-nav-brand\">" + brand + "</div>" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<nav class=\"lmn-nav\"" + st + ">" + brand_html + _ui_slot(s) + "</nav>"
}

fn _ui_render_footer(s) {
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<footer class=\"lmn-footer\"" + st + ">" + _ui_slot(s) + "</footer>"
}

fn _ui_render_split(s) {
    let ratio = _ui_prop(s, "ratio", "1fr 1fr")
    let gap = _ui_space(_ui_prop(s, "gap", "8"))
    let reverse = _ui_flag(s, "reverse")
    let rev_class = ""
    if reverse { rev_class = " lmn-split-reverse" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-split" + rev_class + "\" style=\"--lumen-split-ratio:" + ratio + ";--lumen-split-gap:" + gap + "\"" + st + ">" + _ui_slot(s) + "</div>"
}

fn _ui_render_field(s) {
    let label = _validate.get_field(s, "label")
    let hint = _validate.get_field(s, "hint")
    let error = _validate.get_field(s, "error")
    let label_html = ""
    if label != null { label_html = "<label class=\"lmn-field-label\">" + _sanitize.escape_html("" + label) + "</label>" }
    let hint_html = ""
    if hint != null { hint_html = "<p class=\"lmn-field-hint\">" + _sanitize.escape_html("" + hint) + "</p>" }
    let error_html = ""
    if error != null { error_html = "<p class=\"lmn-field-error\">" + _sanitize.escape_html("" + error) + "</p>" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-field\"" + st + ">" + label_html + _ui_slot(s) + hint_html + error_html + "</div>"
}

fn _ui_render_stat(s) {
    let value = _sanitize.escape_html(_ui_prop(s, "value", ""))
    let label = _sanitize.escape_html(_ui_prop(s, "label", ""))
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-stat\"" + st + "><p class=\"lmn-stat-value\">" + value + "</p><p class=\"lmn-stat-label\">" + label + "</p></div>"
}

fn _ui_render_tag(s) {
    let tone = _ui_prop(s, "tone", "default")
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<span class=\"lmn-tag\" data-tone=\"" + tone + "\"" + st + ">" + _ui_slot(s) + "</span>"
}

fn _ui_render_avatar(s) {
    let src = _validate.get_field(s, "src")
    let alt = _sanitize.escape_html(_ui_prop(s, "alt", ""))
    let sz = _ui_prop(s, "size", "40")
    let sz_px = sz
    // If it's a known space key, resolve it; otherwise use the literal value + "px"
    let space_val = _ui_space(sz)
    if space_val != "1rem" or sz == "4" {
        sz_px = space_val
    } else {
        // check if it's a plain number -> px
        let n = 0
        let is_num = true
        let sc = sz.code_at(0)
        if sc >= 48 and sc <= 57 {
            sz_px = sz + "px"
        }
    }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    if src != null {
        return "<div class=\"lmn-avatar\" style=\"width:" + sz_px + ";height:" + sz_px + "\"" + st + "><img src=\"" + _sanitize.escape_html("" + src) + "\" alt=\"" + alt + "\"></div>"
    }
    return "<div class=\"lmn-avatar\" style=\"width:" + sz_px + ";height:" + sz_px + "\"" + st + ">" + _ui_slot(s) + "</div>"
}

fn _ui_render_alert(s) {
    let tone = _ui_prop(s, "tone", "default")
    let title = _validate.get_field(s, "title")
    let icon = _ui_prop(s, "icon", "zap")
    let icon_html = "<div class=\"lmn-alert-icon\">" + lumen_icon(icon) + "</div>"
    let title_html = ""
    if title != null { title_html = "<p class=\"lmn-alert-title\">" + _sanitize.escape_html("" + title) + "</p>" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-alert\" data-tone=\"" + tone + "\"" + st + ">" + icon_html + "<div class=\"lmn-alert-body\">" + title_html + _ui_slot(s) + "</div></div>"
}

fn _ui_render_empty(s) {
    let icon = _ui_prop(s, "icon", "box")
    let title = _validate.get_field(s, "title")
    let icon_html = "<div class=\"lmn-empty-icon\">" + lumen_icon(icon) + "</div>"
    let title_html = ""
    if title != null { title_html = "<p class=\"lmn-empty-title\">" + _sanitize.escape_html("" + title) + "</p>" }
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = " style=\"" + sp + "\"" }
    return "<div class=\"lmn-empty\"" + st + ">" + icon_html + title_html + _ui_slot(s) + "</div>"
}

fn _ui_render_skeleton(s) {
    let w = _ui_prop(s, "w", "100%")
    let h = _ui_prop(s, "h", "1rem")
    let radius = _ui_prop(s, "radius", "md")
    let rv = _ui_radius(radius)
    let sp = _ui_style_props(s)
    let st = ""
    if sp != "" { st = ";" + sp }
    return "<div class=\"lmn-skel\" style=\"width:" + w + ";height:" + h + ";border-radius:" + rv + st + "\"></div>"
}

