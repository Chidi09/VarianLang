lumen_register_component("Heading", _ui_component(_ui_render_heading))
lumen_register_component("Text", _ui_component(_ui_render_text))
lumen_register_component("Eyebrow", _ui_component(_ui_render_eyebrow))
lumen_register_component("Button", _ui_component(_ui_render_button))
lumen_register_component("Badge", _ui_component(_ui_render_badge))
lumen_register_component("Feature", _ui_component(_ui_render_feature))
lumen_register_component("Divider", _ui_component(_ui_render_divider))
lumen_register_component("Spacer", _ui_component(_ui_render_spacer))
lumen_register_component("Hero", _ui_component(_ui_render_hero))
lumen_register_component("Nav", _ui_component(_ui_render_nav))
lumen_register_component("Footer", _ui_component(_ui_render_footer))
lumen_register_component("Split", _ui_component(_ui_render_split))
lumen_register_component("Field", _ui_component(_ui_render_field))
lumen_register_component("Stat", _ui_component(_ui_render_stat))
lumen_register_component("Tag", _ui_component(_ui_render_tag))
lumen_register_component("Avatar", _ui_component(_ui_render_avatar))
lumen_register_component("Alert", _ui_component(_ui_render_alert))
lumen_register_component("Empty", _ui_component(_ui_render_empty))
lumen_register_component("Skeleton", _ui_component(_ui_render_skeleton))
lumen_register_component("Chat", _ui_component(_ui_render_chat))
lumen_register_component("ChatMessage", _ui_component(_ui_render_chat_message))
lumen_register_component("ChatInput", _ui_component(_ui_render_chat_input))
lumen_register_component("TypingIndicator", _ui_component(_ui_render_typing_indicator))

// Wrap the rendered component in the live shell (data-lumen-root + client).
// Injects SEO metadata, Lumen head defaults, data-lumen-root, and the client
// script into the page's own document structure so the browser sees a single
// valid HTML document with proper <head> and <body>.
// `manifest` is an optional array of LumenJS module names to include.
fn _lumen_shell(inner, ws_path, manifest) {
    let body_start = inner.index_of("<body")
    let body_end = inner.index_of("</body>")
    let head_end = inner.index_of("</head>")
    let meta_tags = _lumen_meta_tags()
    let _dev_inject = _lumen_dev_inject(manifest)

    if body_start == -1 or body_end == -1 {
        // Fragment — wrap in full document.
        let head_html = _lumen_head()
        if meta_tags != "" { head_html = head_html + meta_tags }
        let client_js = _lumen_client_js_with_manifest(manifest)
        return "<!DOCTYPE html><html lang=\"en\"><head>" + head_html + "</head><body>" +
               "<div data-lumen-root>" + inner + "</div>" +
               "<script>window.__LUMEN_WS__=\"" + ws_path + "\";" + client_js + _dev_inject + "</script>" +
               "</body></html>"
    }

    // Full document — inject into existing <head> and <body>.
    // 1. Inject meta tags + Lumen defaults before </head>
    let head_close = head_end
    if head_close < 0 { head_close = body_start }
    let head_prefix = inner.substring(0, head_close)
    let after_head  = inner.substring(head_close)

    // 2. Inject <div data-lumen-root> and client JS into <body>
    let rel_body_open = body_start - head_close
    let rel_body_tag_close = inner.index_of(">", body_start) - head_close + 1
    let rel_body_end = body_end - head_close

    let body_before = after_head.substring(rel_body_open, rel_body_tag_close)
    let body_content = after_head.substring(rel_body_tag_close, rel_body_end)
    let body_after  = after_head.substring(rel_body_end)

    let client_js = _lumen_client_js_with_manifest(manifest)
    return head_prefix + meta_tags + _lumen_head() + "</head>" +
           body_before +
           "<div data-lumen-root>" + body_content + "</div>" +
           "<script>window.__LUMEN_WS__=\"" + ws_path + "\";" + client_js + _dev_inject + "</script>" +
           body_after
}

// ─── LumenJS modules catalog ───
// Each module registers itself against one or more data-lumen-* attributes.
// Modules are opt-in: only emitted if the page statically references the attribute.
// Every brace is escaped as \{/\} for Varian string interpolation.

fn _lumen_module(name) {
    if name == "clipboard" {
        return "document.addEventListener('click',function(e)\{var el=e.target.closest&&e.target.closest('[data-lumen-copy]');if(!el)return;var t=el.getAttribute('data-lumen-copy'),c;if(t==='text'||t==='')c=el.textContent;else c=document.querySelector(t)&&document.querySelector(t).value||'';navigator.clipboard&&navigator.clipboard.writeText(c).catch(function()\{\})\})"
    }
    if name == "focus" {
        return "var F=function()\{document.querySelectorAll('[data-lumen-focus]').forEach(function(el)\{el.focus()\})\};if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',F);else F()"
    }
    if name == "scroll" {
        return "document.addEventListener('click',function(e)\{var el=e.target.closest&&e.target.closest('[data-lumen-scroll]');if(!el)return;var t=el.getAttribute('data-lumen-scroll');if(t==='into-view')el.scrollIntoView(\{behavior:'smooth',block:'center'\});if(t==='lock')\{document.body.style.overflow='hidden';el.addEventListener('lumen-close',function()\{document.body.style.overflow=''\})\};if(t==='restore')\{var k='lumen-scroll-'+location.pathname;var y=sessionStorage.getItem(k);if(y)window.scrollTo(0,parseInt(y));window.addEventListener('scroll',function()\{sessionStorage.setItem(k,window.scrollY)\})\}\})"
    }
    if name == "toast" {
        return "window.__lumen_toast=function(m,t)\{var o=document.createElement('div');o.style.cssText='position:fixed;bottom:24px;right:24px;z-index:9999;padding:12px 20px;border-radius:10px;background:#1b2233;color:#e8eaf0;box-shadow:0 8px 30px rgba(0,0,0,.3);font-size:14px;max-width:400px;border-left:4px solid '+(t==='error'?'#ff6b6b':t==='success'?'#4dd4ac':'#f5b829');o.textContent=m;document.body.appendChild(o);setTimeout(function()\{o.style.opacity='0';o.style.transition='opacity .3s';setTimeout(function()\{o.remove()\},300)\},(t==='error'?6:3)*1e3)\}"
    }
    if name == "key" {
        return "document.addEventListener('keydown',function(e)\{var el=document.querySelector('[data-lumen-key]');if(!el)return;var map=el.getAttribute('data-lumen-key');var pairs=map.split(',');for(var i=0;i<pairs.length;i++)\{var kv=pairs[i].trim().split(':');if(kv.length!==2)continue;var k=kv[0].trim(),h=kv[1].trim();if((e.key||e.code)===k)\{var msg=JSON.stringify(\{t:'event',h:h,v:null\});if(window.__lumen_ws&&window.__lumen_ws.readyState===1)window.__lumen_ws.send(msg)\}\}\})"
    }
    return ""
}

// Scan a template string for directive attributes and return a list of required LumenJS module names.
// Looks for data-lumen-* attributes that map to known modules, data-lumen-hook=X, and event modifiers.
fn _lumen_scan_directives(tpl) {
    let mods = []
    // Single source of truth: directive attribute -> module name, index-aligned.
    // Every name here MUST be implemented in _lumen_module(); keep the two lists
    // in lock-step (a name with no module would ship a dead directive, and an
    // unscanned attr would silently never load its module). data-lumen-mod
    // (debounce/throttle/key modifiers) is handled by core, so it has no module.
    let attrs = ["data-lumen-copy", "data-lumen-focus", "data-lumen-scroll",
                 "data-lumen-toast", "data-lumen-key"]
    let names = ["clipboard", "focus", "scroll", "toast", "key"]
    for i in 0..attrs.len() {
        if tpl.index_of(attrs[i]) >= 0 {
            if _lumen_list_has(mods, names[i]) == false {
                mods = mods.push(names[i])
            }
        }
    }
    return mods
}

// ─── LumenJS client runtime ───
//
// Core transport + DOM morph + error overlay. Always shipped.
// Modules (clipboard, focus, scroll, …) are appended by _lumen_shell
// based on the page's static directive manifest.
//
// Every brace is escaped as \{/\} so Varian's {expr} interpolation doesn't eat it.

// Core runtime — always included.
