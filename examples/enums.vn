// Enum destructuring test
enum Option {
    Some(int),
    None
}

let a = Option::Some(42)
let b = Option::None

// Literal comparison (existing)
match a {
    Option::Some(42) => print(1),
    Option::None => print(2)
}

// Destructuring with binding
match a {
    Option::Some(val) => print(val),
    Option::None => print(99)
}

match b {
    Option::Some(val) => print(val),
    Option::None => print(3)
}
