// 1. Offset Pagination Test
let q1 = select("users")
    .fields(["id", "name"])
    .where("status", "=")
    .paginate(2, 10)
    .build()

print("Offset Pagination (SQLite):")
print("SQL:", q1.sql)
print("Param count:", q1.param_count)
let b1 = bind(q1, ["active"])
print("Params:", b1.params)

// 2. Cursor/Seek Pagination (Postgres Dialect) Test
let q2 = select("posts")
    .use_dialect("postgres")
    .where("category", "=")
    .cursor_paginate("id", true, 5)
    .build()

print("Cursor Pagination (Postgres):")
print("SQL:", q2.sql)
let b2 = bind(q2, ["tech", 100])
print("Params:", b2.params)

// 3. Key-based Access Test
let q3 = select("users")
    .find_by_key("email")
    .build()

print("Key-based Access:")
print("SQL:", q3.sql)
let b3 = bind(q3, ["admin@example.com"])
print("Params:", b3.params)
