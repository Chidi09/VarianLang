{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lumen",
  "scopeName": "source.lumen",
  "patterns": [
    { "include": "#template" },
    { "include": "#interpolation" },
    { "include": "source.varian" }
  ],
  "repository": {
    "template": {
      "patterns": [
        {
          "name": "meta.tag.structure.lumen",
          "begin": "(<)(/?)(template|script|style)(?=[\\s>])",
          "end": "(</)(template|script|style)(>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.lumen" },
            "2": { "name": "punctuation.definition.tag.begin.lumen" },
            "3": { "name": "entity.name.tag.lumen" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.lumen" },
            "2": { "name": "entity.name.tag.lumen" },
            "3": { "name": "punctuation.definition.tag.end.lumen" }
          },
          "patterns": [
            { "include": "#tag-attributes" }
          ]
        },
        {
          "name": "meta.tag.other.lumen",
          "begin": "(</?)([a-zA-Z][a-zA-Z0-9_-]*)(?=[\\s>/])",
          "end": "(/?>)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.lumen" },
            "2": { "name": "entity.name.tag.lumen" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.lumen" }
          },
          "patterns": [
            { "include": "#tag-attributes" }
          ]
        }
      ]
    },
    "tag-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.event.lumen",
          "match": "(@[a-zA-Z_][a-zA-Z0-9_-]*)\\s*(=)\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.event.lumen" },
            "2": { "name": "punctuation.separator.key-value.lumen" },
            "3": { "name": "string.quoted.double.lumen" }
          }
        },
        {
          "name": "entity.other.attribute-name.bind.lumen",
          "match": "(\\:[a-zA-Z_][a-zA-Z0-9_-]*)\\s*(=)\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.bind.lumen" },
            "2": { "name": "punctuation.separator.key-value.lumen" },
            "3": { "name": "string.quoted.double.lumen" }
          }
        },
        {
          "name": "entity.other.attribute-name.lumen",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\s*(=)\\s*(\"[^\"]*\")",
          "captures": {
            "1": { "name": "entity.other.attribute-name.lumen" },
            "2": { "name": "punctuation.separator.key-value.lumen" },
            "3": { "name": "string.quoted.double.lumen" }
          }
        }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.lumen",
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.interpolation.begin.lumen" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.lumen" }
      },
      "patterns": [
        { "include": "source.varian" }
      ]
    }
  }
}
