{
    "name": "varian",
    "displayName": "Varian Language Support",
    "description": "Syntax highlighting, LSP (diagnostics, hover, completion, go-to-definition, formatting) for Varian, Zenith, and Lumen.",
    "version": "0.1.0",
    "publisher": "varianlang",
    "license": "MIT",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/Chidi09/VarianLang.git",
        "directory": "editors/vscode"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Formatters"
    ],
    "keywords": [
        "varian",
        "zenith",
        "lumen",
        "aurora"
    ],
    "activationEvents": [
        "onLanguage:varian",
        "onLanguage:lumen"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "varian",
                "aliases": [
                    "Varian",
                    "varian"
                ],
                "extensions": [
                    ".vn",
                    ".vhtml"
                ],
                "icon": {
                    "light": "./icons/varian-light.svg",
                    "dark": "./icons/varian-dark.svg"
                },
                "configuration": "./language-configuration.json"
            },
            {
                "id": "lumen",
                "aliases": [
                    "Lumen",
                    "lumen"
                ],
                "extensions": [
                    ".lumen"
                ],
                "icon": {
                    "light": "./icons/lumen-light.svg",
                    "dark": "./icons/lumen-dark.svg"
                },
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "varian",
                "scopeName": "source.varian",
                "path": "./syntaxes/varian.tmLanguage.json"
            },
            {
                "language": "lumen",
                "scopeName": "source.lumen",
                "path": "./syntaxes/lumen.tmLanguage.json"
            },
            {
                "language": "lumen",
                "scopeName": "source.varian",
                "path": "./syntaxes/varian.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Varian",
            "properties": {
                "varian.path": {
                    "type": "string",
                    "default": "vn",
                    "description": "Path to the Varian executable (e.g. /path/to/vn or vn if in PATH)"
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^8.1.0"
    }
}
