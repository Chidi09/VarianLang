<style>
.theme-toggle {
  background: transparent;
  border: 1px solid var(--lumen-border);
  border-radius: 8px;
  cursor: pointer;
  color: var(--lumen-fg);
  padding: 8px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}
.theme-toggle:hover {
  background: var(--lumen-muted);
}
html.dark .light-icon {
  display: none;
}
html:not(.dark) .dark-icon {
