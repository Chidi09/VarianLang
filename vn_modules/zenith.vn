// zenith.vn - Zenith web framework
//
// - ZenithApp is a real instantiable struct: route tables, middleware, and
//   docs settings live per-instance instead of in shared module globals, so
//   you can build several independent apps in the same program.
// - Routing is a segment trie (radix-style router): each request walks one
//   node per path segment (O(depth)) instead of scanning every registered
//   route (O(routes)). The HTTP method is folded in as the trie's first
//   segment, so one tree handles all methods.
// - The OpenAPI document is built as real structs/arrays and serialized
//   once via json_encode, instead of hand-concatenated JSON strings.
// - listen() and the middleware "next" chain capture `self`/`app` directly
//   in real closures (value-copy upvalues) — no shared/global app slot.

struct Response { status: int, body: string, content_type: string, _keep_open: bool, headers }
struct Route { method: string, path: string, handler, summary: string, meta }
struct OpenApiInfo { title: string, version: string }
struct PathGroup { path_key: string, methods: array, ops: array }

fn _get_req_field(req, field, default_val) {
    let result = default_val
    try {
        let keys = _validate.get_keys(req)
        for i in 0..keys.len() {
            if keys[i] == field {
                result = _validate.get_field(req, field)
            }
        }
    } catch e {}
    return result
}

struct WebSocket {
    socket_fd: int,
    _buffer: string
}

impl WebSocket {
    fn read(self) {
        let incoming = http.read_socket(self.socket_fd, 4096)
        if incoming != null {
            self._buffer = self._buffer + incoming
        }

        if self._buffer.len() == 0 {
            if incoming == null {
                return null
            }
            return ""
        }

        if self._buffer.len() < 2 {
            return ""
        }

        let first = self._buffer.code_at(0)
        let second = self._buffer.code_at(1)

        let fin = math.bit_and(first, 128) != 0
        let opcode = math.bit_and(first, 15)
        let masked = math.bit_and(second, 128) != 0
        let payload_len = math.bit_and(second, 127)

        let header_len = 2
        if payload_len == 126 {
            if self._buffer.len() < 4 {
                return ""
            }
            let b1 = self._buffer.code_at(2)
            let b2 = self._buffer.code_at(3)
            payload_len = math.bit_or(b1 * 256, b2)
            header_len = 4
        } else if payload_len == 127 {
            if self._buffer.len() < 10 {
                return ""
            }
            let b5 = self._buffer.code_at(6)
            let b6 = self._buffer.code_at(7)
            let b7 = self._buffer.code_at(8)
            let b8 = self._buffer.code_at(9)
            payload_len = math.bit_or(math.bit_or(math.bit_or(b5 * 16777216, b6 * 65536), b7 * 256), b8)
            header_len = 10
        }

        let mask_offset = header_len
        if masked {
            header_len = header_len + 4
        }

        if self._buffer.len() < header_len + payload_len {
            return ""
        }

        let mask = []
        if masked {
            mask = [
                self._buffer.code_at(mask_offset),
                self._buffer.code_at(mask_offset + 1),
                self._buffer.code_at(mask_offset + 2),
                self._buffer.code_at(mask_offset + 3)
            ]
        }

        let payload_offset = header_len
        let payload_codes = []
        for i in 0..payload_len {
            let code = self._buffer.code_at(payload_offset + i)
            if masked {
                code = math.bit_xor(code, mask[i % 4])
            }
            payload_codes = payload_codes.push(code)
        }

        let decoded = "".from_codes(payload_codes)
        self._buffer = self._buffer.substring(header_len + payload_len, self._buffer.len())

        if opcode == 8 {
            return null
        }

        return decoded
    }

    fn write(self, text) {
        let payload_len = text.len()
        let frame_codes = [129]

        if payload_len <= 125 {
            frame_codes = frame_codes.push(payload_len)
        } else if payload_len <= 65535 {
            frame_codes = frame_codes.push(126)
            frame_codes = frame_codes.push(math.bit_and(payload_len / 256, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len, 255))
        } else {
            frame_codes = frame_codes.push(127)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(0)
            frame_codes = frame_codes.push(math.bit_and(payload_len / 16777216, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len / 65536, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len / 256, 255))
            frame_codes = frame_codes.push(math.bit_and(payload_len, 255))
        }

        for i in 0..payload_len {
            frame_codes = frame_codes.push(text.code_at(i))
        }

        let frame = "".from_codes(frame_codes)
        http.write_socket(self.socket_fd, frame)
    }

    fn close(self) {
        let close_frame = "".from_codes([136, 0])
        try {
            http.write_socket(self.socket_fd, close_frame)
        } catch e {}
        http.close_socket(self.socket_fd)
    }
}

struct SseSender {
    socket_fd: int
}

impl SseSender {
    fn send(self, data) {
        let chunk = "data: " + data + "\n\n"
        http.write_socket(self.socket_fd, chunk)
    }

    fn close(self) {
        http.close_socket(self.socket_fd)
    }
}

// CAVEAT: Not TLS-aware — writes handshake directly to the raw socket FD via
// http.write_socket(), bypassing any TLS layer. wss:// is unsupported; deploy
// behind a reverse proxy (nginx/Caddy) that terminates TLS and speaks plain
// ws:// to Zenith. See listen_tls for the same caveat.
fn upgrade_websocket(req) {
    let headers = req.headers
    if headers == null {
        return null
    }
    let key = _get_req_field(headers, "sec_websocket_key", null)
    if key == null {
        return null
    }
    let accept_raw = key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
    let accept = auth.sha1_base64(accept_raw)

    let response = "HTTP/1.1 101 Switching Protocols\r\n" +
                   "Upgrade: websocket\r\n" +
                   "Connection: Upgrade\r\n" +
                   "Sec-WebSocket-Accept: " + accept + "\r\n\r\n"
    
    http.write_socket(req.socket_fd, response)
    
    return WebSocket {
        socket_fd: req.socket_fd,
        _buffer: ""
    }
}

// CAVEAT: Same TLS limitation as upgrade_websocket — writes to raw socket FD.
fn sse_handshake(req) {
    let response = "HTTP/1.1 200 OK\r\n" +
                   "Content-Type: text/event-stream\r\n" +
                   "Cache-Control: no-cache\r\n" +
                   "Connection: keep-alive\r\n\r\n"
    http.write_socket(req.socket_fd, response)
    return SseSender { socket_fd: req.socket_fd }
}

struct RadixNode {
    static_keys: array,
    static_children: array,
    param_name: string,
    param_child,
    handler,
    summary: string
}

fn new_radix_node() {
    return RadixNode {
        static_keys: [],
        static_children: [],
        param_name: "",
        param_child: null,
        handler: null,
        summary: ""
    }
}

fn _split_path(path) {
    let raw = path.split("/")
    let segs = []
    for i in 0..raw.len() {
        if raw[i] != "" {
            segs = segs.push(raw[i])
        }
    }
    return segs
}

fn radix_insert(root, route_key, handler, summary) {
    let segs = _split_path(route_key)
    let node = root
    for i in 0..segs.len() {
        let seg = segs[i]
        if seg.starts_with(":") {
            if node.param_child == null {
                node.param_child = new_radix_node()
            }
            node.param_child.param_name = seg.substring(1, seg.len())
            node = node.param_child
        } else {
            let found = null
            for j in 0..node.static_keys.len() {
                if node.static_keys[j] == seg {
                    found = node.static_children[j]
                    break
                }
            }
            if found == null {
                found = new_radix_node()
                node.static_keys = node.static_keys.push(seg)
                node.static_children = node.static_children.push(found)
            }
            node = found
        }
    }
    node.handler = handler
    node.summary = summary
}

fn radix_lookup(root, route_key) {
    let segs = _split_path(route_key)
    let node = root
    let param_names = []
    let param_values = []
    for i in 0..segs.len() {
        let seg = segs[i]
        let next = null
        for j in 0..node.static_keys.len() {
            if node.static_keys[j] == seg {
                next = node.static_children[j]
                break
            }
        }
        if next == null && node.param_child != null {
            next = node.param_child
            param_names = param_names.push(next.param_name)
            param_values = param_values.push(seg)
        }
        if next == null {
            return null
        }
        node = next
    }
    if node.handler == null {
        return null
    }
    return http.create_struct(
        ["handler", "summary", "param_names", "param_values"],
        [node.handler, node.summary, param_names, param_values]
    )
}

// ─── App ───

struct ZenithApp {
    root: RadixNode,
    middlewares: array,
    route_list: array,
    docs_enabled: bool,
    docs_endpoint: string,
    static_mounts: array,
    title: string,
    schema_names: array,
    schema_values: array,
    port: int,
    error_handler
}

fn new_app() {
    return ZenithApp {
        root: new_radix_node(),
        middlewares: [],
        route_list: [],
        docs_enabled: false,
        docs_endpoint: "/docs",
        static_mounts: [],
        title: "Zenith API",
        schema_names: [],
        schema_values: [],
        port: 8080,
        error_handler: null
    }
}

// ─── Static file serving ───

struct StaticMount { prefix: string, directory: string }

fn _ends_with(s, suffix) {
    let s_len = s.len()
    let suf_len = suffix.len()
    if suf_len > s_len {
        return false
    }
    return s.substring(s_len - suf_len, s_len) == suffix
}

fn _mime_type_for_path(path) {
    if _ends_with(path, ".html") { return "text/html" }
    if _ends_with(path, ".css") { return "text/css" }
    if _ends_with(path, ".js") { return "application/javascript" }
    if _ends_with(path, ".json") { return "application/json" }
    if _ends_with(path, ".png") { return "image/png" }
    if _ends_with(path, ".jpg") { return "image/jpeg" }
    if _ends_with(path, ".jpeg") { return "image/jpeg" }
    if _ends_with(path, ".gif") { return "image/gif" }
    if _ends_with(path, ".svg") { return "image/svg+xml" }
    if _ends_with(path, ".ico") { return "image/x-icon" }
    if _ends_with(path, ".txt") { return "text/plain" }
    if _ends_with(path, ".pdf") { return "application/pdf" }
    if _ends_with(path, ".woff") { return "font/woff" }
    if _ends_with(path, ".woff2") { return "font/woff2" }
    return "application/octet-stream"
}

// Rejects any ".." path segment -- the one thing that matters for static
// file serving, since mount.directory + "/" + rel_path is otherwise just a
// plain filesystem path. ".." anywhere lets a request escape the mounted
// directory (e.g. GET /static/../../../etc/passwd).
fn _is_safe_relative_path(rel_path) {
    let segments = rel_path.split("/")
    for i in 0..segments.len() {
        if segments[i] == ".." {
            return false
        }
    }
    return true
}

// Returns a handler closure if `path` matches a registered static mount
// (whether or not the file actually exists -- a missing file still 404s
// through the normal handler/middleware chain rather than silently falling
// through to routing), or null if no mount's prefix matches at all.
fn _static_handler_for(app, path) {
    for i in 0..app.static_mounts.len() {
        let mount = app.static_mounts[i]
        if path.starts_with(mount.prefix) {
            let rel = path.substring(mount.prefix.len(), path.len())
            if !_is_safe_relative_path(rel) {
                return | req | {
                    return Response { status: 403, body: "Forbidden", content_type: "text/plain" }
                }
            }
            let full_path = mount.directory + "/" + rel
            return | req | {
                let bytes = io.read_bytes(full_path)
                if bytes == null {
                    return Response { status: 404, body: "Not Found", content_type: "text/plain" }
                }
                return Response { status: 200, body: bytes, content_type: _mime_type_for_path(full_path) }
            }
        }
    }
    return null
}

impl ZenithApp {
    fn _add_route(self, method, path, handler, summary, meta) {
        radix_insert(self.root, method + path, handler, summary)
        self.route_list = self.route_list.push(
            Route { method: method, path: path, handler: handler, summary: summary, meta: meta }
        )
    }

    fn register_schema(self, name, model_instance) {
        self.schema_names = self.schema_names.push(name)
        self.schema_values = self.schema_values.push(model_instance)
    }

    fn get(self, path, handler, summary, meta) {
        self._add_route("GET", path, handler, summary, meta)
    }

    fn post(self, path, handler, summary, meta) {
        self._add_route("POST", path, handler, summary, meta)
    }

    fn put(self, path, handler, summary, meta) {
        self._add_route("PUT", path, handler, summary, meta)
    }

    fn delete(self, path, handler, summary, meta) {
        self._add_route("DELETE", path, handler, summary, meta)
    }

    fn patch(self, path, handler, summary, meta) {
        self._add_route("PATCH", path, handler, summary, meta)
    }

    fn options(self, path, handler, summary, meta) {
        self._add_route("OPTIONS", path, handler, summary, meta)
    }

    // HEAD is routed like GET but the response body is dropped by the client;
    // we register it as its own method so an app can answer HEAD explicitly.
    fn head(self, path, handler, summary, meta) {
        self._add_route("HEAD", path, handler, summary, meta)
    }

    fn add_middleware(self, handler) {
        self.middlewares = self.middlewares.push(handler)
    }

    // Serves files under `directory` for any GET request whose path starts
    // with `prefix`. Runs through the normal middleware chain like any
    // other route (so CORS/logging/auth middleware still applies to static
    // assets) -- it's just a fallback when no explicit route matches.
    fn serve_static(self, prefix, directory) {
        self.static_mounts = self.static_mounts.push(StaticMount { prefix: prefix, directory: directory })
    }

    fn enable_docs(self, endpoint) {
        self.docs_enabled = true
        self.docs_endpoint = endpoint
        self.get("/openapi.json", |req| {
            let base_url = "http://localhost:" + self.port
            let spec = build_openapi_spec(self, base_url)
            return Response { status: 200, body: spec, content_type: "application/json" }
        }, "OpenAPI 3.0 specification", null)
        self.get(endpoint, |req| {
            return _swagger_handler(self, req)
        }, "Swagger UI documentation", null)
    }

    fn on_error(self, handler) {
        self.error_handler = handler
        return self
    }

    // Synchronous request handling — usable directly in tests without a
    // running socket: app.handle(fake_req).
    fn handle(self, req) {
        let m = radix_lookup(self.root, req.method + req.path)
        let handler = null
        let params = null
        if m != null {
            handler = m.handler
            params = http.create_struct(m.param_names, m.param_values)
        } else if req.method == "GET" {
            handler = _static_handler_for(self, req.path)
        }
        let body = _get_req_field(req, "body", "")
        let json = _get_req_field(req, "json", null)
        let headers = _get_req_field(req, "headers", null)
        let ip = _get_req_field(req, "ip", "127.0.0.1")
        let socket_fd = _get_req_field(req, "socket_fd", -1)
        let query = _get_req_field(req, "query", "")

        let req2 = http.create_struct(
            ["method", "path", "query", "body", "json", "params", "_middleware_idx", "_route_handler", "headers", "ip", "socket_fd"],
            [req.method, req.path, query, body, json, params, 0, handler, headers, ip, socket_fd]
        )
        try {
            return _run_middleware(self, req2)
        } catch e {
            print("CRASHED:", e)
            let info = errors.make(errors.kind(e), "" + e, "")
            if self.error_handler != null {
                return self.error_handler(info, req)
            }
            // default: clean JSON 500, never leak internals to the client
            return http.create_struct(
                ["status", "body", "content_type"],
                [500, json_encode({ error: "Internal Server Error", kind: info.kind }), "application/json"]
            )
        }
    }

    fn listen(self, port) {
        self.port = port
        print("Zenith running on http://localhost:", port)
        http.serve(port, |req| {
            return self.handle(req)
        })
    }

    // Forks `workers` OS processes sharing one listening socket -- the only
    // way to use more than one CPU core, since the task scheduler itself is
    // single-threaded. Open any DB/redis/etc. connections *inside* route
    // handlers (or otherwise after calling listen_cluster), not before --
    // a connection opened before the fork is a duplicated fd shared across
    // workers, which is unsafe for a stateful protocol.
    fn listen_cluster(self, port, workers) {
        self.port = port
        print("Zenith running on http://localhost:", port, "with", workers, "worker process(es)")
        http.serve(port, |req| {
            return self.handle(req)
        }, workers)
    }

    // HTTPS. cert_path/key_path are PEM files (e.g. from Let's Encrypt/
    // certbot, or a self-signed cert for local dev -- see
    // examples/tls_test.vn for how to generate one with openssl).
    //
    // CAVEAT: WebSocket/SSE upgrades (upgrade_websocket/sse_handshake)
    // write directly to the raw socket via http.write_socket(), which is
    // not TLS-aware — wss:// is unsupported. Lumen reactivity (lumen_mount)
    // silently breaks behind listen_tls because the browser tries wss://
    // and the server can't upgrade it. Production workaround: terminate TLS
    // at a reverse proxy (nginx/Caddy) that proxies plain ws:// to Zenith.
    fn listen_tls(self, port, cert_path, key_path) {
        self.port = port
        print("Zenith running on https://localhost:", port)
        http.serve_tls(port, |req| {
            return self.handle(req)
        }, cert_path, key_path)
    }

    // listen_tls() + listen_cluster()'s multi-process scaling combined.
    fn listen_tls_cluster(self, port, cert_path, key_path, workers) {
        self.port = port
        print("Zenith running on https://localhost:", port, "with", workers, "worker process(es)")
        http.serve_tls(port, |req| {
            return self.handle(req)
        }, cert_path, key_path, workers)
    }
}

fn _run_middleware(app, req) {
    let idx = req._middleware_idx
    if idx < app.middlewares.len() {
        let mw = app.middlewares[idx]
        let next_req = http.create_struct(
            ["method", "path", "body", "json", "params", "_middleware_idx", "_route_handler", "headers", "ip", "socket_fd"],
            [req.method, req.path, req.body, req.json, req.params, idx + 1, req._route_handler, req.headers, req.ip, req.socket_fd]
        )
        return mw(next_req, |r| {
            return _run_middleware(app, r)
        })
    } else {
        let handler = req._route_handler
        if handler == null {
            return Response { status: 404, body: "Not Found", content_type: "text/plain" }
        }
        return handler(req)
    }
}

// ─── OpenAPI ───

fn _convert_path(path_str) {
    let result = ""
    let remaining = path_str
    while remaining.len() > 0 {
        if remaining.starts_with("/") {
            result = result + "/"
            remaining = remaining.substring(1, remaining.len())
        } else if remaining.starts_with(":") {
            result = result + "{"
            remaining = remaining.substring(1, remaining.len())
            let slash = -1
            for j in 0..remaining.len() {
                if remaining.substring(j, j + 1) == "/" {
                    slash = j
                    break
                }
            }
            if slash < 0 {
                result = result + remaining + "}"
                remaining = ""
            } else {
                result = result + remaining.substring(0, slash) + "}"
                remaining = remaining.substring(slash, remaining.len())
            }
        } else {
            result = result + remaining.substring(0, 1)
            remaining = remaining.substring(1, remaining.len())
        }
    }
    return result
}

fn _val_to_schema(v) {
    if v == null {
        return http.create_struct(["type"], ["string"])
    }
    if v == true || v == false {
        return http.create_struct(["type"], ["boolean"])
    }
    let keys = _validate.get_keys(v)
    if keys != null {
        let prop_keys = []
        let prop_vals = []
        for i in 0..keys.len() {
            let key = keys[i]
            let field_val = _validate.get_field(v, key)
            prop_keys = prop_keys.push(key)
            prop_vals = prop_vals.push(_val_to_schema(field_val))
        }
        return http.create_struct(
            ["type", "properties"],
            ["object", http.create_struct(prop_keys, prop_vals)]
        )
    }
    if _validate.min_len(v, 0) {
        return http.create_struct(["type"], ["string"])
    }
    return http.create_struct(["type"], ["number"])
}

fn _val_to_ref(name) {
    return http.create_struct(["$ref"], ["#/components/schemas/" + name])
}

fn _json_content(schema) {
    return http.create_struct(
        ["application/json"],
        [http.create_struct(["schema"], [schema])]
    )
}

fn _response_with_schema(desc, schema) {
    return http.create_struct(
        ["description", "content"],
        [desc, _json_content(schema)]
    )
}

fn build_openapi_spec(app, base_url) {
    let groups = []
    for i in 0..app.route_list.len() {
        let route = app.route_list[i]
        let pkey = _convert_path(route.path)
        let method_name = route.method.lower()

        let op_keys = ["summary"]
        let op_vals = [route.summary]

        let resp_keys = []
        let resp_vals = []

        if route.meta != null {
            let req_schema = _validate.get_field(route.meta, "request_schema")
            let res_schema = _validate.get_field(route.meta, "response_schema")
            let res_status = _validate.get_field(route.meta, "response_status")
            let err_schema = _validate.get_field(route.meta, "error_schema")
            let err_status = _validate.get_field(route.meta, "error_status")
            let req_required = _validate.get_field(route.meta, "request_required")

            if req_schema != null and req_schema != "" {
                let required = true
                if req_required == false { required = false }
                op_keys = op_keys.push("requestBody")
                op_vals = op_vals.push(http.create_struct(
                    ["required", "content"],
                    [required, _json_content(_val_to_ref(req_schema))]
                ))
            }

            if res_schema != null and res_schema != "" {
                if res_status == null { res_status = 200 }
                let status_str = "" + res_status
                resp_keys = resp_keys.push(status_str)
                resp_vals = resp_vals.push(
                    _response_with_schema("OK", _val_to_ref(res_schema))
                )
            } else {
                resp_keys = ["200"]
                resp_vals = [http.create_struct(["description"], ["OK"])]
            }

            if err_schema != null and err_schema != "" {
                if err_status == null { err_status = 400 }
                let err_status_str = "" + err_status
                resp_keys = resp_keys.push(err_status_str)
                resp_vals = resp_vals.push(
                    _response_with_schema("Error", _val_to_ref(err_schema))
                )
            }
        } else {
            resp_keys = ["200"]
            resp_vals = [http.create_struct(["description"], ["OK"])]
        }

        op_keys = op_keys.push("responses")
        op_vals = op_vals.push(http.create_struct(resp_keys, resp_vals))

        let params = []
        let segs = route.path.split("/")
        for j in 0..segs.len() {
            if segs[j] != "" and segs[j].starts_with(":") {
                let param_name = segs[j].substring(1, segs[j].len())
                params = params.push(http.create_struct(
                    ["name", "in", "required", "schema"],
                    [param_name, "path", true, http.create_struct(["type"], ["string"])]
                ))
            }
        }
        if params.len() > 0 {
            op_keys = op_keys.push("parameters")
            op_vals = op_vals.push(params)
        }

        let op = http.create_struct(op_keys, op_vals)

        let group = null
        for j in 0..groups.len() {
            if groups[j].path_key == pkey {
                group = groups[j]
                break
            }
        }
        if group == null {
            group = PathGroup { path_key: pkey, methods: [], ops: [] }
            groups = groups.push(group)
        }
        group.methods = group.methods.push(method_name)
        group.ops = group.ops.push(op)
    }

    let path_keys = []
    let path_vals = []
    for i in 0..groups.len() {
        let g = groups[i]
        path_keys = path_keys.push(g.path_key)
        path_vals = path_vals.push(http.create_struct(g.methods, g.ops))
    }

    let components = null
    if app.schema_names.len() > 0 {
        let schema_keys = []
        let schema_vals = []
        for i in 0..app.schema_names.len() {
            let name = app.schema_names[i]
            let val = app.schema_values[i]
            schema_keys = schema_keys.push(name)
            schema_vals = schema_vals.push(_val_to_schema(val))
        }
        components = http.create_struct(
            ["schemas"],
            [http.create_struct(schema_keys, schema_vals)]
        )
    }

    let info = OpenApiInfo { title: app.title, version: "1.0.0" }
    let servers = [http.create_struct(["url"], [base_url])]
    
    let spec_keys = ["openapi", "info", "paths", "servers"]
    let spec_vals = ["3.0.0", info, http.create_struct(path_keys, path_vals), servers]
    if components != null {
        spec_keys = spec_keys.push("components")
        spec_vals = spec_vals.push(components)
    }
    
    let spec = http.create_struct(spec_keys, spec_vals)
    return json_encode(spec)
}

fn _swagger_handler(app, req) {
    let logo = "data:image/png;base64,"
    let html = "<!DOCTYPE html>"
    html = html + "<html lang=\"en\">"
    html = html + "<head>"
    html = html + "<meta charset=\"UTF-8\">"
    html = html + "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">"
    html = html + "<title>" + app.title + " API Reference</title>"
    html = html + "<link rel=\"icon\" type=\"image/png\" href=\"" + logo + "\">"
    html = html + "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui.css\">"
    html = html + "<style>"
    html = html + "body \{ margin: 0; background: #fafafa; }"
    html = html + ".zenith-topbar \{ display: flex; align-items: center; height: 56px; padding: 0 28px; background: #161616; border-bottom: 2px solid #f95a29; box-shadow: 0 1px 4px rgba(0,0,0,0.25); }"
    html = html + ".zenith-topbar img \{ height: 30px; display: block; }"
    html = html + ".zenith-topbar .zenith-word \{ margin-left: 12px; color: #ffffff; font-family: 'Segoe UI', Helvetica, Arial, sans-serif; font-style: italic; font-weight: 800; font-size: 23px; letter-spacing: 0.5px; transform: skewX(-7deg); display: inline-block; }"
    html = html + ".swagger-ui .topbar \{ display: none; }"
    html = html + ".swagger-ui .info \{ margin: 28px 0; }"
    html = html + ".swagger-ui .opblock.opblock-get .opblock-summary-method \{ background: #f95a29; }"
    html = html + ".swagger-ui .opblock.opblock-get \{ border-color: #f95a29; background: rgba(249,90,41,0.04); }"
    html = html + ".swagger-ui .btn.authorize, .swagger-ui .btn.execute \{ background: #f95a29; border-color: #f95a29; }"
    html = html + ".swagger-ui .btn.authorize svg \{ fill: #fff; }"
    html = html + "</style>"
    html = html + "</head>"
    html = html + "<body>"
    html = html + "<div class=\"zenith-topbar\"><img src=\"" + logo + "\" alt=\"\"><span class=\"zenith-word\">Zenith</span></div>"
    html = html + "<div id=\"swagger-ui\"></div>"
    html = html + "<script src=\"https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-bundle.js\"></script>"
    html = html + "<script src=\"https://cdn.jsdelivr.net/npm/swagger-ui-dist@5/swagger-ui-standalone-preset.js\"></script>"
    html = html + "<script>"
    html = html + "window.ui = SwaggerUIBundle(\{"
    html = html + "url: '/openapi.json',"
    html = html + "dom_id: '#swagger-ui',"
    html = html + "deepLinking: true,"
    html = html + "filter: true,"
    html = html + "tryItOutEnabled: true,"
    html = html + "presets: [SwaggerUIBundle.presets.apis, SwaggerUIStandalonePreset],"
    html = html + "layout: 'BaseLayout'"
    html = html + "})"
    html = html + "</script>"
    html = html + "</body></html>"
    return Response { status: 200, body: html, content_type: "text/html" }
}

// ============================================================================
//  Request helpers — query strings, form bodies, cookies
//
//  Collections here are plain structs built with http.create_struct(): read a
//  field with _validate.get_field(s, key) (returns null when absent) and list
//  keys with _validate.get_keys(s). The query()/form()/cookie() accessors wrap
//  that so handler code never touches _validate directly.
// ============================================================================

fn _hex_nibble(c) {
    if c >= 48 and c <= 57 { return c - 48 }      // '0'..'9'
    if c >= 97 and c <= 102 { return c - 87 }     // 'a'..'f'
    if c >= 65 and c <= 70 { return c - 55 }      // 'A'..'F'
    return -1
}

// Percent-decode a URL-encoded component ("%20" -> space, "+" -> space).
// Invalid/short escapes are passed through literally rather than dropped.
fn url_decode(s) {
    if s == null { return "" }
    let out = []
    let n = s.len()
    let i = 0
    while i < n {
        let c = s.code_at(i)
        if c == 37 and i + 2 < n {                 // '%'
            let hi = _hex_nibble(s.code_at(i + 1))
            let lo = _hex_nibble(s.code_at(i + 2))
            if hi >= 0 and lo >= 0 {
                out = out.push(hi * 16 + lo)
                i = i + 3
            } else {
                out = out.push(c)
                i = i + 1
            }
        } else if c == 43 {                        // '+'
            out = out.push(32)
            i = i + 1
        } else {
            out = out.push(c)
            i = i + 1
        }
    }
    return "".from_codes(out)
}

// Parse "a=1&b=two&flag" into a struct {a:"1", b:"two", flag:""}, decoding
// both keys and values. Empty segments (e.g. trailing "&") are skipped.
fn parse_pairs(s) {
    let keys = []
    let vals = []
    if s == null or s == "" {
        return http.create_struct(keys, vals)
    }
    let pairs = s.split("&")
    for i in 0..pairs.len() {
        let p = pairs[i]
        if p == "" { continue }
        let eq = p.index_of("=")
        if eq < 0 {
            keys = keys.push(url_decode(p))
            vals = vals.push("")
        } else {
            keys = keys.push(url_decode(p.substring(0, eq)))
            vals = vals.push(url_decode(p.substring(eq + 1, p.len())))
        }
    }
    return http.create_struct(keys, vals)
}

// All query-string parameters as a struct.
fn query_params(req) {
    return parse_pairs(_get_req_field(req, "query", ""))
}

// A single query parameter, or `default` when absent.
fn query(req, key, default) {
    let v = _validate.get_field(query_params(req), key)
    if v == null { return default }
    return v
}

// All application/x-www-form-urlencoded body fields as a struct.
fn form_params(req) {
    return parse_pairs(_get_req_field(req, "body", ""))
}

// A single form field, or `default` when absent.
fn form(req, key, default) {
    let v = _validate.get_field(form_params(req), key)
    if v == null { return default }
    return v
}

// ── Cookies ────────────────────────────────────────────────────────────────

// Parse the inbound Cookie header ("a=1; b=2") into a struct.
fn cookies(req) {
    let keys = []
    let vals = []
    let headers = _get_req_field(req, "headers", null)
    let raw = null
    if headers != null {
        raw = _validate.get_field(headers, "cookie")
    }
    if raw == null or raw == "" {
        return http.create_struct(keys, vals)
    }
    let parts = raw.split(";")
    for i in 0..parts.len() {
        let p = _sanitize.trim(parts[i])
        if p == "" { continue }
        let eq = p.index_of("=")
        if eq < 0 { continue }
        keys = keys.push(p.substring(0, eq))
        vals = vals.push(url_decode(p.substring(eq + 1, p.len())))
    }
    return http.create_struct(keys, vals)
}

// A single inbound cookie value, or `default` when absent.
fn cookie(req, name, default) {
    let v = _validate.get_field(cookies(req), name)
    if v == null { return default }
    return v
}

// ============================================================================
//  Response helpers — headers, cookies, redirects
//
//  A Response carries an optional `headers` struct; the C response writer turns
//  each field "X_Foo" into the header "X-Foo". Field names are unique, so at
//  most one value per header name (one Set-Cookie per response).
// ============================================================================

// Return a copy of `resp` with header `name: value` set. `name` may use either
// dashes or underscores ("X-Frame-Options" / "X_Frame_Options").
fn with_header(resp, name, value) {
    let field = name.replace("-", "_")
    let keys = [field]
    let vals = [value]
    let existing = _get_req_field(resp, "headers", null)
    if existing != null {
        let ekeys = _validate.get_keys(existing)
        let nk = []
        let nv = []
        for i in 0..ekeys.len() {
            if ekeys[i] != field {
                nk = nk.push(ekeys[i])
                nv = nv.push(_validate.get_field(existing, ekeys[i]))
            }
        }
        nk = nk.push(field)
        nv = nv.push(value)
        keys = nk
        vals = nv
    }
    let hdrs = http.create_struct(keys, vals)
    return Response {
        status: _get_req_field(resp, "status", 200),
        body: _get_req_field(resp, "body", ""),
        content_type: _get_req_field(resp, "content_type", "text/plain"),
        _keep_open: false,
        headers: hdrs
    }
}

// Build a "Set-Cookie" header value. `opts` is an optional struct understanding
// max_age (int seconds), path, domain, http_only (bool), secure (bool) and
// same_site ("Strict"/"Lax"/"None"). Sensible secure defaults: when no opts are
// given the cookie is HttpOnly + SameSite=Lax + Path=/.
fn build_cookie(name, value, opts) {
    let s = name + "=" + value
    let path = "/"
    let http_only = true
    let secure = false
    let same_site = "Lax"
    let max_age = -1
    let domain = null
    if opts != null {
        let p = _validate.get_field(opts, "path")
        if p != null { path = p }
        let h = _validate.get_field(opts, "http_only")
        if h != null { http_only = h }
        let sc = _validate.get_field(opts, "secure")
        if sc != null { secure = sc }
        let ss = _validate.get_field(opts, "same_site")
        if ss != null { same_site = ss }
        let ma = _validate.get_field(opts, "max_age")
        if ma != null { max_age = ma }
        let dm = _validate.get_field(opts, "domain")
        if dm != null { domain = dm }
    }
    s = s + "; Path=" + path
    if domain != null { s = s + "; Domain=" + domain }
    if max_age >= 0 { s = s + "; Max-Age=" + max_age }
    if same_site != null { s = s + "; SameSite=" + same_site }
    if http_only { s = s + "; HttpOnly" }
    if secure { s = s + "; Secure" }
    return s
}

// Return a copy of `resp` with a Set-Cookie header for (name, value, opts).
fn set_cookie(resp, name, value, opts) {
    return with_header(resp, "Set-Cookie", build_cookie(name, value, opts))
}

// Expire a cookie immediately on the client.
fn clear_cookie(resp, name) {
    return with_header(resp, "Set-Cookie", name + "=; Path=/; Max-Age=0")
}

// 302 redirect to `url`.
fn redirect(url) {
    return redirect_with(url, 302)
}

// Redirect to `url` with an explicit status (301/302/303/307/308).
fn redirect_with(url, status) {
    return Response {
        status: status,
        body: "",
        content_type: "text/html",
        _keep_open: false,
        headers: http.create_struct(["Location"], [url])
    }
}

// JSON response helper: serialize `value` and set the JSON content type.
fn json_response(value, status) {
    return Response {
        status: status,
        body: json_encode(value),
        content_type: "application/json",
        _keep_open: false
    }
}

// ============================================================================
//  Sessions — stateless, signed with JWT (HMAC-SHA256)
//
//  The whole session payload lives in a signed cookie, so there is no
//  server-side store to keep in sync across cluster workers. Keep payloads
//  small and never put secrets in them: the value is signed (tamper-proof) but
//  NOT encrypted, so it is readable by the client. `secret` must be the same
//  across restarts/workers or existing sessions stop verifying.
// ============================================================================

// Sign `data` (a struct) into a session token.
fn session_sign(data, secret) {
    return auth.sign_jwt(data, secret)
}

// Read and verify the session from the "session" cookie. Returns the decoded
// payload struct, or null when missing/invalid/tampered.
fn session_get(req, secret) {
    let token = cookie(req, "session", null)
    if token == null { return null }
    return auth.verify_jwt(token, secret)
}

// Return a copy of `resp` that sets a signed session cookie carrying `data`.
fn session_set(resp, data, secret, opts) {
    let token = session_sign(data, secret)
    return set_cookie(resp, "session", token, opts)
}

// Log out: clear the session cookie.
fn session_clear(resp) {
    return clear_cookie(resp, "session")
}

// ============================================================================
//  Templating — render(template, ctx)
//
//  Supports, with arbitrary nesting:
//    <%= expr %>   interpolate, HTML-escaped (safe default)
//    <%- expr %>   interpolate, raw (no escaping)
//    <% if expr %> ... <% else %> ... <% endif %>
//    <% for x in items %> ... <% endfor %>
//  `expr` is a dotted path resolved against the context ("user.name"); inside a
//  for-loop the loop variable shadows the outer context. `ctx` is a struct
//  (use http.create_struct). Escaping-by-default makes the common case safe.
//
//  Delimiters are brace-free on purpose: Varian string literals already do
//  {expr} interpolation, so "<% %>" is what survives intact in an inline
//  template literal as well as one read from a file.
// ============================================================================

// Resolve a dotted path like "user.name" against a context struct.
fn _tpl_lookup(ctx, path) {
    if ctx == null { return null }
    let segs = path.split(".")
    let cur = ctx
    for i in 0..segs.len() {
        if cur == null { return null }
        cur = _validate.get_field(cur, segs[i])
    }
    return cur
}

fn _tpl_truthy(v) {
    if v == null { return false }
    if v == false { return false }
    if v == "" { return false }
    if v == 0 { return false }
    return true
}

// Shallow-copy `ctx` and override/add a single key — used to bind loop vars.
fn _tpl_bind(ctx, key, value) {
    let keys = [key]
    let vals = [value]
    if ctx != null {
        let ck = _validate.get_keys(ctx)
        for i in 0..ck.len() {
            if ck[i] != key {
                keys = keys.push(ck[i])
                vals = vals.push(_validate.get_field(ctx, ck[i]))
            }
        }
    }
    return http.create_struct(keys, vals)
}

// index_of starting at `from` (the builtin index_of always searches from 0).
fn _substr_index(s, needle, from) {
    if from >= s.len() { return -1 }
    let sub = s.substring(from, s.len())
    let idx = sub.index_of(needle)
    if idx < 0 { return -1 }
    return from + idx
}

// Find the next "<%" tag opener at or after `from`; returns its index or -1.
// (Brace-free delimiters are deliberate: Varian string literals use {expr}
//  interpolation, so any "{" inside an inline template literal would be eaten
//  by the lexer before render() ever ran. "<%" survives in both inline string
//  literals and templates loaded from files.)
fn _tpl_next_tag(tpl, from) {
    let i = from
    let n = tpl.len()
    while i < n - 1 {
        if tpl.code_at(i) == 60 and tpl.code_at(i + 1) == 37 {  // '<' '%'
            return i
        }
        i = i + 1
    }
    return -1
}

// Render the template region tpl[pos..stop) against ctx, returning a struct
// {out, pos, tag}. Recurses for nested if/for blocks. When `stop_tags` is
// non-null, rendering halts at the first "<% <kw> %>" whose keyword is in the
// list and reports that keyword back via "tag" so the caller (if/for) knows
// whether it hit else/endif/endfor.
//   <%= expr %>   interpolate, HTML-escaped
//   <%- expr %>   interpolate, raw
//   <% if/for/else/endif/endfor %>   control flow
fn _tpl_render_region(tpl, pos, stop, ctx, stop_tags) {
    let out = ""
    let i = pos
    while i < stop {
        let tag = _tpl_next_tag(tpl, i)
        if tag < 0 or tag >= stop {
            out = out + tpl.substring(i, stop)
            i = stop
        } else {
            out = out + tpl.substring(i, tag)
            let close = _substr_index(tpl, "%>", tag + 2)
            let marker = tpl.code_at(tag + 2)
            if marker == 61 or marker == 45 {       // '=' escaped, '-' raw
                let expr = _sanitize.trim(tpl.substring(tag + 3, close))
                let looked = _tpl_lookup(ctx, expr)
                let val = ""
                if looked != null { val = "" + looked }
                if marker == 45 {
                    out = out + val
                } else {
                    out = out + _sanitize.escape_html(val)
                }
                i = close + 2
            } else {                                // control-flow statement
                let directive = _sanitize.trim(tpl.substring(tag + 2, close))
                let after = close + 2
                if _tpl_is_stop(directive, stop_tags) {
                    return http.create_struct(["out", "pos", "tag"], [out, after, _tpl_keyword(directive)])
                }
                if directive.starts_with("if ") {
                    let res = _tpl_do_if(tpl, after, stop, ctx, _sanitize.trim(directive.substring(3, directive.len())))
                    out = out + _validate.get_field(res, "out")
                    i = _validate.get_field(res, "pos")
                } else if directive.starts_with("for ") {
                    let res = _tpl_do_for(tpl, after, stop, ctx, _sanitize.trim(directive.substring(4, directive.len())))
                    out = out + _validate.get_field(res, "out")
                    i = _validate.get_field(res, "pos")
                } else {
                    // Unknown directive: emit nothing, skip it.
                    i = after
                }
            }
        }
    }
    return http.create_struct(["out", "pos", "tag"], [out, i, ""])
}

fn _tpl_keyword(directive) {
    let sp = directive.index_of(" ")
    if sp < 0 { return directive }
    return directive.substring(0, sp)
}

fn _tpl_is_stop(directive, stop_tags) {
    if stop_tags == null { return false }
    let kw = _tpl_keyword(directive)
    for i in 0..stop_tags.len() {
        if stop_tags[i] == kw { return true }
    }
    return false
}

// Handle {% if expr %} body [{% else %} body] {% endif %}
fn _tpl_do_if(tpl, pos, stop, ctx, expr) {
    let truthy = _tpl_truthy(_tpl_lookup(ctx, expr))
    let first = _tpl_render_region(tpl, pos, stop, ctx, ["else", "endif"])
    let stopped = _validate.get_field(first, "tag")
    let out = ""
    if truthy {
        out = _validate.get_field(first, "out")
    }
    let cur = _validate.get_field(first, "pos")
    if stopped == "else" {
        let second = _tpl_render_region(tpl, cur, stop, ctx, ["endif"])
        if truthy == false {
            out = _validate.get_field(second, "out")
        }
        cur = _validate.get_field(second, "pos")
    }
    return http.create_struct(["out", "pos"], [out, cur])
}

// Handle {% for x in items %} body {% endfor %}
fn _tpl_do_for(tpl, pos, stop, ctx, header) {
    // header is "x in items"
    let inpos = header.index_of(" in ")
    let var_name = _sanitize.trim(header.substring(0, inpos))
    let list_expr = _sanitize.trim(header.substring(inpos + 4, header.len()))
    let items = _tpl_lookup(ctx, list_expr)
    let out = ""
    let body_end = pos
    if items != null {
        for j in 0..items.len() {
            let child = _tpl_bind(ctx, var_name, items[j])
            let res = _tpl_render_region(tpl, pos, stop, child, ["endfor"])
            out = out + _validate.get_field(res, "out")
            body_end = _validate.get_field(res, "pos")
        }
    }
    if body_end == pos {
        // Empty list: still consume the body up to {% endfor %} once.
        let res = _tpl_render_region(tpl, pos, stop, ctx, ["endfor"])
        body_end = _validate.get_field(res, "pos")
    }
    return http.create_struct(["out", "pos"], [out, body_end])
}

// Render a template string against a context struct.
fn render(template, ctx) {
    let res = _tpl_render_region(template, 0, template.len(), ctx, null)
    return _validate.get_field(res, "out")
}

// Convenience: a 200 text/html response from a rendered template.
fn render_response(template, ctx) {
    return Response {
        status: 200,
        body: render(template, ctx),
        content_type: "text/html",
        _keep_open: false
    }
}
