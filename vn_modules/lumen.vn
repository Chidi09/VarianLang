// lumen.vn — Lumen, the Varian frontend framework (server-driven live).
//
// A Lumen component renders to HTML on the SERVER (on top of Zenith). Event
// bindings like @click are compiled to `data-lumen-*` hook attributes; a tiny
// client runtime forwards those events over a WebSocket, the server re-renders
// the component and patches the DOM. Logic is written in Varian — Lumen is to
// Varian what JSX is to TypeScript.
//
// This file is MILESTONE 1: the server-side renderer for Lumen's `{{ }}` markup
// syntax, plus the @event -> data-lumen-* rewrite that the (future) live client
// will hook into. The live WebSocket/DOM-diff layer and `.lumen` single-file
// component compilation are later milestones.
//
// Markup:
//   {{ expr }}                     interpolate, HTML-escaped (safe by default)
//   {{! expr }}                    interpolate, raw / unescaped (trusted only)
//   {{#if expr}} .. {{else}} .. {{/if}}
//   {{#each items as item}} .. {{/each}}
//   @click="handler"               -> data-lumen-click="handler"  (live hook)
//
// `expr` is resolved against the context struct (dotted paths supported), using
// the same lookup/truthy/bind helpers Zenith's template engine already uses.

// ─── small string helper: replace every `find` with `repl` ───
fn _lumen_replace(s, find, repl) {
    let out = ""
    let i = 0
    let n = s.len()
    let flen = find.len()
    while i < n {
        let hit = _substr_index(s, find, i)
        if hit < 0 {
            out = out + s.substring(i, n)
            i = n
        } else {
            out = out + s.substring(i, hit) + repl
            i = hit + flen
        }
    }
    return out
}

// Rewrite @event="..." attribute bindings into data-lumen-event="..." hooks.
// The live client runtime listens for these and forwards the event server-side.
fn _lumen_bind_events(html) {
    let events = ["click", "input", "change", "submit", "keydown", "keyup", "blur", "focus", "mouseover", "mouseout"]
    let out = html
    for i in 0..events.len() {
        out = _lumen_replace(out, "@" + events[i] + "=\"", "data-lumen-" + events[i] + "=\"")
    }
    return out
}

// Is `token` (e.g. "else", "/if", "/each") one of the tokens we should halt at?
fn _lumen_is_stop(token, stop_tags) {
    if stop_tags == null { return false }
    for i in 0..stop_tags.len() {
        if stop_tags[i] == token { return true }
    }
    return false
}

// Render tpl[pos..stop) against ctx. Halts at the first {{else}}/{{/if}}/{{/each}}
// whose token is in stop_tags, reporting it back via "tag". Returns {out,pos,tag}.
fn _lumen_render_region(tpl, pos, stop, ctx, stop_tags) {
    // Varian treats `{` as interpolation in strings, so the delimiters are
    // written with brace escapes: "\{\{" is the literal two-char open marker.
    let OPEN = "\{\{"
    let CLOSE = "\}\}"
    let out = ""
    let i = pos
    while i < stop {
        let tag = _substr_index(tpl, OPEN, i)
        if tag < 0 or tag >= stop {
            out = out + tpl.substring(i, stop)
            i = stop
        } else {
            out = out + tpl.substring(i, tag)
            let close = _substr_index(tpl, CLOSE, tag + 2)
            if close < 0 or close >= stop {
                // No closing braces — emit the rest verbatim.
                out = out + tpl.substring(tag, stop)
                i = stop
            } else {
                let marker = tpl.code_at(tag + 2)
                if marker == 33 {                 // '!' raw interpolation
                    let expr = _sanitize.trim(tpl.substring(tag + 3, close))
                    let looked = _tpl_lookup(ctx, expr)
                    let val = ""
                    if looked != null { val = "" + looked }
                    out = out + val
                    i = close + 2
                } else if marker == 35 {           // '#' block: if / each
                    let directive = _sanitize.trim(tpl.substring(tag + 3, close))
                    let after = close + 2
                    if directive.starts_with("if ") {
                        let res = _lumen_do_if(tpl, after, stop, ctx, _sanitize.trim(directive.substring(3, directive.len())))
                        out = out + _validate.get_field(res, "out")
                        i = _validate.get_field(res, "pos")
                    } else if directive.starts_with("each ") {
                        let res = _lumen_do_each(tpl, after, stop, ctx, _sanitize.trim(directive.substring(5, directive.len())))
                        out = out + _validate.get_field(res, "out")
                        i = _validate.get_field(res, "pos")
                    } else {
                        i = after
                    }
                } else if marker == 47 {           // '/' closing token: /if, /each
                    let token = "/" + _sanitize.trim(tpl.substring(tag + 3, close))
                    if _lumen_is_stop(token, stop_tags) {
                        return http.create_struct(["out", "pos", "tag"], [out, close + 2, token])
                    }
                    i = close + 2
                } else {
                    let inner = _sanitize.trim(tpl.substring(tag + 2, close))
                    if inner == "else" and _lumen_is_stop("else", stop_tags) {
                        return http.create_struct(["out", "pos", "tag"], [out, close + 2, "else"])
                    }
                    // {{ expr }} — escaped interpolation (safe by default)
                    let looked = _tpl_lookup(ctx, inner)
                    let val = ""
                    if looked != null { val = "" + looked }
                    out = out + _sanitize.escape_html(val)
                    i = close + 2
                }
            }
        }
    }
    return http.create_struct(["out", "pos", "tag"], [out, i, ""])
}

// {{#if expr}} body [{{else}} body] {{/if}}
fn _lumen_do_if(tpl, pos, stop, ctx, expr) {
    let truthy = _tpl_truthy(_tpl_lookup(ctx, expr))
    let first = _lumen_render_region(tpl, pos, stop, ctx, ["else", "/if"])
    let stopped = _validate.get_field(first, "tag")
    let out = ""
    if truthy { out = _validate.get_field(first, "out") }
    let cur = _validate.get_field(first, "pos")
    if stopped == "else" {
        let second = _lumen_render_region(tpl, cur, stop, ctx, ["/if"])
        if truthy == false { out = _validate.get_field(second, "out") }
        cur = _validate.get_field(second, "pos")
    }
    return http.create_struct(["out", "pos"], [out, cur])
}

// {{#each items as item}} body {{/each}}
fn _lumen_do_each(tpl, pos, stop, ctx, header) {
    let aspos = header.index_of(" as ")
    let list_expr = _sanitize.trim(header.substring(0, aspos))
    let var_name = _sanitize.trim(header.substring(aspos + 4, header.len()))
    let items = _tpl_lookup(ctx, list_expr)
    let out = ""
    let body_end = pos
    if items != null {
        for j in 0..items.len() {
            let child = _tpl_bind(ctx, var_name, items[j])
            let res = _lumen_render_region(tpl, pos, stop, child, ["/each"])
            out = out + _validate.get_field(res, "out")
            body_end = _validate.get_field(res, "pos")
        }
    }
    if body_end == pos {
        // Empty list: consume the body once so we land past {{/each}}.
        let res = _lumen_render_region(tpl, pos, stop, ctx, ["/each"])
        body_end = _validate.get_field(res, "pos")
    }
    return http.create_struct(["out", "pos"], [out, body_end])
}

let _lumen_active_child_states = null
let _lumen_component_names = []
let _lumen_components = []

fn lumen_register_component(name, component) {
    _lumen_component_names = _lumen_component_names.push(name)
    _lumen_components = _lumen_components.push(component)
}

fn _lumen_get_component(name) {
    for i in 0.._lumen_component_names.len() {
        if _lumen_component_names[i] == name {
            return _lumen_components[i]
        }
    }
    return null
}

fn _lumen_parse_attrs(attr_str) {
    let keys = []
    let vals = []
    let i = 0
    let n = attr_str.len()
    while i < n {
        while i < n and attr_str.code_at(i) <= 32 { i = i + 1 }
        if i >= n { break }
        let eq = attr_str.index_of("=", i)
        if eq < 0 { break }
        let key = _sanitize.trim(attr_str.substring(i, eq))
        let quote_pos = eq + 1
        while quote_pos < n and attr_str.code_at(quote_pos) <= 32 { quote_pos = quote_pos + 1 }
        if quote_pos >= n { break }
        let quote_char = attr_str.substring(quote_pos, quote_pos + 1)
        if quote_char != "\"" and quote_char != "'" { break }
        let close_quote = attr_str.index_of(quote_char, quote_pos + 1)
        if close_quote < 0 { break }
        let val = attr_str.substring(quote_pos + 1, close_quote)
        keys = keys.push(key)
        vals = vals.push(val)
        i = close_quote + 1
    }
    return http.create_struct(keys, vals)
}

fn _lumen_rewrite_child_events(html, child_id) {
    let events = ["click", "input", "change", "submit", "keydown", "keyup", "blur", "focus", "mouseover", "mouseout"]
    let out = html
    for i in 0..events.len() {
        let attr = "data-lumen-" + events[i] + "=\""
        out = _lumen_replace(out, attr, attr + child_id + ":")
    }
    return out
}

fn _lumen_process_composition(html, state) {
    let n = html.len()

    // M9 fast path: a component tag is a "<" followed by an uppercase letter.
    // If the markup has none (every leaf component, the common case), skip the
    // full char-by-char rebuild and its allocations — just return the input.
    let scan = 0
    let found_comp = false
    while scan < n {
        let lt = html.index_of("<", scan)
        if lt < 0 { break }
        if lt + 1 < n {
            let nc = html.code_at(lt + 1)
            if nc >= 65 and nc <= 90 { found_comp = true; break }
        }
        scan = lt + 1
    }
    if found_comp == false { return html }

    let out = ""
    let i = 0
    let child_counts = {}

    while i < n {
        let tag_start = html.index_of("<", i)
        if tag_start < 0 {
            out = out + html.substring(i, n)
            break
        }
        out = out + html.substring(i, tag_start)
        
        let is_comp = false
        if tag_start + 1 < n {
            let next_char = html.code_at(tag_start + 1)
            if next_char >= 65 and next_char <= 90 {
                is_comp = true
            }
        }
        
        if is_comp == false {
            out = out + "<"
            i = tag_start + 1
            continue
        }
        
        let tag_end = html.index_of(">", tag_start)
        if tag_end < 0 {
            out = out + html.substring(tag_start, n)
            break
        }
        
        let tag_content = html.substring(tag_start + 1, tag_end)
        let is_self_closing = false
        if tag_content.ends_with("/") {
            is_self_closing = true
            tag_content = tag_content.substring(0, tag_content.len() - 1)
        }
        
        let space_pos = tag_content.index_of(" ")
        let comp_name = ""
        let attrs_str = ""
        if space_pos < 0 {
            comp_name = _sanitize.trim(tag_content)
        } else {
            comp_name = _sanitize.trim(tag_content.substring(0, space_pos))
            attrs_str = tag_content.substring(space_pos + 1, tag_content.len())
        }
        
        let comp = _lumen_get_component(comp_name)
        if comp == null {
            let slash_str = ""
            if is_self_closing { slash_str = "/" }
            out = out + "<" + tag_content + slash_str + ">"
            i = tag_end + 1
            continue
        }
        
        let raw_attrs = _lumen_parse_attrs(attrs_str)
        let child_id = _validate.get_field(raw_attrs, "id")
        if child_id == null {
            let current_count = _validate.get_field(child_counts, comp_name)
            if current_count == null { current_count = 0 }
            child_id = comp_name + "_" + current_count
            child_counts = _tpl_bind(child_counts, comp_name, current_count + 1)
        }
        
        if _lumen_active_child_states == null {
            _lumen_active_child_states = {}
        }
        let child_state = _validate.get_field(_lumen_active_child_states, child_id)
        if child_state == null {
            child_state = (comp.state_fn)()
            child_state = _tpl_bind(child_state, "_comp", comp_name)
            child_state = _tpl_bind(child_state, "_id", child_id)
        }

        let attr_keys = _validate.get_keys(raw_attrs)
        for k in 0..attr_keys.len() {
            let key = attr_keys[k]
            if key != "id" {
                let val = _validate.get_field(raw_attrs, key)
                child_state = _tpl_bind(child_state, key, val)
            }
        }

        // ─── M6: slots ───
        // For a paired tag <Comp>..inner..</Comp>, the inner markup is the
        // component's `children`. It's already interpolated against the parent
        // context (composition runs after lumen_render's {{ }} pass), so we just
        // recursively process it for nested components, then inject it into the
        // child's {{! children }} slot AFTER the child's own events are scoped.
        // A placeholder keeps the two event scopes from colliding: the child's
        // own @events get the child_id prefix; the slot content (already final)
        // is spliced in untouched.
        let next_i = tag_end + 1
        let slot_html = ""
        let has_slot = false
        if is_self_closing == false {
            let close_tag = "</" + comp_name + ">"
            let close_tag_pos = html.index_of(close_tag, tag_end)
            if close_tag_pos >= 0 {
                let inner = html.substring(tag_end + 1, close_tag_pos)
                slot_html = _lumen_process_composition(inner, state)
                has_slot = true
                next_i = close_tag_pos + close_tag.len()
            }
        }
        if has_slot {
            child_state = _tpl_bind(child_state, "children", "<!--lumen-slot-->")
        }
        _lumen_active_child_states = _tpl_bind(_lumen_active_child_states, child_id, child_state)

        let child_html = (comp.render_fn)(child_state)
        let child_html_rewritten = _lumen_rewrite_child_events(child_html, child_id)
        if has_slot {
            child_html_rewritten = _lumen_replace(child_html_rewritten, "<!--lumen-slot-->", slot_html)
        }
        out = out + child_html_rewritten
        i = next_i
    }
    return out
}

fn _lumen_escape_string(s) {
    let out = ""
    let i = 0
    let n = s.len()
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\\" {
            out = out + "\\\\"
        } else if c == "\"" {
            out = out + "\\\""
        } else if c == "{" {
            out = out + "\\{"
        } else if c == "}" {
            out = out + "\\}"
        } else if c == "\n" {
            out = out + "\\n"
        } else if c == "\r" {
            out = out + "\\r"
        } else if c == "\t" {
            out = out + "\\t"
        } else {
            out = out + c
        }
        i = i + 1
    }
    return out
}

fn _lumen_extract_fns(script) {
    let names = []
    let i = 0
    let n = script.len()
    while i < n {
        let fn_pos = script.index_of("fn ", i)
        if fn_pos < 0 { break }
        let name_start = fn_pos + 3
        let open_paren = script.index_of("(", name_start)
        if open_paren > name_start {
            let name = _sanitize.trim(script.substring(name_start, open_paren))
            if name != "state" and name != "" {
                names = names.push(name)
            }
        }
        i = fn_pos + 3
    }
    return names
}

fn lumen_compile_source(name, lumen_src) {
    let temp_start = lumen_src.index_of("<template>")
    let temp_end = lumen_src.index_of("</template>")
    let script_start = lumen_src.index_of("<script>")
    let script_end = lumen_src.index_of("</script>")
    
    if temp_start < 0 or temp_end < 0 or script_start < 0 or script_end < 0 {
        throw("Invalid .lumen file structure: must contain <template> and <script> tags")
    }
    
    let template = lumen_src.substring(temp_start + 10, temp_end)
    let script = lumen_src.substring(script_start + 8, script_end)

    // ─── M8: client islands ───
    // An optional <client> block ships verbatim client-side JS for a
    // browser-only widget (charts, maps, canvas…). It's appended to the
    // component's markup as a <script>, so it runs once on first paint and is
    // left untouched by the live DOM morph (cloneNode/innerHTML never re-run
    // scripts). This is the honest island: real client code where you ask for
    // it, with the rest of the component still server-driven — no
    // Varian-in-browser, no hydration mismatch.
    let client_start = lumen_src.index_of("<client>")
    let client_end = lumen_src.index_of("</client>")
    if client_start >= 0 and client_end > client_start {
        let client_js = lumen_src.substring(client_start + 8, client_end)
        template = template + "<script>" + client_js + "</script>"
    }

    let escaped_tpl = _lumen_escape_string(template)
    
    let names = _lumen_extract_fns(script)
    let name_str = ""
    let fn_str = ""
    for idx in 0..names.len() {
        if idx > 0 {
            name_str = name_str + ", "
            fn_str = fn_str + ", "
        }
        name_str = name_str + "\"" + names[idx] + "\""
        fn_str = fn_str + names[idx]
    }
    
    // Braces meant to appear literally in the GENERATED Varian source are
    // written as \{ / \} here, otherwise Varian's lexer would treat them as
    // string interpolation in *this* file before they ever reach the output.
    let out = "// Auto-generated by Lumen compiler from " + name + "\n"
    out = out + "fn _lumen_init_component_" + name + "() \{\n"
    out = out + "    let _tpl = \"" + escaped_tpl + "\"\n"
    out = out + script + "\n"
    out = out + "    return lumen_component(\n"
    out = out + "        state,\n"
    out = out + "        |s| \{ return lumen_render(_tpl, s) \},\n"
    out = out + "        [" + name_str + "],\n"
    out = out + "        [" + fn_str + "]\n"
    out = out + "    )\n"
    out = out + "\}\n"
    out = out + "lumen_register_component(\"" + name + "\", _lumen_init_component_" + name + "())\n"
    return out
}

fn lumen_compile_file(lumen_path, vn_path) {
    let src = io.read_text(lumen_path)
    if src == null {
        throw("Could not read .lumen file: " + lumen_path)
    }
    let slash = lumen_path.last_index_of("/")
    let file_part = lumen_path
    if slash >= 0 {
        file_part = lumen_path.substring(slash + 1, lumen_path.len())
    }
    let dot = file_part.index_of(".lumen")
    let name = file_part.substring(0, dot)
    let code = lumen_compile_source(name, src)
    io.write_text(vn_path, code)
}

// ─── File-based routing (the `vn dev` tool, à la Next/Nuxt) ───
// A pages/ directory maps file names to routes and component names:
//   pages/index.lumen      → "/"        component "Index"
//   pages/about.lumen      → "/about"   component "About"
//   pages/user-card.lumen  → "/user-card" component "UserCard"

fn _lumen_pascal(base) {
    let out = ""
    let cap = true
    let i = 0
    let n = base.len()
    while i < n {
        let c = base.substring(i, i + 1)
        if c == "-" or c == "_" or c == " " {
            cap = true
        } else {
            if cap { out = out + c.upper() } else { out = out + c }
            cap = false
        }
        i = i + 1
    }
    return out
}

fn _lumen_route(base) {
    if base == "index" { return "/" }
    return "/" + base
}

// Scan a pages directory, compile every .lumen file, and emit ONE runnable
// Varian app that registers each component and mounts it at its file route.
// (No eval in the language, so the dev command runs this generated file in a
// second pass — see `vn dev` in main.c.) Returns the page count.
fn _lumen_build_dir(pages_dir, out_path, port) {
    let files = io.list_dir(pages_dir)
    if files == null {
        throw("Lumen: pages directory not found: " + pages_dir)
    }
    let combined = "// Auto-generated by `vn dev` from " + pages_dir + " — do not edit.\n"
    let mounts = ""
    let count = 0
    for i in 0..files.len() {
        let f = files[i]
        if f.ends_with(".lumen") {
            let base = f.substring(0, f.len() - 6)
            let comp_name = _lumen_pascal(base)
            let src = io.read_text(pages_dir + "/" + f)
            if src != null {
                combined = combined + lumen_compile_source(comp_name, src) + "\n"
                let route = _lumen_route(base)
                mounts = mounts + "lumen_mount(app, \"" + route + "\", _lumen_get_component(\"" + comp_name + "\"))\n"
                count = count + 1
            }
        }
    }
    if count == 0 {
        throw("Lumen: no .lumen files found in " + pages_dir)
    }
    // Serve the project's /public dir (favicons, manifest, user assets). Static
    // mounts are consulted only AFTER routing, so page routes always win and a
    // missing file just 404s — mounting at "/" is safe.
    let statics = "app.serve_static(\"/\", \"public\")\n"
    // Serve directly via http.serve (not app.listen) so the framework's own
    // startup line is suppressed — `vn dev` prints its own Lumen console.
    let program = combined + "\nlet app = new_app()\n" + mounts + statics +
                  "http.serve(" + port + ", |req| \{ return app.handle(req) \})\n"
    io.write_text(out_path, program)
    return count
}

// ─── Public API (Milestone 1) ───

// Render a Lumen template string against a context struct -> HTML string.
fn lumen_render(template, ctx) {
    let res = _lumen_render_region(template, 0, template.len(), ctx, null)
    let raw_html = _lumen_bind_events(_validate.get_field(res, "out"))
    return _lumen_process_composition(raw_html, ctx)
}

// Convenience: a 200 text/html Response from a rendered Lumen template.
// Built with http.create_struct (not a `Response { }` literal) so this module
// doesn't depend on zenith.vn's struct declarations being parsed first — the
// vn_modules prelude order isn't guaranteed, and struct literals resolve their
// type at parse time while function calls resolve at runtime.
fn lumen_render_response(template, ctx) {
    return http.create_struct(
        ["status", "body", "content_type"],
        [200, lumen_render(template, ctx), "text/html"]
    )
}

// ─── Lumen M2 — live layer (server-driven interactivity) ───
//
// Build a component struct from its three plain-Varian pieces:
//   state_fn()        -> initial state
//   render_fn(state)  -> rendered HTML string (calls lumen_render internally)
//   handler_names/handler_fns  -> parallel arrays mapping handler name -> fn
//
// Returns a struct with http.create_struct (no parse-order dependency).

fn lumen_component(state_fn, render_fn, handler_names, handler_fns) {
    return http.create_struct(
        ["state_fn", "render_fn", "handler_names", "handler_fns"],
        [state_fn, render_fn, handler_names, handler_fns]
    )
}

// M7 DX: render a component against its initial state to an HTML string.
// Snapshot-friendly: tests can assert on lumen_snapshot(component) directly,
// and it drives any child components through the normal composition pass.
fn lumen_snapshot(component) {
    _lumen_active_child_states = {}
    return (component.render_fn)((component.state_fn)())
}

// Resolve a handler by name against the registered set ONLY.  Returns null if
// the name isn't registered — the caller must then silently ignore the event.
// This is the security gate: never dispatch an arbitrary name from the wire.
fn _lumen_handler(component, name) {
    let names = component.handler_names
    for i in 0..names.len() {
        if names[i] == name { return component.handler_fns[i] }
    }
    return null
}

// Mount a live component on a Zenith app.
//   GET <path>       → initial HTML page (full shell)
//   GET <path>/live  → WebSocket upgrade → live loop
//
// Uses radix_insert directly instead of app.get() because zenith.vn's impl
// methods aren't visible when this module is compiled (prelude order).
fn lumen_mount(app, path, component) {
    // Avoid a double slash for the root route ("/" + "/live" → "//live").
    let ws_path = path + "/live"
    if path == "/" { ws_path = "/live" }
    let page = |req| {
        let state = (component.state_fn)()
        _lumen_active_child_states = {}
        let inner = (component.render_fn)(state)
        let html = _lumen_shell(inner, ws_path)
        return http.create_struct(["status","body","content_type"], [200, html, "text/html"])
    }
    let live = |req| {
        let ws = upgrade_websocket(req)
        if ws == null {
            return http.create_struct(["status","body","content_type"], [400, "bad ws", "text/plain"])
        }
        _lumen_live_loop(ws, component)
        return http.create_struct(["status","body","content_type","_keep_open"], [101, "", "", true])
    }
    radix_insert(app.root, "GET" + path, page, "Lumen page")
    radix_insert(app.root, "GET" + ws_path, live, "Lumen live socket")
}

// ─── M4: DOM patch protocol ───
// Send a render to the client as a minimal splice patch instead of full HTML.
// We compute the longest common ASCII prefix (p) and suffix (q) between the
// previously-sent HTML and the new HTML, and send only the changed middle:
//   { t: "p", s: p, e: q, d: middle }
// The client reconstructs:  new = prev[0:p] + d + prev[len-q:]  then morphs.
// Keeping the prefix/suffix ASCII-only guarantees the server's byte offsets
// equal the client's JS (UTF-16) string indices, so Unicode in the changed
// middle (sent verbatim in d) can never corrupt the splice. prev == null means
// "no baseline yet" (fresh connect) → send the full HTML to (re)sync.
fn _lumen_send_update(ws, prev, html) {
    if prev == null {
        ws.write(json_encode({ t: "html", html: html }))
        return html
    }
    let pn = prev.len()
    let hn = html.len()
    let lim = pn
    if hn < lim { lim = hn }
    let p = 0
    while p < lim {
        let cc = prev.code_at(p)
        if cc != html.code_at(p) { break }
        if cc >= 128 { break }   // keep prefix ASCII so byte offset == JS index
        p = p + 1
    }
    let q = 0
    let qlim = lim - p
    while q < qlim {
        let cp = prev.code_at(pn - 1 - q)
        if cp != html.code_at(hn - 1 - q) { break }
        if cp >= 128 { break }
        q = q + 1
    }
    let mid = html.substring(p, hn - q)
    ws.write(json_encode({ t: "p", s: p, e: q, d: mid }))
    return html
}

// M7 DX: turn a caught handler error into a friendly dev overlay message.
// errors.explain() gives a what/fix block; fall back to the raw value.
fn _lumen_error_msg(e) {
    let detail = errors.explain(e)
    if detail == null { return "" + e }
    return detail
}

// Per-connection event loop.
// ws.read() is NON-BLOCKING (returns "" on EAGAIN, null on close).
// The loop yields via task.yield() when no message is available so the
// cooperative scheduler can service other connections.
fn _lumen_live_loop(ws, component) {
    let state = (component.state_fn)()
    // Initial render discovers and registers any child components so their
    // state exists before the first event referencing them arrives.
    _lumen_active_child_states = {}
    let _initial = (component.render_fn)(state)
    let child_states = _lumen_active_child_states
    let prev = null
    let alive = true
    while alive {
        let msg = ws.read()
        if msg == null {
            alive = false
        } else if msg != "" {
            let ev = json_decode(msg)
            let kind = _validate.get_field(ev, "t")
            if kind == "event" {
                let hname = _validate.get_field(ev, "h")
                let value = _validate.get_field(ev, "v")
                _lumen_active_child_states = child_states
                
                let colon_pos = hname.index_of(":")
                if colon_pos >= 0 {
                    let child_id = hname.substring(0, colon_pos)
                    let child_hname = hname.substring(colon_pos + 1, hname.len())
                    let child_state = _validate.get_field(child_states, child_id)
                    if child_state != null {
                        let comp_name = child_state._comp
                        let comp = _lumen_get_component(comp_name)
                        if comp != null {
                            let handler = _lumen_handler(comp, child_hname)
                            if handler != null {
                                try {
                                    let new_child_state = handler(child_state, value)
                                    new_child_state = _tpl_bind(new_child_state, "_comp", comp_name)
                                    new_child_state = _tpl_bind(new_child_state, "_id", child_id)
                                    child_states = _tpl_bind(child_states, child_id, new_child_state)
                                    _lumen_active_child_states = child_states

                                    let html = (component.render_fn)(state)
                                    child_states = _lumen_active_child_states
                                    prev = _lumen_send_update(ws, prev, html)
                                } catch e {
                                    ws.write(json_encode({ t: "error", msg: _lumen_error_msg(e) }))
                                }
                            }
                        }
                    }
                } else {
                    let handler = _lumen_handler(component, hname)
                    if handler != null {
                        try {
                            state = handler(state, value)
                            let html = (component.render_fn)(state)
                            child_states = _lumen_active_child_states
                            prev = _lumen_send_update(ws, prev, html)
                        } catch e {
                            ws.write(json_encode({ t: "error", msg: _lumen_error_msg(e) }))
                        }
                    }
                }
            }
        } else {
            task.yield()
        }
    }
}

// The <head> Lumen injects into every page: responsive viewport, the full
// favicon set (served from /public — see _lumen_build_dir), a web-app
// manifest, the Degular typeface (loaded via Adobe Fonts), and a base style
// that wires Degular up with a system-font fallback so a page looks right
// even before the webfont arrives. This is the "batteries-included" head
// every Next/Nuxt/Vite starter ships — authors never write it themselves.
fn _lumen_head() {
    return "<meta charset=\"utf-8\">" +
           "<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">" +
           "<title>Lumen</title>" +
           "<meta name=\"theme-color\" content=\"#1b2233\">" +
           "<link rel=\"icon\" href=\"/favicon.ico\" sizes=\"any\">" +
           "<link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon-32x32.png\">" +
           "<link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon-16x16.png\">" +
           "<link rel=\"apple-touch-icon\" href=\"/apple-touch-icon.png\">" +
           "<link rel=\"manifest\" href=\"/manifest.json\">" +
           "<link rel=\"stylesheet\" href=\"https://use.typekit.net/jsj7zpl.css\">" +
           "<style>:root\{--lumen-font:\"degular\",ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif\}" +
           "html\{font-family:var(--lumen-font);-webkit-font-smoothing:antialiased\}" +
           "body\{margin:0\}</style>"
}

// Wrap the rendered component in the live shell (data-lumen-root + client).
fn _lumen_shell(inner, ws_path) {
    return "<!DOCTYPE html><html lang=\"en\"><head>" + _lumen_head() + "</head><body>" +
           "<div data-lumen-root>" + inner + "</div>" +
           "<script>window.__LUMEN_WS__=\"" + ws_path + "\";" + _lumen_client_js() + "</script>" +
           "</body></html>"
}

// Embedded client JavaScript as a Varian string.
// Every brace is escaped as \{/\} so Varian's {expr} interpolation doesn't eat it.
fn _lumen_client_js() {
    return "(function()\{var r=document.querySelector('[data-lumen-root]'),w,P,EV=['click','input','change','submit','keydown','keyup','blur','focus'];function c()\{P=null;w=new WebSocket((location.protocol==='https:'?'wss://':'ws://')+location.host+window.__LUMEN_WS__);w.onmessage=function(e)\{var m=JSON.parse(e.data);if(m.t==='error')\{showErr(m.msg);return\}var eo=document.getElementById('__lumen_err');if(eo)eo.remove();if(m.t==='html')\{P=m.html;morph(r,P)\}else if(m.t==='p')\{P=P.slice(0,m.s)+m.d+P.slice(P.length-m.e);morph(r,P)\}\};w.onclose=function()\{setTimeout(c,1000)\}\}EV.forEach(function(ev)\{document.addEventListener(ev,function(e)\{var a='data-lumen-'+ev,el=e.target.closest&&e.target.closest('['+a+']');if(!el)return;if(ev==='submit')e.preventDefault();var v='value'in el?el.value:null;if(w&&w.readyState===1)w.send(JSON.stringify(\{t:'event',h:el.getAttribute(a),v:v\}))\},true)\});function morph(a,h)\{var t=document.createElement('div');t.innerHTML=h;reconcile(a,t.firstElementChild)\}function reconcile(a,b)\{if(!a||!b)return;if(a.nodeType!==b.nodeType||a.nodeName!==b.nodeName)\{a.replaceWith(b.cloneNode(true));return\}if(a.nodeType===3)\{if(a.nodeValue!==b.nodeValue)a.nodeValue=b.nodeValue;return\}var i,f=document.activeElement,bn=\{\};if(b.attributes)for(i=0;i<b.attributes.length;i++)bn[b.attributes[i].name]=1;if(a.attributes)for(i=a.attributes.length-1;i>=0;i--)if(!bn[a.attributes[i].name])a.removeAttribute(a.attributes[i].name);if(b.attributes)for(i=0;i<b.attributes.length;i++)\{var at=b.attributes[i];if(f&&a===f&&at.name==='value')continue;if(a.getAttribute(at.name)!==at.value)a.setAttribute(at.name,at.value)\}var ac=a.childNodes,bc=b.childNodes,mx=Math.max(ac.length,bc.length);for(i=0;i<mx;i++)\{if(!ac[i])a.appendChild(bc[i].cloneNode(true));else reconcile(ac[i],bc[i])\}while(a.childNodes.length>bc.length)a.removeChild(a.lastChild)\}function showErr(msg)\{var o=document.getElementById('__lumen_err');if(!o)\{o=document.createElement('div');o.id='__lumen_err';o.style.cssText='position:fixed;inset:0;z-index:2147483647;display:flex;align-items:center;justify-content:center;background:rgba(10,14,22,.8);font-family:ui-monospace,SFMono-Regular,Menlo,monospace';o.onclick=function(ev)\{if(ev.target===o)o.remove()\};document.body.appendChild(o)\}o.innerHTML='';var card=document.createElement('div');card.style.cssText='max-width:780px;width:90%;background:#1b2233;border:1px solid #2c3650;border-top:4px solid #f5b829;border-radius:14px;box-shadow:0 24px 70px rgba(0,0,0,.55);overflow:hidden';var hd=document.createElement('div');hd.style.cssText='display:flex;align-items:center;gap:12px;padding:16px 22px;background:linear-gradient(90deg,#222b40,#1b2233)';hd.innerHTML='<svg width=\"26\" height=\"26\" viewBox=\"0 0 48 48\" style=\"flex:none\"><defs><linearGradient id=\"lbg\" x1=\"15\" y1=\"7\" x2=\"33\" y2=\"41\" gradientUnits=\"userSpaceOnUse\"><stop stop-color=\"#ffd24d\"/><stop offset=\"1\" stop-color=\"#f5a623\"/></linearGradient></defs><rect x=\"3\" y=\"3\" width=\"42\" height=\"42\" rx=\"11\" fill=\"#222b40\"/><path d=\"M26 7 L15 27 h7 L19 41 L33 21 h-8 L29 7 Z\" fill=\"url(#lbg)\"/></svg><span style=\"color:#f5b829;font-weight:800;letter-spacing:4px;font-size:15px\">LUMEN</span><span style=\"color:#8b93a7;font-size:13px\">runtime error</span>';var x=document.createElement('span');x.textContent='✕';x.style.cssText='margin-left:auto;color:#8b93a7;cursor:pointer;font-size:15px';x.onclick=function()\{o.remove()\};hd.appendChild(x);var bd=document.createElement('pre');bd.style.cssText='margin:0;padding:22px;color:#e8eaf0;white-space:pre-wrap;word-break:break-word;line-height:1.55;font-size:13px';bd.textContent=msg;card.appendChild(hd);card.appendChild(bd);o.appendChild(card)\}c()\})();"
}
